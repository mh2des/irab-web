---
/**
 * AppHub: signed in product dashboard for /app and /en/app.
 *
 * This is intentionally a product surface, not a marketing section: plan state,
 * upgrade choice, daily usage, and tools are visible at a glance. Firebase still
 * loads lazily only after the local signed in hint passes.
 */
import { PADDLE_ENABLED } from '../lib/paddle';

interface Props { lang?: 'ar' | 'en'; }
const { lang = 'ar' } = Astro.props;
const login = lang === 'ar' ? '/login' : '/en/login';
const home = lang === 'ar' ? '/' : '/en';
const account = lang === 'ar' ? '/account' : '/en/account';
const dir = lang === 'ar' ? 'rtl' : 'ltr';
const titleClass = lang === 'ar' ? 'font-arabic-display' : 'font-display';

const tools = lang === 'ar'
  ? [
      { key: 'analyzer', title: 'محلّل الإعراب', desc: 'إعراب كامل للجمل العربية كلمة بكلمة، مع العلامة والسبب.', href: '/tool', usageKey: '', accent: 'purple', cta: 'حلّل الآن' },
      { key: 'practice', title: 'المدرّب', desc: 'أَعرِب بنفسك أو تدرّب على جمل جاهزة، ثم احصل على تصحيح وشرح لكل كلمة.', href: '/practice/play', usageKey: 'customPractice', accent: 'teal', cta: 'ابدأ التدريب' },
      { key: 'dictionary', title: 'المعجم الذكي', desc: 'معنى الكلمة وجذرها ووزنها وأمثلة عليها في سياقها.', href: '/dictionary', usageKey: 'smartDictionary', accent: 'purple', cta: 'افتح المعجم' },
      { key: 'quran', title: 'إعراب القرآن', desc: 'مكتبة منظمة لإعراب الآيات، مناسبة للمراجعة والدراسة.', href: '/quran', usageKey: '', accent: 'teal', cta: 'تصفّح' },
      { key: 'library', title: 'المكتبة النحوية', desc: '٤٧ كتابًا في النحو والصرف والبلاغة، تُقرأ كاملةً.', href: '/library', usageKey: '', accent: 'purple', cta: 'افتح المكتبة' },
    ]
  : [
      { key: 'analyzer', title: "I'rab analyzer", desc: "Full word by word i'rab for Arabic sentences, with the marker and why.", href: '/en/tool', usageKey: '', accent: 'purple', cta: 'Analyze now' },
      { key: 'practice', title: 'Trainer', desc: 'Parse it yourself or drill ready-made sentences, then get word-by-word correction.', href: '/en/practice/play', usageKey: 'customPractice', accent: 'teal', cta: 'Start training' },
      { key: 'dictionary', title: 'Smart dictionary', desc: 'Meaning, root, pattern, examples, and translation for any word.', href: '/en/dictionary', usageKey: 'smartDictionary', accent: 'purple', cta: 'Open dictionary' },
      { key: 'quran', title: "Quran i'rab", desc: "Browse structured i'rab pages for Quranic verses.", href: '/en/quran', usageKey: '', accent: 'teal', cta: 'Browse' },
      { key: 'library', title: 'Grammar library', desc: '47 works on nahw, sarf, and balagha: read in full.', href: '/en/library', usageKey: '', accent: 'purple', cta: 'Open library' },
    ];

const t = lang === 'ar'
  ? {
      loading: 'جارٍ التحميل…',
      signInTitle: 'سجّل الدخول لفتح تطبيقك',
      signInBody: 'حساب واحد لأدوات إعراب على الويب والتطبيق.',
      signInCta: 'تسجيل الدخول',
      greeting: 'تطبيقي',
      welcome: 'أهلاً',
      planFree: 'الخطة المجانية',
      planPlus: 'إعراب بلس',
      freeNote: 'حدود يومية واضحة، وترقية واحدة تفتح كل شيء.',
      plusNote: 'اشتراكك فعّال على الويب والتطبيق بالحساب نفسه.',
      manage: 'إدارة الحساب',
      signOut: 'تسجيل الخروج',
      today: 'استخدام اليوم',
      practice: 'التدريب',
      dictionary: 'المعجم',
      tools: 'الأدوات',
      toolsBody: 'كل أداة واضحة، وكل حد يظهر في مكانه.',
      upgradeEyebrow: 'إعراب بلس',
      upgradeTitle: 'افتح التجربة الكاملة',
      upgradeBody: 'تحليل غير محدود، تدريب كامل، معجم ذكي، OCR، وشهادات الخطة السنوية. يعمل على الويب و iOS و Android بالحساب نفسه.',
      annual: 'سنوي',
      monthly: 'شهري',
      annualPrice: '٣٥٫٩٩$',
      monthlyPrice: '٤٫٩٩$',
      annualMeta: 'تجربة مجانية ٧ أيام',
      monthlyMeta: 'مرونة شهرية',
      save: 'وفّر ٤٠٪',
      annualCta: 'ابدأ التجربة المجانية',
      monthlyCta: 'اشترك شهريًّا',
      secure: 'دفع آمن عبر Paddle. قد تُضاف الضريبة حسب بلدك.',
      appFallback: 'أو اشترك من التطبيق',
      activatingTitle: 'تم الدفع: جارٍ تفعيل اشتراكك',
      activatingBody: 'سيُفتح كل شيء تلقائيًّا خلال لحظات.',
      leftToday: (n: number) => `${n} متبقٍ`,
      unlimited: 'غير محدود',
      user: 'مستخدم',
      statsKicker: 'تقدّمك',
      statAnalyzed: 'جملة محلَّلة',
      statPracticed: 'تمرين',
      statAvg: 'متوسّط الدقّة',
      statStreak: 'يوم متتالٍ',
      recentTitle: 'النشاط الأخير',
      recentEmpty: 'لا نشاط بعد: ابدأ بتحليل جملة أو تمرين، وسيظهر هنا.',
      seeAll: 'عرض الكل',
    }
  : {
      loading: 'Loading…',
      signInTitle: 'Sign in to open your app',
      signInBody: 'One account for Irab on web and mobile.',
      signInCta: 'Sign in',
      greeting: 'My app',
      welcome: 'Welcome',
      planFree: 'Free plan',
      planPlus: 'Irab Plus',
      freeNote: 'Clear daily limits, with one upgrade for everything.',
      plusNote: 'Your subscription is active on web and mobile with the same account.',
      manage: 'Manage account',
      signOut: 'Sign out',
      today: "Today's usage",
      practice: 'Practice',
      dictionary: 'Dictionary',
      tools: 'Tools',
      toolsBody: 'Every tool, with the limits shown where they matter.',
      upgradeEyebrow: 'Irab Plus',
      upgradeTitle: 'Unlock the full experience',
      upgradeBody: 'Unlimited analysis, full practice, smart dictionary, OCR, and annual certificates. Works on web, iOS, and Android with one account.',
      annual: 'Annual',
      monthly: 'Monthly',
      annualPrice: '$35.99',
      monthlyPrice: '$4.99',
      annualMeta: '7 day free trial',
      monthlyMeta: 'Flexible monthly access',
      save: 'Save 40%',
      annualCta: 'Start free trial',
      monthlyCta: 'Subscribe monthly',
      secure: 'Secure checkout by Paddle. Tax may be added for your country.',
      appFallback: 'or subscribe in the app',
      activatingTitle: 'Payment received: activating your subscription',
      activatingBody: 'Everything unlocks automatically in a few moments.',
      leftToday: (n: number) => `${n} left`,
      unlimited: 'Unlimited',
      user: 'User',
      statsKicker: 'Your progress',
      statAnalyzed: 'analyzed',
      statPracticed: 'practiced',
      statAvg: 'avg accuracy',
      statStreak: 'day streak',
      recentTitle: 'Recent activity',
      recentEmpty: 'No activity yet: analyze a sentence or practice, and it shows up here.',
      seeAll: 'See all',
    };
const historyHref = lang === 'ar' ? '/history' : '/en/history';
const toolHref = lang === 'ar' ? '/tool' : '/en/tool';
const practiceHref = lang === 'ar' ? '/practice/play' : '/en/practice/play';
const premiumFeatures = lang === 'ar'
  ? ['تحليل إعراب غير محدود', 'تدريب كامل مع تصحيح ذكي', 'معجم و OCR وشرح أعمق', 'اشتراك واحد للويب والتطبيق']
  : ['Unlimited i\'rab analysis', 'Full practice with AI correction', 'Dictionary, OCR, and deeper explanations', 'One subscription for web and app'];
---
<div data-hub-root data-lang={lang} data-login={login} data-home={home} dir={dir} class="app-shell w-full max-w-6xl mx-auto">
  <div data-hub-loading aria-busy="true" aria-label={t.loading} class="space-y-6">
    <div class="app-hero skeleton h-56"></div>
    <div class="grid grid-cols-1 lg:grid-cols-[1.08fr_0.92fr] gap-5">
      <div class="skeleton h-96"></div>
      <div class="skeleton h-96"></div>
    </div>
  </div>

  <div data-hub-gate class="hidden app-gate panel-in text-center">
    <div class="mx-auto mb-5 grid place-items-center app-gate-mark" aria-hidden="true">
      <svg viewBox="0 0 24 24" class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 15v2"/><path d="M7 10V8a5 5 0 0 1 10 0v2"/><rect x="5" y="10" width="14" height="10" rx="2"/>
      </svg>
    </div>
    <h2 class:list={[titleClass, 'text-h2 leading-tight mb-3']}>{t.signInTitle}</h2>
    <p class="text-body text-ink/70 dark:text-mist/70 mb-7 max-w-lg mx-auto">{t.signInBody}</p>
    <a href={login} class="btn-primary btn-lg">{t.signInCta}</a>
  </div>

  <div data-hub class="hidden panel-in space-y-6">
    <section class="app-hero">
      <div class="min-w-0">
        <p class="app-kicker">{t.greeting}</p>
        <h1 class:list={[titleClass, 'app-title leading-tight']}>
          <span>{t.welcome}</span>
          <span data-hub-name class="block truncate"></span>
        </h1>
        <p data-plan-note class="app-subtitle">{t.freeNote}</p>
      </div>
      <div class="app-status">
        <span data-hub-plan class="app-plan-pill">{t.planFree}</span>
        <div class="flex gap-2">
          <a href={account} class="btn-ghost app-action">{t.manage}</a>
          <button type="button" data-hub-signout class="btn-ghost app-action app-action-muted">{t.signOut}</button>
        </div>
      </div>
    </section>

    <section class="app-stats" aria-label={t.statsKicker}>
      <div class="stat-tile stat-tile-purple"><span class="stat-tile-num" data-stat="analyze">0</span><span class="stat-tile-label">{t.statAnalyzed}</span></div>
      <div class="stat-tile stat-tile-teal"><span class="stat-tile-num" data-stat="practice">0</span><span class="stat-tile-label">{t.statPracticed}</span></div>
      <div class="stat-tile"><span class="stat-tile-num" data-stat="avg">0%</span><span class="stat-tile-label">{t.statAvg}</span></div>
      <div class="stat-tile"><span class="stat-tile-num" data-stat="streak">0</span><span class="stat-tile-label">{t.statStreak}</span></div>
    </section>

    <div data-hub-activating class="hidden app-activating">
      <svg viewBox="0 0 24 24" class="w-7 h-7 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 6 9 17l-5-5"/>
      </svg>
      <div>
        <p class:list={[titleClass, 'text-h3 leading-tight']}>{t.activatingTitle}</p>
        <p class="text-small text-ink/70 dark:text-mist/70">{t.activatingBody}</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1.08fr_0.92fr] gap-5 items-start">
      <section class="app-panel">
        <div class="flex items-start justify-between gap-4 mb-5">
          <div>
            <p class="app-kicker">{t.tools}</p>
            <h2 class:list={[titleClass, 'text-h2 leading-tight']}>{t.tools}</h2>
            <p class="text-small text-ink/68 dark:text-mist/68 max-w-xl">{t.toolsBody}</p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {tools.map((tool) => (
            <a href={tool.href} data-usage-key={tool.usageKey} class:list={['tool-card', tool.accent === 'teal' ? 'tool-card-teal' : 'tool-card-purple']}>
              <span class="tool-icon" aria-hidden="true">
                {tool.key === 'analyzer' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M4 12h10"/><path d="M4 18h7"/><path d="m16 16 2 2 4-5"/></svg>
                )}
                {tool.key === 'practice' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H6a2 2 0 0 0-2 2v15h16V5a2 2 0 0 0-2-2h-2"/><path d="M8 3h8v4H8z"/><path d="M8 13h8"/><path d="M8 17h5"/></svg>
                )}
                {tool.key === 'dictionary' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M9 7h7"/><path d="M9 11h5"/></svg>
                )}
                {tool.key === 'quran' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6v15"/><path d="M5 4h4a3 3 0 0 1 3 3v14a3 3 0 0 0-3-3H5z"/><path d="M19 4h-4a3 3 0 0 0-3 3"/></svg>
                )}
                {tool.key === 'library' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M9.5 2v15"/><path d="M13 6h3"/></svg>
                )}
              </span>
              <span class="block min-w-0">
                <span class:list={[titleClass, 'tool-title']}>{tool.title}</span>
                <span class="tool-desc">{tool.desc}</span>
              </span>
              <span class="tool-footer">
                <span data-usage class="tool-usage"></span>
                <span class="tool-cta">{tool.cta}<span aria-hidden="true">{lang === 'ar' ? '←' : '→'}</span></span>
              </span>
            </a>
          ))}
        </div>
      </section>

      <aside class="space-y-5">
        <section class="usage-panel">
          <div>
            <p class="app-kicker">{t.today}</p>
            <h2 class:list={[titleClass, 'text-h3 leading-tight']}>{t.today}</h2>
          </div>
          <div class="usage-grid">
            <div class="usage-card">
              <span class="usage-label">{t.practice}</span>
              <strong data-usage-summary="customPractice">0</strong>
            </div>
            <div class="usage-card">
              <span class="usage-label">{t.dictionary}</span>
              <strong data-usage-summary="smartDictionary">0</strong>
            </div>
          </div>
        </section>

        <section data-hub-upgrade class="hidden upgrade-panel">
          <div class="upgrade-head">
            <p class="app-kicker app-kicker-light">{t.upgradeEyebrow}</p>
            <h2 class:list={[titleClass, 'upgrade-title']}>{t.upgradeTitle}</h2>
            <p class="upgrade-body">{t.upgradeBody}</p>
          </div>

          <ul class="upgrade-features" aria-label={t.upgradeTitle}>
            {premiumFeatures.map((feature) => (
              <li>
                <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          {PADDLE_ENABLED ? (
            <div class="upgrade-plans">
              <button type="button" data-paddle-plan="annual" class="plan-card plan-card-featured">
                <span class="plan-badge">{t.save}</span>
                <span class="plan-name">{t.annual}</span>
                <span class="plan-price">{t.annualPrice}</span>
                <span class="plan-meta">{t.annualMeta}</span>
                <span class="plan-cta">{t.annualCta}</span>
              </button>
              <button type="button" data-paddle-plan="monthly" class="plan-card">
                <span class="plan-name">{t.monthly}</span>
                <span class="plan-price">{t.monthlyPrice}</span>
                <span class="plan-meta">{t.monthlyMeta}</span>
                <span class="plan-cta">{t.monthlyCta}</span>
              </button>
            </div>
          ) : (
            <a href={`${home}#cta`} class="btn-primary btn-block">{lang === 'ar' ? 'حمّل التطبيق' : 'Get the app'}</a>
          )}
          <p class="upgrade-fineprint">{t.secure}</p>
          <a href={`${home}#cta`} class="upgrade-link">{t.appFallback}</a>
        </section>
      </aside>
    </div>

    <section data-hub-recent class="app-panel hidden">
      <div class="flex items-center justify-between gap-4 mb-5">
        <div>
          <p class="app-kicker">{t.recentTitle}</p>
          <h2 class:list={[titleClass, 'text-h2 leading-tight']}>{t.recentTitle}</h2>
        </div>
        <a href={historyHref} data-recent-seeall class="btn-ghost app-action hidden">{t.seeAll}</a>
      </div>
      <ul data-recent-list class="recent-list"></ul>
      <p data-recent-empty class="hidden text-small text-ink/65 dark:text-mist/65 py-8 text-center">{t.recentEmpty}</p>
    </section>
  </div>
</div>

<style>
  .app-shell { --panel-pad: clamp(1.25rem, 2.4vw, 2rem); }
  .app-gate,
  .app-hero,
  .app-panel,
  .usage-panel,
  .upgrade-panel,
  .app-activating {
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    box-shadow: var(--shadow-lift);
  }
  :global(.dark) .app-gate,
  :global(.dark) .app-hero,
  :global(.dark) .app-panel,
  :global(.dark) .usage-panel,
  :global(.dark) .upgrade-panel,
  :global(.dark) .app-activating {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
    box-shadow: 0 20px 46px -24px rgb(0 0 0 / 0.75);
  }
  .app-gate { border-radius: 1.25rem; padding: clamp(2rem, 6vw, 4rem); }
  .app-gate-mark {
    width: 4.25rem; height: 4.25rem; border-radius: 1.2rem;
    color: var(--color-purple-deep);
    background: color-mix(in srgb, var(--color-purple) 12%, white);
    border: 1px solid color-mix(in srgb, var(--color-purple) 28%, var(--color-card-edge));
  }
  .app-hero {
    border-radius: 1.25rem;
    padding: clamp(1.4rem, 3vw, 2.25rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .app-hero::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 0;
    width: 0.45rem;
    height: 100%;
    background: var(--color-purple);
  }
  .app-title { font-size: clamp(2.25rem, 5vw, 4.25rem); }
  .app-subtitle { max-width: 42rem; color: color-mix(in srgb, var(--color-ink) 70%, transparent); font-size: var(--text-small); }
  :global(.dark) .app-subtitle { color: color-mix(in srgb, var(--color-mist) 72%, transparent); }
  .app-kicker {
    display: block;
    color: var(--color-purple-deep);
    font-weight: 800;
    font-size: var(--text-caption);
    line-height: 1.35;
  }
  :global(.dark) .app-kicker { color: color-mix(in srgb, var(--color-purple) 85%, white); }
  .app-kicker-light { color: color-mix(in srgb, white 86%, transparent); }
  .app-status { display: flex; flex-direction: column; align-items: flex-end; gap: 1rem; }
  .app-plan-pill {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 8rem;
    border-radius: 999px;
    padding: 0.65rem 1.1rem;
    font-size: var(--text-caption);
    font-weight: 800;
    background: color-mix(in srgb, var(--color-ink) 8%, transparent);
    color: var(--color-ink);
  }
  .app-plan-pill.is-plus {
    background: var(--color-purple);
    color: white;
    box-shadow: 0 14px 26px -12px color-mix(in srgb, var(--color-purple) 70%, transparent);
  }
  .app-action { padding: 0.7rem 1.05rem; font-size: var(--text-caption); }
  .app-action-muted { color: color-mix(in srgb, var(--color-ink) 62%, transparent); }
  :global(.dark) .app-action-muted { color: color-mix(in srgb, var(--color-mist) 68%, transparent); }

  /* Stats strip */
  .app-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.85rem; }
  .stat-tile {
    border-radius: 1.1rem; padding: 1.1rem 1.25rem;
    background: var(--color-card); border: 1px solid var(--color-card-edge); box-shadow: var(--shadow-card);
    display: flex; flex-direction: column; gap: 0.25rem;
  }
  :global(.dark) .stat-tile { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }
  .stat-tile-num { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.9rem, 4vw, 2.7rem); line-height: 1; color: var(--color-ink); }
  :global(.dark) .stat-tile-num { color: var(--color-mist); }
  .stat-tile-purple .stat-tile-num { color: var(--color-purple-deep); }
  :global(.dark) .stat-tile-purple .stat-tile-num { color: color-mix(in srgb, var(--color-purple) 85%, white); }
  .stat-tile-teal .stat-tile-num { color: var(--color-teal); }
  .stat-tile-label { font-size: var(--text-caption); font-weight: 700; color: color-mix(in srgb, var(--color-ink) 66%, transparent); }
  :global(.dark) .stat-tile-label { color: color-mix(in srgb, var(--color-mist) 70%, transparent); }

  /* Recent activity */
  /* .recent-* rows are injected via JS — styled in the global block below. */
  .app-panel,
  .usage-panel {
    border-radius: 1.25rem;
    padding: var(--panel-pad);
  }
  .app-activating {
    border-radius: 1.1rem;
    padding: 1rem 1.25rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    color: var(--color-teal);
    border-color: color-mix(in srgb, var(--color-teal) 45%, var(--color-card-edge));
  }
  .app-activating.hidden { display: none; }
  .tool-card {
    min-height: 15.5rem;
    border-radius: 1rem;
    padding: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    background: color-mix(in srgb, var(--color-paper-soft) 62%, white);
    border: 1px solid var(--color-card-edge);
    transition: transform .22s var(--ease-out-quart), border-color .22s, box-shadow .22s, background-color .22s;
  }
  :global(.dark) .tool-card {
    background: color-mix(in srgb, var(--color-coal) 52%, var(--color-coal-soft));
    border-color: var(--color-coal-edge);
  }
  .tool-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--lift-shadow);
    background: var(--color-card);
  }
  :global(.dark) .tool-card:hover { background: var(--color-coal-soft); }
  .tool-card-purple:hover { border-color: color-mix(in srgb, var(--color-purple) 48%, var(--color-card-edge)); }
  .tool-card-teal:hover { border-color: color-mix(in srgb, var(--color-teal) 52%, var(--color-card-edge)); }
  .tool-icon {
    width: 3.2rem; height: 3.2rem; border-radius: 0.95rem;
    display: grid; place-items: center;
    background: white;
    border: 1px solid var(--color-card-edge);
  }
  :global(.dark) .tool-icon { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }
  .tool-card-purple .tool-icon, .tool-card-purple .tool-cta { color: var(--color-purple-deep); }
  .tool-card-teal .tool-icon, .tool-card-teal .tool-cta { color: var(--color-teal); }
  .tool-icon svg { width: 1.55rem; height: 1.55rem; }
  .tool-title { display: block; font-size: 1.65rem; line-height: 1.25; }
  .tool-desc {
    display: block;
    margin-top: 0.35rem;
    color: color-mix(in srgb, var(--color-ink) 68%, transparent);
    font-size: var(--text-caption);
