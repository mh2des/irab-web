---
/**
 * AppHub — the signed-in web "app" home (/app). One coherent surface tying the
 * tools (analyzer, practice, dictionary, Quran i'rab) + plan status + today's
 * usage into a single dashboard, so the web feels like a product, not scattered
 * pages. Login-gated; Firebase loads only here (lazy). Premium recognized via
 * the same cross-platform entitlement (worker /v1/me + /api/usage).
 *
 * Usage badges are only shown where they're TRUE: practice -> customPractice and
 * dictionary -> smartDictionary map to /api/usage. The web analyzer uses the
 * public demo quota (not /api/usage) and Quran is public, so those carry no
 * daily badge.
 */
import { PADDLE_ENABLED } from '../lib/paddle';
interface Props { lang?: 'ar' | 'en'; }
const { lang = 'ar' } = Astro.props;
const login = lang === 'ar' ? '/login' : '/en/login';
const home = lang === 'ar' ? '/' : '/en';
const account = lang === 'ar' ? '/account' : '/en/account';
const dir = lang === 'ar' ? 'rtl' : 'ltr';

const tools = lang === 'ar'
  ? [
      { key: 'analyzer',   title: 'محلّل الإعراب',  desc: 'ألصق جملة واحصل على إعرابها الكامل كلمة بكلمة.', href: '/tool',          usageKey: '', accent: 'purple' },
      { key: 'practice',   title: 'تمارين الإعراب', desc: 'أَعرِبْ بنفسك واحصل على تصحيحٍ فوري وشرحٍ لكلّ كلمة.', href: '/practice/play', usageKey: 'customPractice', accent: 'teal' },
      { key: 'dictionary', title: 'المعجم الذكي',   desc: 'معاني وجذور وأمثلة وترجمة لأيّ كلمة عربية.',     href: '/dictionary',    usageKey: 'smartDictionary', accent: 'purple' },
      { key: 'quran',      title: 'إعراب القرآن',   desc: 'تصفّح إعراب آيات القرآن الكريم.',                href: '/quran',         usageKey: '', accent: 'teal' },
    ]
  : [
      { key: 'analyzer',   title: "I'rab analyzer",   desc: 'Paste a sentence, get its full word-by-word i\'rab.', href: '/en/tool',          usageKey: '', accent: 'purple' },
      { key: 'practice',   title: 'Practice',         desc: 'Parse it yourself, get instant correction per word.', href: '/en/practice/play', usageKey: 'customPractice', accent: 'teal' },
      { key: 'dictionary', title: 'Smart dictionary', desc: 'Meanings, roots, examples, and translation for any word.', href: '/en/dictionary', usageKey: 'smartDictionary', accent: 'purple' },
      { key: 'quran',      title: "Quran i'rab",      desc: 'Browse the i\'rab of Quranic verses.',          href: '/quran',         usageKey: '', accent: 'teal' },
    ];

const t = lang === 'ar'
  ? {
      hi: 'أهلاً', tools: 'أدواتك', loading: 'جارٍ التحميل…',
      planFree: 'مجاني', planPlus: 'إعراب بلس',
      upgradeTitle: 'افتح كلّ الميزات بلا حدود',
      upgradeBody: 'اشترك في إعراب بلس ليُفتح كلّ شيء على الويب والتطبيق — بالحساب نفسه.',
      upgradeCta: 'حمّل التطبيق', manage: 'إدارة الحساب', signOut: 'تسجيل الخروج',
      open: 'افتح',
      subAnnual: 'اشترك سنويًّا — الأفضل قيمة', subMonthly: 'اشترك شهريًّا', orGetApp: 'أو احصل عليه من التطبيق',
      activatingTitle: '✓ تمّ الدفع — جارٍ تفعيل اشتراكك…', activatingBody: 'لحظات من فضلك، سيُفتح كلّ شيء تلقائيًّا.',
    }
  : {
      hi: 'Welcome', tools: 'Your tools', loading: 'Loading…',
      planFree: 'Free', planPlus: 'Irab Plus',
      upgradeTitle: 'Unlock everything, unlimited',
      upgradeBody: 'Subscribe to Irab Plus and it unlocks across web and app — on the same account.',
      upgradeCta: 'Get the app', manage: 'Manage account', signOut: 'Sign out',
      open: 'Open',
      subAnnual: 'Subscribe yearly — best value', subMonthly: 'Subscribe monthly', orGetApp: 'or get it in the app',
      activatingTitle: '✓ Payment received — activating your subscription…', activatingBody: 'One moment — everything unlocks automatically.',
    };
const titleClass = lang === 'ar' ? 'font-arabic-display' : 'font-display';
---
<div data-hub-root data-lang={lang} data-login={login} data-home={home} dir={dir} class="w-full max-w-3xl mx-auto">
  {/* Loading skeleton until auth resolves */}
  <div data-hub-loading aria-busy="true" aria-label={t.loading}>
    <div class="flex items-center justify-between gap-4 mb-8">
      <div class="space-y-2.5"><div class="skeleton h-4 w-20 rounded-md"></div><div class="skeleton h-8 w-44 rounded-md"></div></div>
      <div class="skeleton h-8 w-24 rounded-full"></div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="skeleton h-32 rounded-2xl"></div><div class="skeleton h-32 rounded-2xl"></div>
      <div class="skeleton h-32 rounded-2xl"></div><div class="skeleton h-32 rounded-2xl"></div>
    </div>
  </div>

  {/* Signed-out gate */}
  <div data-hub-gate class="hidden card panel-in p-8 md:p-10 text-center">
    <h2 class:list={[titleClass, 'text-h2 mb-3']}>{lang === 'ar' ? 'سجّل الدخول لفتح تطبيقك' : 'Sign in to open your app'}</h2>
    <p class="text-body text-ink/75 dark:text-mist/75 mb-7 max-w-md mx-auto">{lang === 'ar' ? 'حسابٌ واحد لكلّ الأدوات على الويب والتطبيق.' : 'One account for all your tools, on web and app.'}</p>
    <a href={login} class="btn-primary btn-lg">{lang === 'ar' ? 'تسجيل الدخول' : 'Sign in'}</a>
  </div>

  {/* Hub */}
  <div data-hub class="hidden panel-in">
    {/* Activating banner — shown after a successful checkout while entitlement syncs */}
    <div data-hub-activating class="hidden mb-6 card p-5 text-center" style="border-color: color-mix(in srgb, var(--color-teal) 35%, var(--color-card-edge));">
      <p class:list={[titleClass, 'text-h3 text-teal leading-tight mb-1']}>{t.activatingTitle}</p>
      <p class="text-small text-ink/75 dark:text-mist/75">{t.activatingBody}</p>
    </div>

    {/* Header: greeting + plan */}
    <div class="flex items-center justify-between gap-4 mb-8">
      <div class="min-w-0">
        <p class="text-small font-semibold text-ink/70 dark:text-mist/70">{t.hi}</p>
        <h1 data-hub-name class:list={[titleClass, 'text-h2 leading-tight truncate']}></h1>
      </div>
      <span data-hub-plan class="badge shrink-0">{t.planFree}</span>
    </div>

    {/* Upgrade nudge (free only) */}
    <div data-hub-upgrade class="hidden mb-8 card p-6 md:p-7" style="border-color: color-mix(in srgb, var(--color-purple) 30%, var(--color-card-edge));">
      <p class:list={[titleClass, 'text-h3 leading-tight mb-1.5']}>{t.upgradeTitle}</p>
      <p class="text-body text-ink/75 dark:text-mist/75 mb-5">{t.upgradeBody}</p>
      {PADDLE_ENABLED ? (
        <Fragment>
          <div class="flex flex-col sm:flex-row gap-3">
            <button type="button" data-paddle-plan="annual" class="btn-primary">{t.subAnnual}</button>
            <button type="button" data-paddle-plan="monthly" class="btn-ghost">{t.subMonthly}</button>
          </div>
          <a href={`${home}#cta`} class="inline-block mt-4 text-small font-medium text-ink/60 dark:text-mist/60 hover:text-purple transition-colors">{t.orGetApp}</a>
        </Fragment>
      ) : (
        <a href={`${home}#cta`} class="btn-primary">{t.upgradeCta}</a>
      )}
    </div>

    {/* Tool grid */}
    <p class="text-small font-semibold text-ink/70 dark:text-mist/70 mb-3">{t.tools}</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      {tools.map((tool) => (
        <a href={tool.href} data-usage-key={tool.usageKey}
          class="group card card-interactive block p-6">
          <div class="flex items-start justify-between gap-3 mb-2">
            <h3 class:list={[titleClass, 'text-h3 leading-tight']}>{tool.title}</h3>
            <span data-usage class:list={['text-small font-semibold shrink-0', tool.accent === 'teal' ? 'text-teal' : 'text-purple']}></span>
          </div>
          <p class="text-small text-ink/75 dark:text-mist/75 leading-relaxed">{tool.desc}</p>
          <span class="mt-3 inline-flex items-center gap-1 text-small font-semibold text-purple group-hover:gap-2 transition-all">
            {t.open}<span aria-hidden="true">{lang === 'ar' ? '←' : '→'}</span>
          </span>
        </a>
      ))}
    </div>

    {/* Footer actions */}
    <div class="flex flex-col sm:flex-row gap-3 items-center">
      <a href={account} class="btn-ghost btn-block sm:w-auto">{t.manage}</a>
      <button type="button" data-hub-signout class="text-small font-semibold text-ink/60 dark:text-mist/60 hover:text-red-600 dark:hover:text-red-400 transition-colors py-2 px-4">{t.signOut}</button>
    </div>
  </div>
</div>

<script>
  import { maybeSignedIn } from '../lib/session';

  const root = document.querySelector<HTMLElement>('[data-hub-root]');
  if (root) {
    const lang = root.dataset.lang === 'en' ? 'en' : 'ar';
    const login = root.dataset.login || '/login';
    const home = root.dataset.home || '/';
    const WORKER = 'https://irab-api-v2.mansourhassan783.workers.dev';
    const q = <T extends Element>(s: string) => root.querySelector<T>(s)!;
    const loadingEl = q<HTMLElement>('[data-hub-loading]');
    const gate = q<HTMLElement>('[data-hub-gate]');
    const hub = q<HTMLElement>('[data-hub]');
    const nameEl = q<HTMLElement>('[data-hub-name]');
    const planEl = q<HTMLElement>('[data-hub-plan]');
    const upgradeEl = q<HTMLElement>('[data-hub-upgrade]');

    const T = lang === 'ar'
      ? { plus: 'إعراب بلس', free: 'مجاني', unlimited: 'غير محدود ⚡', leftToday: (n: number) => `${n} متبقٍ اليوم`, user: 'مستخدم' }
      : { plus: 'Irab Plus', free: 'Free', unlimited: 'Unlimited ⚡', leftToday: (n: number) => `${n} left today`, user: 'User' };

    function setUsage(key: string, text: string) {
      const card = root!.querySelector<HTMLElement>(`[data-usage-key="${key}"]`);
      const span = card?.querySelector<HTMLElement>('[data-usage]');
      if (span) span.textContent = text;
    }

    (async () => {
      if (!maybeSignedIn()) { loadingEl.classList.add('hidden'); gate.classList.remove('hidden'); return; }
      try {
        const [{ onAuth, logout }, { fetchMe }, { forgetSignedIn, rememberSignedIn }] =
          await Promise.all([import('../lib/auth'), import('../lib/entitlement'), import('../lib/session')]);

        q<HTMLButtonElement>('[data-hub-signout]').addEventListener('click', async () => {
          try { await logout(); } catch {}
          forgetSignedIn();
          window.location.assign(home);
        });

        onAuth(async (u) => {
          loadingEl.classList.add('hidden');
          if (!u) { forgetSignedIn(); gate.classList.remove('hidden'); return; }
          rememberSignedIn();
          hub.classList.remove('hidden');

          const name = u.displayName || (u.email ? u.email.split('@')[0] : T.user);
          nameEl.textContent = name;

          let idToken: string | null = null;
          try { idToken = await u.getIdToken(); } catch {}

          // Plan badge via /v1/me
          let premium = false;
          try { const me = await fetchMe(u); premium = me?.premium === true; } catch {}
          if (premium) {
            planEl.textContent = T.plus;
            planEl.className = 'badge badge-brand shrink-0';
          } else {
            planEl.textContent = T.free;
            upgradeEl.classList.remove('hidden');
            // Web checkout buttons (only rendered when PADDLE_ENABLED) — tag the
            // purchase with this user's UID so the webhook grants their entitlement.
            root!.querySelectorAll<HTMLButtonElement>('[data-paddle-plan]').forEach((btn) => {
              btn.addEventListener('click', async () => {
                const plan = btn.dataset.paddlePlan === 'monthly' ? 'monthly' : 'annual';
                btn.disabled = true;
                try {
                  const { openCheckout } = await import('../lib/paddle');
                  await openCheckout({
                    plan, firebaseUid: u.uid, email: u.email || undefined, lang,
                    onComplete: async () => {
                      const act = q<HTMLElement>('[data-hub-activating]');
                      act.classList.remove('hidden');
                      upgradeEl.classList.add('hidden');
                      act.scrollIntoView({ behavior: 'smooth', block: 'center' });
                      // Poll entitlement until RevenueCat reflects the Paddle purchase, then refresh.
                      for (let i = 0; i < 12; i++) {
                        await new Promise((r) => setTimeout(r, 3000));
                        try { const me2 = await fetchMe(u); if (me2?.premium) break; } catch {}
                      }
                      window.location.reload();
                    },
                  });
                } catch (e) {
                  console.error('paddle checkout failed', e);
                } finally {
                  btn.disabled = false;
                }
              });
            });
          }

          // Today's usage (truthful badges only — practice + dictionary)
          if (idToken) {
            try {
              const res = await fetch(`${WORKER}/api/usage`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${idToken}` },
                body: '{}',
              });
              if (res.ok) {
                const j = await res.json();
                const usage = j?.data?.usage || {};
                for (const key of ['customPractice', 'smartDictionary']) {
                  const u2 = usage[key];
                  if (premium) { setUsage(key, T.unlimited); continue; }
                  if (u2 && typeof u2.remaining === 'number' && u2.limit !== -1) {
                    setUsage(key, T.leftToday(u2.remaining));
                  }
                }
              } else if (premium) {
                setUsage('customPractice', T.unlimited);
                setUsage('smartDictionary', T.unlimited);
              }
            } catch {
              if (premium) { setUsage('customPractice', T.unlimited); setUsage('smartDictionary', T.unlimited); }
            }
          }
        });
      } catch { loadingEl.classList.add('hidden'); gate.classList.remove('hidden'); }
    })();
  }
</script>
