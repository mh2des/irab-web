  }
  :global(.dark) .tool-desc { color: color-mix(in srgb, var(--color-mist) 72%, transparent); }
  .tool-footer {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }
  .tool-usage {
    min-height: 1.75rem;
    color: color-mix(in srgb, var(--color-ink) 58%, transparent);
    font-size: var(--text-caption);
    font-weight: 800;
  }
  :global(.dark) .tool-usage { color: color-mix(in srgb, var(--color-mist) 70%, transparent); }
  .tool-cta {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
    font-size: var(--text-caption);
    font-weight: 800;
    white-space: nowrap;
  }
  .usage-panel { display: grid; gap: 1rem; }
  .usage-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
  .usage-card {
    border-radius: 1rem;
    border: 1px solid var(--color-card-edge);
    background: color-mix(in srgb, var(--color-paper-soft) 58%, white);
    padding: 1rem;
  }
  :global(.dark) .usage-card { background: color-mix(in srgb, var(--color-coal) 48%, var(--color-coal-soft)); border-color: var(--color-coal-edge); }
  .usage-label {
    display: block;
    font-size: var(--text-caption);
    color: color-mix(in srgb, var(--color-ink) 62%, transparent);
    font-weight: 700;
  }
  :global(.dark) .usage-label { color: color-mix(in srgb, var(--color-mist) 68%, transparent); }
  .usage-card strong {
    display: block;
    margin-top: 0.15rem;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.55rem);
    line-height: 1.05;
    color: var(--color-ink);
  }
  :global(.dark) .usage-card strong { color: var(--color-mist); }
  .upgrade-panel {
    border-radius: 1.25rem;
    padding: var(--panel-pad);
    color: white;
    background: var(--color-ink);
    border-color: color-mix(in srgb, var(--color-purple) 42%, transparent);
  }
  :global(.dark) .upgrade-panel {
    background: color-mix(in srgb, var(--color-coal-soft) 72%, var(--color-purple-deep));
  }
  .upgrade-title { font-size: clamp(2rem, 4vw, 3rem); line-height: 1.08; }
  .upgrade-body {
    margin-top: 0.75rem;
    color: color-mix(in srgb, white 78%, transparent);
    font-size: var(--text-small);
    line-height: 1.55;
  }
  .upgrade-features {
    list-style: none;
    display: grid;
    gap: 0.55rem;
    margin: 1rem 0 0;
    padding: 0;
  }
  .upgrade-features li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: color-mix(in srgb, white 88%, transparent);
    font-size: var(--text-caption);
    font-weight: 800;
    line-height: 1.35;
  }
  .upgrade-features svg {
    width: 1.25rem;
    height: 1.25rem;
    flex: none;
    color: var(--color-teal);
    background: white;
    border-radius: 999px;
    padding: 0.18rem;
  }
  .upgrade-plans { display: grid; gap: 0.85rem; margin-top: 1.25rem; }
  .plan-card {
    position: relative;
    width: 100%;
    text-align: start;
    border-radius: 1rem;
    padding: 1.05rem;
    background: rgb(255 255 255 / 0.1);
    border: 1px solid rgb(255 255 255 / 0.18);
    color: white;
    transition: transform .2s var(--ease-out-quart), background-color .2s, border-color .2s;
  }
  .plan-card:hover {
    transform: translateY(-3px);
    background: rgb(255 255 255 / 0.16);
    border-color: rgb(255 255 255 / 0.38);
  }
  .plan-card-featured {
    background: white;
    color: var(--color-ink);
    border-color: white;
    box-shadow: 0 18px 34px -18px rgb(0 0 0 / 0.55);
  }
  .plan-card-featured:hover { background: white; border-color: white; }
  .plan-badge {
    position: absolute;
    inset-inline-end: 1rem;
    top: 1rem;
    border-radius: 999px;
    padding: 0.26rem 0.7rem;
    background: var(--color-teal);
    color: white;
    font-size: 0.95rem;
    font-weight: 900;
  }
  .plan-name,
  .plan-meta,
  .plan-cta { display: block; }
  .plan-name { font-size: var(--text-caption); font-weight: 900; opacity: 0.78; }
  .plan-price { display: block; margin-top: 0.2rem; font-family: var(--font-display); font-size: 2.45rem; line-height: 1; font-weight: 700; }
  .plan-meta { margin-top: 0.2rem; font-size: var(--text-caption); opacity: 0.76; }
  .plan-cta {
    margin-top: 0.8rem;
    border-radius: 999px;
    padding: 0.62rem 0.9rem;
    text-align: center;
    font-size: var(--text-caption);
    font-weight: 900;
    background: rgb(255 255 255 / 0.16);
  }
  .plan-card-featured .plan-cta { background: var(--color-purple); color: white; }
  .upgrade-fineprint {
    margin-top: 1rem;
    color: color-mix(in srgb, white 66%, transparent);
    font-size: var(--text-caption);
    line-height: 1.45;
  }
  .upgrade-link {
    display: inline-flex;
    margin-top: 0.55rem;
    color: white;
    font-size: var(--text-caption);
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
  @media (max-width: 780px) {
    .app-hero { grid-template-columns: 1fr; }
    .app-status { align-items: stretch; }
    .app-status > .flex { flex-direction: column; }
    .app-action { width: 100%; }
    .usage-grid { grid-template-columns: 1fr; }
    .tool-card { min-height: 14rem; }
    .app-stats { grid-template-columns: 1fr 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .tool-card:hover,
    .plan-card:hover { transform: none; }
  }
</style>

<style is:global>
  /* Recent-activity rows are built in JS (renderRecent), so they must be styled
     globally — scoped styles never reach injected nodes. recent-* prefixed. */
  .recent-list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; margin: 0; padding: 0; }
  .recent-item {
    display: flex; align-items: center; gap: 0.8rem;
    border-radius: 0.85rem; padding: 0.7rem 0.95rem;
    border: 1px solid var(--color-card-edge); background: var(--color-card);
    box-shadow: var(--shadow-card);
    text-decoration: none; transition: transform .16s var(--ease-out-quart), border-color .16s, box-shadow .16s;
  }
  .dark .recent-item { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }
  .recent-item:hover { transform: translateY(-1px); border-color: color-mix(in srgb, var(--color-purple) 38%, var(--color-card-edge)); box-shadow: var(--shadow-lift); }
  .recent-ic { width: 2.1rem; height: 2.1rem; border-radius: 0.6rem; display: grid; place-items: center; flex: none; }
  .recent-ic svg { width: 1rem; height: 1rem; }
  .recent-ic-analyze { color: var(--color-purple-deep); background: color-mix(in srgb, var(--color-purple) 12%, transparent); }
  .recent-ic-practice { color: var(--color-teal); background: color-mix(in srgb, var(--color-teal) 12%, transparent); }
  .recent-main { min-width: 0; flex: 1; }
  .recent-sentence { display: block; font-family: var(--font-arabic-classical); font-size: 1.3rem; line-height: 1.45; color: var(--color-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .dark .recent-sentence { color: var(--color-mist); }
  .recent-meta { display: block; margin-top: 0.1rem; font-size: 0.98rem; color: color-mix(in srgb, var(--color-ink) 60%, transparent); }
  .dark .recent-meta { color: color-mix(in srgb, var(--color-mist) 64%, transparent); }
  .recent-time { flex: none; font-family: var(--font-mono); font-size: 0.92rem; color: color-mix(in srgb, var(--color-ink) 52%, transparent); }
  .dark .recent-time { color: color-mix(in srgb, var(--color-mist) 58%, transparent); }
</style>

<script>
  import { maybeSignedIn } from '../lib/session';
  import { getStats, getHistory, formatAgo } from '../lib/history';

  const root = document.querySelector<HTMLElement>('[data-hub-root]');
  if (root) {
    const lang = root.dataset.lang === 'en' ? 'en' : 'ar';
    const login = root.dataset.login || '/login';
    const home = root.dataset.home || '/';
    const WORKER = 'https://irab-api-v2.mansourhassan783.workers.dev';
    const q = <T extends Element>(s: string) => root.querySelector<T>(s)!;
    const loadingEl = q<HTMLElement>('[data-hub-loading]');
    const gate = q<HTMLElement>('[data-hub-gate]');
    const hub = q<HTMLElement>('[data-hub]');
    const nameEl = q<HTMLElement>('[data-hub-name]');
    const planEl = q<HTMLElement>('[data-hub-plan]');
    const planNoteEl = q<HTMLElement>('[data-plan-note]');
    const upgradeEl = q<HTMLElement>('[data-hub-upgrade]');

    const T = lang === 'ar'
      ? {
          plus: 'إعراب بلس',
          free: 'الخطة المجانية',
          plusNote: 'اشتراكك فعّال على الويب والتطبيق بالحساب نفسه.',
          freeNote: 'حدود يومية واضحة، وترقية واحدة تفتح كل شيء.',
          unlimited: 'غير محدود',
          leftToday: (n: number) => `${n} متبقٍ`,
          user: 'مستخدم',
        }
      : {
          plus: 'Irab Plus',
          free: 'Free plan',
          plusNote: 'Your subscription is active on web and mobile with the same account.',
          freeNote: 'Clear daily limits, with one upgrade for everything.',
          unlimited: 'Unlimited',
          leftToday: (n: number) => `${n} left`,
          user: 'User',
        };

    function setUsage(key: string, text: string) {
      const card = root!.querySelector<HTMLElement>(`[data-usage-key="${key}"]`);
      const span = card?.querySelector<HTMLElement>('[data-usage]');
      const summary = root!.querySelector<HTMLElement>(`[data-usage-summary="${key}"]`);
      if (span) span.textContent = text;
      if (summary) summary.textContent = text;
    }

    const escapeHtml = (s: string) => (s || '').replace(/[&<>"]/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' } as Record<string, string>)[c]);

    function renderStats(uid: string) {
      const stats = getStats(uid);
      const set = (k: string, v: string) => { const el = root!.querySelector<HTMLElement>(`[data-stat="${k}"]`); if (el) el.textContent = v; };
      set('analyze', String(stats.analyzeCount));
      set('practice', String(stats.practiceCount));
      set('avg', stats.avgScore == null ? '0%' : `${stats.avgScore}%`);
      set('streak', String(stats.streak));
    }

    function renderRecent(uid: string) {
      const section = root!.querySelector<HTMLElement>('[data-hub-recent]');
      const list = root!.querySelector<HTMLElement>('[data-recent-list]');
      const empty = root!.querySelector<HTMLElement>('[data-recent-empty]');
      const seeAll = root!.querySelector<HTMLElement>('[data-recent-seeall]');
      if (!section || !list) return;
      section.classList.remove('hidden');
      const items = getHistory(uid).slice(0, 5);
      if (!items.length) { empty?.classList.remove('hidden'); return; }
      seeAll?.classList.remove('hidden');
      const toolBase = lang === 'ar' ? '/tool' : '/en/tool';
      const practiceBase = lang === 'ar' ? '/practice/play' : '/en/practice/play';
      const icA = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M4 12h10"/><path d="M4 18h7"/><path d="m16 16 2 2 4-5"/></svg>';
      const icP = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H6a2 2 0 0 0-2 2v15h16V5a2 2 0 0 0-2-2h-2"/><path d="M8 3h8v4H8z"/><path d="M8 13h8"/><path d="M8 17h5"/></svg>';
      list.replaceChildren();
      for (const it of items) {
        const isA = it.kind === 'analyze';
        const meta = isA
          ? (it.wordCount ? `${it.wordCount} ${lang === 'ar' ? 'كلمة' : 'words'}` : (lang === 'ar' ? 'تحليل' : 'analysis'))
          : (typeof it.score === 'number'
              ? `${Math.round(it.score * 100)}%${it.level ? ' · ' + it.level : ''}`
              : (lang === 'ar' ? 'تمرين' : 'practice'));
        const a = document.createElement('a');
        a.className = 'recent-item';
        a.href = `${isA ? toolBase : practiceBase}?h=${encodeURIComponent(it.id)}`;
        a.innerHTML =
          `<span class="recent-ic recent-ic-${isA ? 'analyze' : 'practice'}" aria-hidden="true">${isA ? icA : icP}</span>` +
          `<span class="recent-main"><span class="recent-sentence" dir="rtl">${escapeHtml(it.sentence)}</span><span class="recent-meta">${escapeHtml(meta)}</span></span>` +
          `<span class="recent-time">${escapeHtml(formatAgo(it.ts, lang))}</span>`;
        list.appendChild(a);
      }
    }

    (async () => {
      if (!maybeSignedIn()) {
        loadingEl.classList.add('hidden');
        gate.classList.remove('hidden');
        return;
      }
      try {
        const [{ onAuth, logout }, { fetchMe }, { forgetSignedIn, rememberSignedIn }] =
          await Promise.all([import('../lib/auth'), import('../lib/entitlement'), import('../lib/session')]);

        q<HTMLButtonElement>('[data-hub-signout]').addEventListener('click', async () => {
          try { await logout(); } catch {}
          forgetSignedIn();
          window.location.assign(home);
        });

        onAuth(async (u) => {
          loadingEl.classList.add('hidden');
          if (!u) {
            forgetSignedIn();
            gate.classList.remove('hidden');
            return;
          }
          rememberSignedIn();
          hub.classList.remove('hidden');

          const name = u.displayName || (u.email ? u.email.split('@')[0] : T.user);
          nameEl.textContent = name;

          // Stats + recent activity from this account's saved history.
          try { renderStats(u.uid); renderRecent(u.uid); } catch {}

          let idToken: string | null = null;
          try { idToken = await u.getIdToken(); } catch {}

          let premium = false;
          try {
            const me = await fetchMe(u);
            premium = me?.premium === true;
          } catch {}

          if (premium) {
            planEl.textContent = T.plus;
            planEl.className = 'app-plan-pill is-plus';
            planNoteEl.textContent = T.plusNote;
            setUsage('customPractice', T.unlimited);
            setUsage('smartDictionary', T.unlimited);
          } else {
            planEl.textContent = T.free;
            planEl.className = 'app-plan-pill';
            planNoteEl.textContent = T.freeNote;
            upgradeEl.classList.remove('hidden');

            root!.querySelectorAll<HTMLButtonElement>('[data-paddle-plan]').forEach((btn) => {
              btn.addEventListener('click', async () => {
                const plan = btn.dataset.paddlePlan === 'monthly' ? 'monthly' : 'annual';
                btn.disabled = true;
                try {
                  const { openCheckout } = await import('../lib/paddle');
                  await openCheckout({
                    plan,
                    firebaseUid: u.uid,
                    email: u.email || undefined,
                    lang,
                    onComplete: async () => {
                      const act = q<HTMLElement>('[data-hub-activating]');
                      act.classList.remove('hidden');
                      upgradeEl.classList.add('hidden');
                      act.scrollIntoView({ behavior: 'smooth', block: 'center' });
                      for (let i = 0; i < 12; i++) {
                        await new Promise((r) => setTimeout(r, 3000));
                        try {
                          const me2 = await fetchMe(u);
                          if (me2?.premium) break;
                        } catch {}
                      }
                      window.location.reload();
                    },
                  });
                } catch (e) {
                  console.error('paddle checkout failed', e);
                } finally {
                  btn.disabled = false;
                }
              });
            });
          }

          if (idToken) {
            try {
              const res = await fetch(`${WORKER}/api/usage`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${idToken}` },
                body: '{}',
              });
              if (res.ok) {
                const j = await res.json();
                const usage = j?.data?.usage || {};
                for (const key of ['customPractice', 'smartDictionary']) {
                  const u2 = usage[key];
                  if (premium) {
                    setUsage(key, T.unlimited);
                    continue;
                  }
                  if (u2 && typeof u2.remaining === 'number' && u2.limit !== -1) {
                    setUsage(key, T.leftToday(u2.remaining));
                  }
                }
              }
            } catch {
              if (premium) {
                setUsage('customPractice', T.unlimited);
                setUsage('smartDictionary', T.unlimited);
              }
            }
          }
        });
      } catch {
        loadingEl.classList.add('hidden');
        gate.classList.remove('hidden');
      }
    })();
  }
</script>
