---
/**
 * LegalDoc — themed wrapper for the privacy / terms documents.
 *
 * The legal body HTML is extracted verbatim from the original standalone
 * pages (src/data/legal/*.html) and injected here, then fully re-skinned
 * with the site design system: Aref Ruqaa / Lateef fonts, brand colors,
 * the lattice background, section cards, themed tables, scroll reveal, and
 * a bilingual (ع / EN) toggle. Arabic is shown by default.
 */
import Nav from './Nav.astro';
import Footer from './sections/Footer.astro';
import Container from './Container.astro';

interface Props {
  kind: 'privacy' | 'terms';
  body: string;
}
const { kind, body } = Astro.props;

const meta = {
  privacy: {
    titleAr: 'سياسة الخصوصية', titleEn: 'Privacy Policy',
    other: { href: '/terms', ar: 'شروط الخدمة', en: 'Terms of Service' },
  },
  terms: {
    titleAr: 'شروط الخدمة', titleEn: 'Terms of Service',
    other: { href: '/privacy', ar: 'سياسة الخصوصية', en: 'Privacy Policy' },
  },
}[kind];

const updatedAr = '١ مايو ٢٠٢٦';
const updatedEn = 'May 1, 2026';
---
<Nav lang="ar" />

<main class="legal" data-legal>
  {/* Hero */}
  <header class="legal-hero">
    <img
      src="/brand-watermark.png"
      alt=""
      aria-hidden="true"
      class="legal-watermark dark:invert"
    />
    <Container size="narrow">
      <div class="legal-hero-inner">
        <p class="eyebrow legal-back">
          <a href="/">→ إعراب</a>
          <span class="ar">قانوني</span><span class="en">Legal</span>
        </p>

        <h1 class="legal-title">
          <span class="ar font-arabic-display">{meta.titleAr}</span>
          <span class="en font-display">{meta.titleEn}</span>
        </h1>

        <div class="legal-hero-meta">
          <span class="legal-updated">
            <span class="ar">آخر تحديث: {updatedAr}</span>
            <span class="en">Last updated: {updatedEn}</span>
          </span>

          {/* Language toggle */}
          <div class="legal-lang" role="group" aria-label="Language">
            <button type="button" data-lang="ar" class="is-active">ع</button>
            <button type="button" data-lang="en">EN</button>
          </div>
        </div>
      </div>
    </Container>
  </header>

  {/* Body */}
  <Container size="narrow">
    <div class="legal-body" set:html={body} />

    <div class="legal-foot">
      <p class="ar font-arabic">
        لأي سؤال حول هذه الوثيقة، راسلنا على <a href="mailto:support@irab.app">support@irab.app</a>.
        اطّلع أيضًا على <a href={meta.other.href}>{meta.other.ar}</a>.
      </p>
      <p class="en">
        Questions about this document? Email <a href="mailto:support@irab.app">support@irab.app</a>.
        See also our <a href={meta.other.href}>{meta.other.en}</a>.
      </p>
    </div>
  </Container>
</main>

<Footer lang="ar" />

<style>
  /* ── Language visibility (Arabic default) ─────────────────────────── */
  .legal :global(.en) { display: none; }
  .legal :global(.ar) { display: revert; direction: rtl; text-align: right; }
  .legal.show-en :global(.ar) { display: none; }
  .legal.show-en :global(.en) { display: revert; direction: ltr; text-align: left; }

  /* ── Hero ─────────────────────────────────────────────────────────── */
  .legal-hero { position: relative; overflow: hidden; border-bottom: 1px solid var(--color-stone); }
  :global(.dark) .legal-hero { border-color: var(--color-coal-edge); }
  .legal-watermark {
    pointer-events: none; user-select: none;
    position: absolute; top: 50%; left: -6%; transform: translateY(-50%);
    width: 40%; max-width: 460px; opacity: 0.05;
  }
  :global(.dark) .legal-watermark { opacity: 0.10; }
  .legal-hero-inner { position: relative; padding: 4.5rem 0 3rem; }
  .legal-back { margin-bottom: 1.4rem; }
  .legal-back a { color: inherit; transition: color .2s; }
  .legal-back a:hover { color: var(--color-ink); }
  :global(.dark) .legal-back a:hover { color: var(--color-mist); }
  .legal-title { font-size: clamp(2.4rem, 6vw, 4.2rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.01em; }

  .legal-hero-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 1.25rem; margin-top: 1.75rem; }
  .legal-updated { font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: .02em; color: color-mix(in srgb, var(--color-ink) 50%, transparent); }
  :global(.dark) .legal-updated { color: color-mix(in srgb, var(--color-mist) 50%, transparent); }

  .legal-lang { display: inline-flex; gap: 0.2rem; padding: 0.25rem; border-radius: 9999px; background: color-mix(in srgb, var(--color-stone) 45%, transparent); }
  :global(.dark) .legal-lang { background: color-mix(in srgb, var(--color-coal-edge) 50%, transparent); }
  .legal-lang button {
    font-family: var(--font-mono); font-size: 0.78rem; line-height: 1;
    padding: 0.4rem 0.8rem; border-radius: 9999px; cursor: pointer;
    color: color-mix(in srgb, var(--color-ink) 55%, transparent);
    background: transparent; border: 0; transition: background-color .2s, color .2s, box-shadow .2s;
  }
  :global(.dark) .legal-lang button { color: color-mix(in srgb, var(--color-mist) 55%, transparent); }
  .legal-lang button.is-active {
    color: var(--color-purple-deep);
    background: var(--color-paper);
    box-shadow: 0 1px 2px color-mix(in srgb, var(--color-ink) 12%, transparent);
  }
  :global(.dark) .legal-lang button.is-active { color: var(--color-mist); background: var(--color-coal-soft); }

  /* ── Body ─────────────────────────────────────────────────────────── */
  .legal-body { padding: 3rem 0 1rem; font-size: 1.0625rem; color: color-mix(in srgb, var(--color-ink) 82%, transparent); }
  :global(.dark) .legal-body { color: color-mix(in srgb, var(--color-mist) 82%, transparent); }

  /* Section cards */
  .legal-body :global(.section) {
    margin: 0 0 1.5rem;
    padding: 2rem 2.25rem;
    border-radius: 18px;
    background: color-mix(in srgb, var(--color-paper) 72%, transparent);
    border: 1px solid var(--color-stone);
    box-shadow: 0 2px 8px -4px color-mix(in srgb, var(--color-ink) 10%, transparent);
  }
  :global(.dark) .legal-body :global(.section) { background: color-mix(in srgb, var(--color-coal-soft) 60%, transparent); border-color: var(--color-coal-edge); }

  .legal-body :global(.section-header) { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
  .legal-body :global(.s-icon) {
    flex: none; width: 2.9rem; height: 2.9rem; border-radius: 13px; display: grid; place-items: center;
    color: var(--color-purple);
    background: color-mix(in srgb, var(--color-purple) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-purple) 22%, transparent);
  }
  .legal-body :global(.s-icon svg) { width: 1.45rem; height: 1.45rem; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .legal-body :global(.s-eyebrow) { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: .14em; text-transform: uppercase; color: color-mix(in srgb, var(--color-ink) 42%, transparent); margin-bottom: 0.15rem; }
  :global(.dark) .legal-body :global(.s-eyebrow) { color: color-mix(in srgb, var(--color-mist) 42%, transparent); }
  .legal-body :global(.section-title) { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; line-height: 1.2; color: var(--color-ink); }
  :global(.dark) .legal-body :global(.section-title) { color: var(--color-mist); }
  .legal-body :global(.section-title.ar) { font-family: var(--font-arabic-display); }
  .legal-body :global(.section-title.en) { font-family: var(--font-display); }

  /* Prose */
  .legal-body :global(.ar) { font-family: var(--font-arabic); }
  .legal-body :global(.en) { font-family: var(--font-sans); }
  .legal-body :global(p) { margin: 0 0 1rem; line-height: 2; }
  .legal-body :global(p:last-child) { margin-bottom: 0; }
  .legal-body :global(h3) { font-size: 1.25rem; font-weight: 700; margin: 1.75rem 0 0.65rem; color: var(--color-ink); }
  :global(.dark) .legal-body :global(h3) { color: var(--color-mist); }
  .legal-body :global(.ar h3) { font-family: var(--font-arabic-display); }
  .legal-body :global(.en h3) { font-family: var(--font-display); }
  .legal-body :global(strong) { color: var(--color-ink); font-weight: 600; }
  :global(.dark) .legal-body :global(strong) { color: var(--color-mist); }
  .legal-body :global(a) { color: var(--color-purple); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; transition: color .2s; }
  .legal-body :global(a:hover) { color: var(--color-purple-deep); }
  .legal-body :global(ul), .legal-body :global(ol) { margin: 0.5rem 0 1.1rem; padding-inline-start: 1.5rem; }
  .legal-body :global(ul) { list-style: disc; }
  .legal-body :global(ol) { list-style: decimal; }
  .legal-body :global(li) { margin-bottom: 0.45rem; line-height: 1.9; }
  .legal-body :global(li::marker) { color: color-mix(in srgb, var(--color-purple) 70%, transparent); }

  /* Tables */
  .legal-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.1rem 0 1.4rem; font-size: 0.95rem; }
  .legal-body :global(th), .legal-body :global(td) { text-align: start; padding: 0.7rem 0.9rem; border: 1px solid var(--color-stone); vertical-align: top; }
  :global(.dark) .legal-body :global(th), :global(.dark) .legal-body :global(td) { border-color: var(--color-coal-edge); }
  .legal-body :global(thead th) { background: var(--color-paper-soft); font-weight: 700; color: var(--color-ink); }
  :global(.dark) .legal-body :global(thead th) { background: var(--color-coal); color: var(--color-mist); }
  .legal-body :global(tbody tr:nth-child(even) td) { background: color-mix(in srgb, var(--color-paper-soft) 55%, transparent); }
  :global(.dark) .legal-body :global(tbody tr:nth-child(even) td) { background: color-mix(in srgb, var(--color-coal-soft) 40%, transparent); }

  /* Closing note */
  .legal-foot { margin: 2rem 0 1rem; padding: 1.75rem 2rem; border-radius: 16px; border: 1px dashed var(--color-stone); font-size: 1.0625rem; line-height: 2; color: color-mix(in srgb, var(--color-ink) 70%, transparent); }
  :global(.dark) .legal-foot { border-color: var(--color-coal-edge); color: color-mix(in srgb, var(--color-mist) 70%, transparent); }
  .legal-foot a { color: var(--color-purple); text-decoration: underline; text-underline-offset: 3px; }
  .legal-foot .ar { font-family: var(--font-arabic); }

  /* Lucide icons throughout the body */
  .legal-body :global(.lucide) { fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .legal-body :global(.lucide-sm) { width: 1.1rem; height: 1.1rem; flex: none; }
  .legal-body :global(.lucide-lg) { width: 1.45rem; height: 1.45rem; }

  /* Callouts — tinted info boxes with a colored icon */
  .legal-body :global(.callout) {
    --c: var(--color-purple);
    display: flex; gap: 0.85rem; align-items: flex-start;
    margin: 1.25rem 0; padding: 1.1rem 1.3rem; border-radius: 14px; line-height: 1.95;
    background: color-mix(in srgb, var(--c) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 26%, transparent);
  }
  .legal-body :global(.callout .callout-ico) { color: var(--c); margin-top: 0.2rem; }
  .legal-body :global(.callout.purple) { --c: var(--color-purple); }
  .legal-body :global(.callout.green)  { --c: #10B981; }
  .legal-body :global(.callout.gold)   { --c: #E0A82E; }
  .legal-body :global(.callout.red)    { --c: #EF4444; }

  /* Rights grid */
  .legal-body :global(.rights-grid) { display: grid; grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr)); gap: 0.85rem; margin: 1rem 0 1.25rem; }
  .legal-body :global(.right-card) { padding: 1.1rem 1.25rem; border-radius: 14px; border: 1px solid var(--color-stone); background: color-mix(in srgb, var(--color-paper-soft) 60%, transparent); }
  :global(.dark) .legal-body :global(.right-card) { border-color: var(--color-coal-edge); background: color-mix(in srgb, var(--color-coal-soft) 45%, transparent); }
  .legal-body :global(.rc-title) { display: flex; align-items: center; gap: 0.5rem; font-weight: 700; color: var(--color-ink); margin-bottom: 0.35rem; }
  :global(.dark) .legal-body :global(.rc-title) { color: var(--color-mist); }
  .legal-body :global(.rc-title .lucide) { color: var(--color-purple); }
  .legal-body :global(.right-card p) { margin: 0; font-size: 0.97rem; line-height: 1.8; }

  /* Highlight box */
  .legal-body :global(.highlight-box) { margin: 1.25rem 0; padding: 1.3rem 1.5rem; border-radius: 16px; background: color-mix(in srgb, var(--color-purple) 8%, transparent); border: 1px solid color-mix(in srgb, var(--color-purple) 26%, transparent); }
  .legal-body :global(.hb-title) { font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; color: var(--color-purple-deep); margin-bottom: 0.4rem; }
  :global(.dark) .legal-body :global(.hb-title) { color: color-mix(in srgb, var(--color-purple) 72%, white); }

  /* Contact card */
  .legal-body :global(.contact-card) { margin: 1.75rem 0 0.5rem; padding: 1.9rem 2rem; border-radius: 18px; border: 1px solid var(--color-stone); background: color-mix(in srgb, var(--color-paper) 72%, transparent); }
  :global(.dark) .legal-body :global(.contact-card) { border-color: var(--color-coal-edge); background: color-mix(in srgb, var(--color-coal-soft) 55%, transparent); }
  .legal-body :global(.contact-card h3) { margin-top: 0; }
  .legal-body :global(.contact-links) { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.1rem; }
  .legal-body :global(.contact-link) {
    display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.55rem 1.05rem; border-radius: 9999px;
    border: 1px solid var(--color-stone); background: var(--color-paper); color: var(--color-ink);
    text-decoration: none; font-size: 0.95rem;
    transition: transform .2s var(--ease-out-quart), box-shadow .2s, border-color .2s, color .2s;
  }
  :global(.dark) .legal-body :global(.contact-link) { border-color: var(--color-coal-edge); background: var(--color-coal-soft); color: var(--color-mist); }
  .legal-body :global(.contact-link:hover) { border-color: var(--color-purple); color: var(--color-purple-deep); transform: translateY(-2px); box-shadow: var(--lift-shadow); }
  :global(.dark) .legal-body :global(.contact-link:hover) { color: color-mix(in srgb, var(--color-purple) 75%, white); }

  /* Table wrapper */
  .legal-body :global(.table-wrap) { overflow-x: auto; margin: 1rem 0 1.25rem; }
  .legal-body :global(.table-wrap table) { margin: 0; }

  @media (max-width: 640px) {
    .legal-body :global(.section) { padding: 1.5rem 1.25rem; }
    .legal-body :global(.table-wrap table) { white-space: nowrap; }
  }

  /* ── Scroll reveal (added by JS; no-JS keeps everything visible) ───── */
  .legal.anim .legal-body :global(.section:not(.in)) { opacity: 0; transform: translateY(20px); }
  .legal.anim .legal-body :global(.section) { transition: opacity .6s cubic-bezier(.16,1,.3,1), transform .6s cubic-bezier(.16,1,.3,1); }
  @media (prefers-reduced-motion: reduce) {
    .legal.anim .legal-body :global(.section:not(.in)) { opacity: 1; transform: none; }
  }
</style>

<script>
  // Language toggle
  const root = document.querySelector<HTMLElement>('[data-legal]');
  if (root) {
    root.querySelectorAll<HTMLButtonElement>('.legal-lang button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const en = btn.dataset.lang === 'en';
        root.classList.toggle('show-en', en);
        root.querySelectorAll('.legal-lang button').forEach((b) =>
          b.classList.toggle('is-active', b === btn));
      });
    });

    // Scroll reveal for sections
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sections = Array.from(root.querySelectorAll<HTMLElement>('.legal-body .section'));
    if (!reduce && 'IntersectionObserver' in window && sections.length) {
      root.classList.add('anim');
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      sections.forEach((s) => io.observe(s));
    }
  }
</script>
