      copyResult: 'نسخ',
      unlimited: 'تدريب غير محدود',
      score: 'نتيجتك',
      upgradeEyebrow: 'إعراب بلس',
      upgradeTitle: 'واصِل تعلّمك بلا حدود',
      upgradeBody: 'أنهيت محاولاتك المجانية لليوم. اشترك لتُحلّل وتتدرّب بلا حدود — مع تصحيح إعرابك بالذكاء الاصطناعي، الميزة التي تميّزنا.',
      benefits: ['تحليل وتدريب بلا حدود كل يوم', 'تصحيح ذكي مفصّل لإعراب كل كلمة', 'بنك التدريب الكامل: ٥٧٦ جملة', 'المعجم الذكي وOCR وتصدير PDF', 'شهادات الإتقان على الخطة السنوية', 'حساب واحد على الويب والتطبيق'],
      annual: 'سنوي',
      monthly: 'شهري',
      annualPrice: '٣٥٫٩٩$',
