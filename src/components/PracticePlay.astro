---
/**
 * PracticePlay — the web practice surface, two clean modes (mirrors the app):
 *
 *  • Curated: pick a topic + a ready-made sentence, then answer each word with
 *    guided type → role → case selectors. Graded against the sentence's stored
 *    `correctAnalysis` (Firestore `sentences/{topicId}/items`). /api/grade-practice
 *    is called only to apply the daily free quota.
 *  • Custom: write any Arabic sentence, type your own i'rab per word, AI grades it
 *    via /api/grade-custom-irab.
 *
 * One calm, linear flow — no nested phases, no flicker. Firebase/Firestore load
 * only inside this login-gated island. Results save to local history.
 */
import Paywall from './Paywall.astro';
import { EXAMPLES } from '../data/demo-examples';

interface Props { lang?: 'ar' | 'en'; }
const { lang = 'ar' } = Astro.props;
const login = lang === 'ar' ? '/login' : '/en/login';
const dir = lang === 'ar' ? 'rtl' : 'ltr';
const titleClass = lang === 'ar' ? 'font-arabic-display' : 'font-display';
const back = lang === 'ar' ? 'M15 18l-6-6 6-6' : 'M9 18l6-6-6-6';

const t = lang === 'ar'
  ? {
      gateTitle: 'سجّل الدخول لتبدأ التدريب',
