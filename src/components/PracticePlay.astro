    }
  : {
      gateTitle: 'Sign in to start practicing',
      gateBody: 'Pick a ready-made sentence or write your own, then parse it and get corrected.',
      signIn: 'Sign in',
      chooseTitle: 'How do you want to practice?',
      chooseBody: 'Start with the strongest feature: write your i\'rab, then get AI feedback.',
      curatedTitle: 'Ready-made sentences',
      curatedBody: 'Pick a sentence from the bank, then set each word\'s type, role, and case.',
      curatedTag: 'Second option',
      curatedFeats: ['576 ready sentences', 'Guided practice'],
      customTitle: 'Write your own',
      customBody: 'Enter any sentence, type your i\'rab, and let AI grade and explain it.',
      customTag: 'Golden feature',
      customFeats: ['AI feedback', 'Any sentence you write'],
      start: 'Start',
      back: 'Back',
      chooseSentence: 'Choose a sentence',
      loadingBank: 'Loading the sentence bank…',
      noTopics: 'Couldn\'t load sentences right now. Please retry.',
      noSentences: 'No sentences in this topic.',
      level: 'Level',
      words: 'words',
