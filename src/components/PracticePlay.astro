      customFeats: ['تصحيح بالذكاء الاصطناعي', 'أي جملة تكتبها'],
      start: 'ابدأ',
      back: 'رجوع',
      chooseSentence: 'اختر جملة',
      loadingBank: 'جارٍ تحميل بنك الجمل…',
      noTopics: 'تعذّر تحميل الجمل الآن. حاول مجددًا.',
      noSentences: 'لا توجد جمل في هذا الموضوع.',
      level: 'المستوى',
      words: 'كلمة',
      answerTitle: 'حدّد إعراب كل كلمة',
      type: 'النوع', role: 'الموقع', caseMarker: 'العلامة', select: 'اختر',
      answered: (a: number, n: number) => `${a} من ${n}`,
      check: 'تحقّق من الإجابات',
      completeAll: 'أكمل اختيارات كل كلمة أولاً.',
      writeTitle: 'اكتب جملتك',
      sentencePlaceholder: 'اكتب جملة عربية من كلمتين إلى ١٥ كلمة…',
      trySentence: 'جرّب جملة:',
      splitHint: 'سنقسّمها كلماتٍ لتكتب إعراب كلٍّ منها.',
      split: 'التالي',
      yourIrabPlaceholder: 'إعرابك لهذه الكلمة… مثال: فاعل مرفوع وعلامة رفعه الضمة',
      gradeCustom: 'صحّح إعرابي',
      grading: 'جارٍ التصحيح…',
      needWords: 'اكتب إعرابك لكلمة واحدة على الأقل.',
