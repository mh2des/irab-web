---
<div data-practice-root data-lang={lang} data-login={login} dir={dir} class="pr-shell">
  {/* Loading */}
  <div data-pr-loading aria-busy="true" class="space-y-4">
    <div class="skeleton h-40 rounded-2xl"></div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4"><div class="skeleton h-52 rounded-2xl"></div><div class="skeleton h-52 rounded-2xl"></div></div>
  </div>

  {/* Gate */}
  <div data-pr-gate class="hidden card panel-in p-8 md:p-12 text-center">
    <div class="pr-gate-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15v2"/><path d="M7 10V8a5 5 0 0 1 10 0v2"/><rect x="5" y="10" width="14" height="10" rx="2"/></svg>
    </div>
    <h2 class:list={[titleClass, 'text-h2 leading-tight mb-3']}>{t.gateTitle}</h2>
    <p class="text-body text-ink/75 dark:text-mist/75 mb-7 max-w-md mx-auto">{t.gateBody}</p>
    <a href={login} class="btn-primary btn-lg">{t.signIn}</a>
  </div>

  {/* Tool */}
  <div data-pr-tool class="hidden">
    <div class="pr-toolbar">
      <button type="button" data-pr-mute class="pr-mute" aria-label={t.sound} aria-pressed="false">
        <svg class="ic-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M19 5a9 9 0 0 1 0 14"/></svg>
        <svg class="ic-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M22 9l-6 6"/><path d="M16 9l6 6"/></svg>
      </button>
    </div>
    {/* Quota pill (premium only) */}
    <p data-pr-quota class="pr-quota"></p>

    <Paywall lang={lang} />

    {/* ── Phase: mode chooser ───────────────────────────────── */}
    <section data-phase="choose" class="pr-phase">
      <div class="text-center max-w-xl mx-auto mb-8">
        <h1 class:list={[titleClass, 'text-h1 leading-tight']}>{t.chooseTitle}</h1>
        <p class="text-body text-ink/70 dark:text-mist/70 mt-3">{t.chooseBody}</p>
      </div>
      <div class="pr-modes">
        <button type="button" data-go="custom" class="pr-mode pr-mode-purple pr-mode-featured">
          <span class="pr-mode-ribbon">{t.customTag}</span>
          <span class="pr-mode-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></span>
          <span class:list={[titleClass, 'pr-mode-title']}>{t.customTitle}</span>
          <span class="pr-mode-body">{t.customBody}</span>
          <span class="pr-mode-feats">
            {t.customFeats.map((f) => (
              <span class="pr-mode-feat"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>{f}</span>
            ))}
          </span>
          <span class="pr-mode-cta">{t.start}<span class="pr-mode-arrow" aria-hidden="true">{lang === 'ar' ? '←' : '→'}</span></span>
        </button>
        <button type="button" data-go="curated" class="pr-mode pr-mode-teal">
          <span class="pr-mode-tag">{t.curatedTag}</span>
          <span class="pr-mode-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M9 7h7"/><path d="M9 11h5"/></svg></span>
          <span class:list={[titleClass, 'pr-mode-title']}>{t.curatedTitle}</span>
          <span class="pr-mode-body">{t.curatedBody}</span>
          <span class="pr-mode-feats">
            {t.curatedFeats.map((f) => (
              <span class="pr-mode-feat"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>{f}</span>
            ))}
          </span>
          <span class="pr-mode-cta">{t.start}<span class="pr-mode-arrow" aria-hidden="true">{lang === 'ar' ? '←' : '→'}</span></span>
        </button>
      </div>
    </section>

    {/* ── Phase: curated browse (topic chips + sentences) ───── */}
    <section data-phase="browse" class="pr-phase hidden">
      <div class="pr-head">
        <button type="button" data-back="choose" class="icon-btn" aria-label={t.back}><svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={back}/></svg></button>
        <h2 class:list={[titleClass, 'text-h2 leading-tight']}>{t.chooseSentence}</h2>
      </div>
      <div data-topic-chips class="pr-chips"></div>
      <p data-bank-loading class="pr-hint text-center py-6">{t.loadingBank}</p>
      <p data-bank-error class="hidden pr-hint text-center py-6">{t.noTopics}</p>
      <div data-sentence-list class="pr-sentences"></div>
    </section>

    {/* ── Phase: curated solve ──────────────────────────────── */}
    <section data-phase="solve" class="pr-phase hidden">
      <div class="pr-head">
        <button type="button" data-back="browse" class="icon-btn" aria-label={t.back}><svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={back}/></svg></button>
        <div class="min-w-0">
          <p class="pr-kicker" data-solve-topic></p>
          <h2 class:list={[titleClass, 'text-h2 leading-tight']}>{t.answerTitle}</h2>
        </div>
      </div>
      <p data-solve-sentence class="pr-sentence-show" lang="ar" dir="rtl"></p>
      <div class="pr-progressbar" aria-hidden="true"><span data-solve-bar></span></div>
      <div data-solve-words class="space-y-3"></div>
      <div class="pr-actions">
        <span data-solve-progress class="pr-progress"></span>
        <button type="button" data-solve-check class="btn-primary"><span data-solve-check-label>{t.check}</span></button>
      </div>
      <p data-solve-msg class="hidden pr-msg"></p>
    </section>

    {/* ── Phase: custom write + solve ───────────────────────── */}
    <section data-phase="custom" class="pr-phase hidden">
      <div class="pr-head">
        <button type="button" data-back="choose" class="icon-btn" aria-label={t.back}><svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={back}/></svg></button>
        <h2 class:list={[titleClass, 'text-h2 leading-tight']}>{t.writeTitle}</h2>
      </div>
      {/* write step */}
      <div data-custom-write>
        <textarea data-custom-input rows="3" dir="rtl" maxlength="500" placeholder={t.sentencePlaceholder} class="input pr-textarea"></textarea>
        {/* Empty-state suggestions: tap a curated sentence to fill the textarea. */}
        <div class="mt-3">
          <p class="text-small font-semibold text-ink-subtle dark:text-mist-subtle mb-2">{t.trySentence}</p>
          <div class="flex flex-wrap gap-2">
            {EXAMPLES.map((ex) => (
              <button type="button" class="ex-chip" data-practice-example={ex.id} lang="ar" dir="rtl">{ex.source}</button>
            ))}
          </div>
        </div>
        <p class="pr-hint mt-3 mb-4">{t.splitHint}</p>
        <button type="button" data-custom-split class="btn-primary btn-block">{t.split}</button>
      </div>
      {/* solve step */}
      <div data-custom-solve class="hidden">
        <p data-custom-sentence class="pr-sentence-show" lang="ar" dir="rtl"></p>
        <div data-custom-words class="space-y-3"></div>
        <button type="button" data-custom-grade class="btn-primary btn-block mt-2"><span data-custom-grade-label>{t.gradeCustom}</span></button>
        <p data-custom-msg class="hidden pr-msg"></p>
      </div>
    </section>

    {/* ── Phase: results (shared) ───────────────────────────── */}
    <section data-phase="results" class="pr-phase hidden">
      <div data-results-overall></div>
      <div data-results-words class="space-y-3 mt-5"></div>
      {/* Share sits at the END of the results, not under the input. */}
      <div class="pr-share-row">
        <button type="button" data-result-share class="pr-share-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          <span data-result-share-label>{t.shareResult}</span>
        </button>
        <button type="button" data-result-copy class="pr-share-btn pr-share-ghost">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <span data-result-copy-label>{t.copyResult}</span>
        </button>
      </div>
      <button type="button" data-again class="btn-ghost btn-block mt-4">{t.again}</button>
    </section>
  </div>
</div>

<style is:global>
  /* Global (not scoped): the chips, sentence cards, word cards, selects and
     results are injected via JS, so scoped styles would never reach them. All
     selectors are pr-* prefixed to avoid leaking into other components. */
  .pr-shell { width: 100%; max-width: 60rem; margin-inline: auto; }
  .pr-gate-icon { width: 4rem; height: 4rem; border-radius: 1.1rem; margin: 0 auto 1.25rem; display: grid; place-items: center; color: var(--color-purple-deep); background: color-mix(in srgb, var(--color-purple) 12%, white); border: 1px solid color-mix(in srgb, var(--color-purple) 26%, var(--color-card-edge)); }
  .dark .pr-gate-icon { background: color-mix(in srgb, var(--color-purple) 22%, var(--color-coal-soft)); }
  .pr-gate-icon svg { width: 1.9rem; height: 1.9rem; }

  .pr-quota { text-align: center; font-weight: 800; color: var(--color-teal); font-size: var(--text-caption); margin-bottom: 1.25rem; }
  .pr-quota:empty { display: none; }

  /* Phase transition */
  .pr-phase { animation: pr-in .34s var(--ease-out-quart) both; }
  @keyframes pr-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

  /* Mode chooser */
  .pr-modes { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; align-items: stretch; }
  .pr-mode {
    --accent: var(--color-teal); --accent-deep: var(--color-teal-deep);
    position: relative; overflow: hidden; text-align: start; display: flex; flex-direction: column; gap: 0.55rem;
    padding: clamp(1.5rem, 3vw, 2.1rem); border-radius: 1.5rem;
    background: var(--color-card); border: 1px solid var(--color-card-edge); box-shadow: var(--shadow-card);
    transition: transform .22s var(--ease-out-quart), box-shadow .22s, border-color .22s;
  }
  .dark .pr-mode { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }
  /* Top accent bar */
  .pr-mode::before {
    content: ""; position: absolute; inset: 0 0 auto 0; height: 0.32rem;
    background: linear-gradient(90deg, var(--accent), var(--accent-deep));
    opacity: 0.9;
  }
  .pr-mode:hover { transform: translateY(-5px); box-shadow: var(--shadow-lift); border-color: color-mix(in srgb, var(--accent) 50%, var(--color-card-edge)); }
  .pr-mode-purple { --accent: var(--color-purple); --accent-deep: var(--color-purple-deep); }
  .pr-mode-teal { --accent: var(--color-teal); --accent-deep: var(--color-teal-deep); }
  /* Featured (golden) card: a faint accent wash so it leads the eye */
  .pr-mode-featured {
    border-color: color-mix(in srgb, var(--accent) 42%, var(--color-card-edge));
    background:
      radial-gradient(120% 80% at 100% 0%, color-mix(in srgb, var(--accent) 10%, transparent) 0%, transparent 52%),
      var(--color-card);
  }
  .dark .pr-mode-featured {
    background:
      radial-gradient(120% 80% at 100% 0%, color-mix(in srgb, var(--accent) 20%, transparent) 0%, transparent 52%),
      var(--color-coal-soft);
  }
  /* Ribbon on the featured card */
  .pr-mode-ribbon {
    position: absolute; inset-block-start: 1.15rem; inset-inline-end: 1.15rem;
    padding: 0.28rem 0.7rem; border-radius: 999px; font-size: 0.78rem; font-weight: 800;
    color: #fff; background: linear-gradient(120deg, var(--accent), var(--accent-deep));
    box-shadow: 0 6px 16px -6px var(--accent);
  }
  .pr-mode-ic {
    width: 3.6rem; height: 3.6rem; border-radius: 1.1rem; display: grid; place-items: center; margin-bottom: 0.5rem;
    color: #fff; background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    box-shadow: 0 12px 24px -12px var(--accent);
    transition: transform .22s var(--ease-out-quart);
  }
  .pr-mode:hover .pr-mode-ic { transform: scale(1.06) rotate(-3deg); }
  .pr-mode-ic svg { width: 1.8rem; height: 1.8rem; }
