      limit: 'You\'ve hit today\'s free practice limit. Come back tomorrow or upgrade.',
      error: 'Something went wrong. Please try again.',
      yourAnswer: 'Your answer', correct: 'Correct',
      again: 'Practice again',
      shareResult: 'Share result',
      copyResult: 'Copy',
      unlimited: 'Unlimited practice',
      score: 'Your score',
      upgradeEyebrow: 'Irab Plus',
      upgradeTitle: 'Keep learning, no limits',
      upgradeBody: 'You\'ve used today\'s free tries. Subscribe to analyze and practice without limits — with AI feedback on your own i\'rab, the feature that sets us apart.',
      benefits: ['Unlimited analysis & practice, every day', 'Detailed AI feedback on every word', 'Full practice bank: 576 sentences', 'Smart dictionary, OCR & PDF export', 'Mastery certificates on the annual plan', 'One account across web & app'],
      annual: 'Annual',
      monthly: 'Monthly',
      annualPrice: '$35.99',
      monthlyPrice: '$4.99',
      annualPer: '≈ $3.00/mo',
      annualMeta: '7-day free trial',
      monthlyMeta: 'Renews monthly',
      save: 'Save 40%',
      annualCta: 'Start 7-day free trial',
      monthlyCta: 'Subscribe monthly',
      secure: 'Cancel anytime · Secure checkout by Paddle',
