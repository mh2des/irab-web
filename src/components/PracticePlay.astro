<script>
  import { maybeSignedIn } from '../lib/session';
  import { addHistory, getHistoryItem } from '../lib/history';
  import { revealStagger, springPress } from '../lib/animate';
  import { sfx, confetti, countUp, isMuted, setMuted } from '../lib/celebrate';
  import { EXAMPLES } from '../data/demo-examples';

  const root = document.querySelector<HTMLElement>('[data-practice-root]');
  if (root) {
    const lang = root.dataset.lang === 'en' ? 'en' : 'ar';
    const WORKER = 'https://irab-api-v2.mansourhassan783.workers.dev';
    const q = <T extends Element>(s: string) => root.querySelector<T>(s)!;

    // Vocabulary — must match the app's PracticeWordTypes / PracticeRoles / PracticeCaseMarkers.
    const WORD_TYPES = ['اسم', 'فعل', 'حرف'];
    const ROLES: Record<string, string[]> = {
      'اسم': ['مبتدأ', 'خبر', 'فاعل', 'مفعول به', 'اسم مجرور', 'حال', 'تمييز', 'نعت', 'مضاف إليه', 'اسم إن وأخواتها', 'خبر إن وأخواتها', 'اسم كان وأخواتها', 'خبر كان وأخواتها', 'بدل', 'توكيد', 'معطوف', 'منادى', 'مستثنى', 'مفعول مطلق', 'مفعول لأجله', 'مفعول فيه', 'مفعول معه', 'نائب فاعل'],
      'فعل': ['فعل ماضٍ', 'فعل مضارع', 'فعل أمر'],
      'حرف': ['حرف جر', 'حرف نصب', 'حرف جزم', 'حرف عطف', 'حرف نفي', 'حرف استفهام', 'حرف نداء', 'حرف ناسخ', 'حرف شرط', 'حرف تعليل'],
    };
    const CASES = ['مرفوع بالضمة', 'منصوب بالفتحة', 'مجرور بالكسرة', 'مبني على السكون', 'مبني على الفتح', 'مبني على الضم', 'مبني على الكسر', 'مرفوع بالواو', 'منصوب بالألف', 'مجرور بالياء', 'مرفوع بالألف', 'منصوب بالياء', 'مرفوع بثبوت النون', 'منصوب بحذف النون', 'مجزوم بحذف النون', 'مجزوم بالسكون', 'مجزوم بحذف حرف العلة', 'منصوب بالكسرة', 'مجرور بالفتحة'];

    const T = lang === 'ar'
      ? { select: 'اختر', type: 'النوع', role: 'الموقع', caseMarker: 'العلامة', grading: 'جارٍ التصحيح…', check: 'تحقّق من الإجابات', gradeCustom: 'صحّح إعرابي', completeAll: 'أكمل اختيارات كل كلمة أولاً.', needWords: 'اكتب إعرابك لكلمة واحدة على الأقل.', limit: 'بلغت حدّك اليومي المجاني للتدريب. عُد غدًا أو رقِّ حسابك.', error: 'حدث خطأ. حاول مرة أخرى.', yourAnswer: 'إجابتك', correct: 'الصواب', unlimited: 'تدريب غير محدود', level: 'المستوى', words: 'كلمة', noSentences: 'لا توجد جمل في هذا الموضوع.', score: 'نتيجتك', answered: (a: number, n: number) => `${a} من ${n}`, yourIrabPlaceholder: 'إعرابك لهذه الكلمة…', fbExcellent: 'ممتاز! إتقان رائع 🎉', fbGreat: 'أحسنت! اقتربت من الإتقان', fbGood: 'جيد، واصل التدريب', fbKeep: 'لا بأس — التكرار يصنع الإتقان' }
      : { select: 'Select', type: 'Type', role: 'Role', caseMarker: 'Marker', grading: 'Grading…', check: 'Check answers', gradeCustom: 'Grade my i\'rab', completeAll: 'Complete every word\'s choices first.', needWords: 'Write your i\'rab for at least one word.', limit: 'You\'ve hit today\'s free practice limit. Come back tomorrow or upgrade.', error: 'Something went wrong. Please try again.', yourAnswer: 'Your answer', correct: 'Correct', unlimited: 'Unlimited practice', level: 'Level', words: 'words', noSentences: 'No sentences in this topic.', score: 'Your score', answered: (a: number, n: number) => `${a} of ${n}`, yourIrabPlaceholder: 'Your i\'rab for this word…', fbExcellent: 'Excellent! Outstanding 🎉', fbGreat: 'Great work! Almost there', fbGood: 'Good — keep training', fbKeep: 'Keep going — practice makes perfect' };

    const feedbackFor = (s: number) => s >= 0.9 ? T.fbExcellent : s >= 0.7 ? T.fbGreat : s >= 0.5 ? T.fbGood : T.fbKeep;

    const loadingEl = q<HTMLElement>('[data-pr-loading]');
    const gateEl = q<HTMLElement>('[data-pr-gate]');
    const toolEl = q<HTMLElement>('[data-pr-tool]');
    const quotaEl = q<HTMLElement>('[data-pr-quota]');
    const phaseEls = Array.from(root.querySelectorAll<HTMLElement>('[data-phase]'));
    const el = (tag: string, cls?: string, text?: string) => { const n = document.createElement(tag); if (cls) n.className = cls; if (text != null) n.textContent = text; return n; };
    const toAr = (n: number) => lang === 'ar' ? String(n).replace(/\d/g, (d) => '٠١٢٣٤٥٦٧٨٩'[+d]) : String(n);
    let lastShareSentence = '';
    let lastSharePct = 0;

    function showPhase(name: string) {
      phaseEls.forEach((p) => p.classList.toggle('hidden', p.dataset.phase !== name));
      const active = phaseEls.find((p) => p.dataset.phase === name);
      if (active) { active.style.animation = 'none'; void active.offsetWidth; active.style.animation = ''; }
      root!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    let idToken: string | null = null;
    let currentUid = 'anon';
    let authUser: any = null;
    let isPremium = false;
    let topics: any[] = [];
    let selectedTopic: any = null;
    let selectedSentence: any = null;
    let customSentence = '';
    let lastMode: 'curated' | 'custom' | null = null; // so "another practice" stays in the same mode

    // ── Curated ────────────────────────────────────────────────
    const chipsEl = q<HTMLElement>('[data-topic-chips]');
    const bankLoading = q<HTMLElement>('[data-bank-loading]');
    const bankError = q<HTMLElement>('[data-bank-error]');
    const sentenceListEl = q<HTMLElement>('[data-sentence-list]');

    // Firestore loaded once, lazily; topics + per-topic sentences cached so the
    // bank opens instantly (it is prefetched in the background right after boot).
    let fsMod: any = null; let db: any = null;
    async function getFs() {
      if (!fsMod) {
        fsMod = await import('firebase/firestore');
        const { app } = await import('../lib/firebase');
        db = fsMod.getFirestore(app);
      }
      return fsMod;
    }

    let bankPromise: Promise<void> | null = null;
    function ensureBank(): Promise<void> {
      if (!bankPromise) {
        bankPromise = (async () => {
          const f = await getFs();
          const snap = await f.getDocs(f.query(f.collection(db, 'grammar_topics'), f.orderBy('level')));
          topics = snap.docs.map((d: any) => ({ id: d.id, ...d.data() }))
            .sort((a: any, b: any) => (a.level - b.level) || ((a.order ?? 0) - (b.order ?? 0)));
          if (topics[0]) loadSentencesFor(topics[0].id).catch(() => {}); // warm the first topic
        })();
      }
      return bankPromise;
    }

    const sentCache: Record<string, any[]> = {};
    async function loadSentencesFor(topicId: string): Promise<any[]> {
      if (sentCache[topicId]) return sentCache[topicId];
      const f = await getFs();
      const snap = await f.getDocs(f.query(f.collection(db, 'sentences', topicId, 'items'), f.orderBy('order')));
      sentCache[topicId] = snap.docs.map((d: any) => ({ id: d.id, ...d.data() }));
      return sentCache[topicId];
    }

    let bankRendered = false;
    async function openCurated() {
      showPhase('browse');
      if (bankRendered) return; // chips + sentences already on screen
      bankLoading.classList.remove('hidden');
      bankError.classList.add('hidden');
      try {
        await ensureBank();
        bankLoading.classList.add('hidden');
        if (!topics.length) { bankError.classList.remove('hidden'); return; }
        bankRendered = true;
        renderTopicChips();
        selectTopic(topics[0]);
      } catch (e) {
        console.error('practice bank failed', e);
        bankLoading.classList.add('hidden');
        bankError.classList.remove('hidden');
      }
    }

    function renderTopicChips() {
      chipsEl.replaceChildren();
      topics.forEach((topic) => {
        const b = el('button', 'pr-chip', topic.name || topic.id) as HTMLButtonElement;
        b.type = 'button';
        b.dataset.topicId = topic.id;
        b.addEventListener('click', () => { sfx.tap(); selectTopic(topic); });
        chipsEl.appendChild(b);
      });
    }

    async function selectTopic(topic: any) {
      selectedTopic = topic;
      chipsEl.querySelectorAll('.pr-chip').forEach((c) => c.classList.toggle('is-active', (c as HTMLElement).dataset.topicId === topic.id));
      if (sentCache[topic.id]) { renderSentences(sentCache[topic.id]); return; }
      sentenceListEl.replaceChildren();
      sentenceListEl.appendChild(el('p', 'pr-hint text-center py-6', lang === 'ar' ? 'جارٍ التحميل…' : 'Loading…'));
      try {
        const s = await loadSentencesFor(topic.id);
        if (selectedTopic?.id === topic.id) renderSentences(s);
      } catch (e) {
        console.error('sentences failed', e);
        sentenceListEl.replaceChildren();
        sentenceListEl.appendChild(el('p', 'pr-hint text-center py-6', T.noSentences));
      }
    }

    function renderSentences(sentences: any[]) {
      sentenceListEl.replaceChildren();
      if (!sentences.length) { sentenceListEl.appendChild(el('p', 'pr-hint text-center py-6', T.noSentences)); return; }
      const chevPath = lang === 'ar' ? 'M15 18l-6-6 6-6' : 'M9 18l6-6-6-6';
      sentences.forEach((s, i) => {
        const count = Array.isArray(s.correctAnalysis) ? s.correctAnalysis.length : String(s.sentence || '').split(/\s+/).filter(Boolean).length;
        const b = el('button', 'pr-sentence') as HTMLButtonElement;
        b.type = 'button';
        b.innerHTML =
          `<span class="pr-sentence-idx" aria-hidden="true">${toAr(i + 1)}</span>` +
          `<span class="pr-sentence-main">` +
            `<span class="pr-sentence-text" dir="rtl"></span>` +
            `<span class="pr-sentence-meta">${count} ${T.words}</span>` +
          `</span>` +
          `<svg class="pr-sentence-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="${chevPath}"/></svg>`;
        b.querySelector('.pr-sentence-text')!.textContent = s.sentence || '';
        b.addEventListener('click', () => { sfx.tap(); openSolve(s); });
        sentenceListEl.appendChild(b);
      });
      revealStagger(sentenceListEl.querySelectorAll('.pr-sentence'), 0.05);
    }

    let curatedInputs: { word: string; type: HTMLSelectElement; role: HTMLSelectElement; cm: HTMLSelectElement }[] = [];

    function opt(values: string[], placeholder: string) {
      return `<option value="">${placeholder}</option>` + values.map((v) => `<option value="${v}">${v}</option>`).join('');
    }

    function openSolve(sentence: any) {
      lastMode = 'curated';
      selectedSentence = sentence;
      q<HTMLElement>('[data-solve-topic]').textContent = `${selectedTopic?.name || ''} · ${T.level} ${selectedTopic?.level ?? 1}`;
      q<HTMLElement>('[data-solve-sentence]').textContent = sentence.sentence || '';
      const wordsEl = q<HTMLElement>('[data-solve-words]');
      wordsEl.replaceChildren();
      curatedInputs = [];
      const words = Array.isArray(sentence.correctAnalysis) && sentence.correctAnalysis.length
        ? sentence.correctAnalysis.map((a: any) => a.word)
        : String(sentence.sentence || '').split(/\s+/).filter(Boolean);
      words.forEach((word: string, i: number) => {
        const card = el('div', 'pr-word');
        const head = el('div', 'pr-word-head');
        const tok = el('span', 'pr-word-token'); tok.dir = 'rtl'; tok.textContent = word;
        head.append(tok, el('span', 'pr-word-num', String(i + 1)));
        card.appendChild(head);
        const grid = el('div', 'pr-selects');
        const type = document.createElement('select'); type.className = 'pr-select'; type.dir = 'rtl'; type.innerHTML = opt(WORD_TYPES, T.type);
        const role = document.createElement('select'); role.className = 'pr-select'; role.dir = 'rtl'; role.innerHTML = opt([], T.role); role.disabled = true;
        const cm = document.createElement('select'); cm.className = 'pr-select'; cm.dir = 'rtl'; cm.innerHTML = opt(CASES, T.caseMarker);
        type.addEventListener('change', () => { role.innerHTML = opt(ROLES[type.value] || [], T.role); role.disabled = !type.value; markDone(card, type, role, cm); });
        [[T.type, type], [T.role, role], [T.caseMarker, cm]].forEach(([label, sel]) => {
          const f = el('div', 'pr-field'); f.appendChild(el('span', 'pr-field-label', String(label))); f.appendChild(sel as HTMLSelectElement); grid.appendChild(f);
        });
        [role, cm].forEach((s) => s.addEventListener('change', () => markDone(card, type, role, cm)));
        card.appendChild(grid);
        wordsEl.appendChild(card);
        curatedInputs.push({ word, type, role, cm });
      });
      updateProgress();
      q<HTMLElement>('[data-solve-msg]').className = 'hidden pr-msg';
      showPhase('solve');
      revealStagger(wordsEl.querySelectorAll('.pr-word'));
    }

    function markDone(card: HTMLElement, type: HTMLSelectElement, role: HTMLSelectElement, cm: HTMLSelectElement) {
      const done = !!(type.value && role.value && cm.value);
      const was = card.dataset.done === '1';
      card.dataset.done = done ? '1' : '0';
      card.classList.toggle('is-done', done);
      if (done && !was) {
        card.classList.remove('just-done'); void card.offsetWidth; card.classList.add('just-done');
        sfx.select();
      } else { sfx.tap(); }
      updateProgress();
    }
    function updateProgress() {
      const done = curatedInputs.filter((w) => w.type.value && w.role.value && w.cm.value).length;
      q<HTMLElement>('[data-solve-progress]').textContent = T.answered(done, curatedInputs.length);
      const bar = root!.querySelector<HTMLElement>('[data-solve-bar]');
      if (bar) bar.style.width = curatedInputs.length ? `${(done / curatedInputs.length) * 100}%` : '0%';
    }

    async function checkCurated() {
      const attempts = curatedInputs.map((w) => ({ word: w.word, type: w.type.value, role: w.role.value, caseMarker: w.cm.value }));
      const msg = q<HTMLElement>('[data-solve-msg]');
      if (attempts.some((a) => !a.type || !a.role || !a.caseMarker)) { msg.textContent = T.completeAll; msg.className = 'pr-msg'; return; }
      msg.className = 'hidden pr-msg';
      const btn = q<HTMLButtonElement>('[data-solve-check]');
      const label = q<HTMLElement>('[data-solve-check-label]');
      btn.disabled = true; label.textContent = T.grading;
      try {
        // Worker call applies the daily free quota (and premium bypass); the
        // correctness comes from the sentence's stored answer.
        const res = await fetch(`${WORKER}/api/grade-practice`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', ...(idToken ? { Authorization: `Bearer ${idToken}` } : {}) },
          body: JSON.stringify({ sentence: selectedSentence.sentence }),
        }).catch(() => null);
        if (res && res.status === 429) { msg.className = 'hidden pr-msg'; showUpgrade(); return; }
        const correct: any[] = selectedSentence.correctAnalysis || [];
        const norm = (s?: string) => (s || '').trim().replace(/\s+/g, ' ');
        const results = attempts.map((a, i) => {
          const c = correct[i] || {};
          const typeOk = norm(a.type) === norm(c.type);
          const roleOk = norm(a.role) === norm(c.role);
          const caseOk = norm(a.caseMarker) === norm(c.caseMarker);
          return { word: a.word, attempt: a, correct: c, isCorrect: typeOk && roleOk && caseOk };
        });
        const score = results.length ? results.filter((r) => r.isCorrect).length / results.length : 0;
        renderCuratedResults(selectedSentence.sentence, score, results);
        celebrate(score);
      } finally {
        btn.disabled = false; label.textContent = T.check;
      }
    }

    // ── Custom ─────────────────────────────────────────────────
    let customInputs: { word: string; input: HTMLInputElement }[] = [];
    const customWrite = q<HTMLElement>('[data-custom-write]');
    const customSolve = q<HTMLElement>('[data-custom-solve]');

    function openCustom() {
      lastMode = 'custom';
      customWrite.classList.remove('hidden');
      customSolve.classList.add('hidden');
      q<HTMLTextAreaElement>('[data-custom-input]').value = '';
      showPhase('custom');
      setTimeout(() => q<HTMLTextAreaElement>('[data-custom-input]').focus(), 60);
    }

    function splitCustom() {
      const s = q<HTMLTextAreaElement>('[data-custom-input]').value.trim();
      const words = s.split(/\s+/).filter(Boolean);
      if (words.length < 2) return;
      customSentence = s;
      q<HTMLElement>('[data-custom-sentence]').textContent = s;
      const wrap = q<HTMLElement>('[data-custom-words]');
      wrap.replaceChildren();
      customInputs = [];
      words.slice(0, 15).forEach((word) => {
        const card = el('div', 'pr-word');
        const head = el('div', 'pr-word-head');
        const tok = el('span', 'pr-word-token'); tok.dir = 'rtl'; tok.textContent = word;
        head.appendChild(tok);
        card.appendChild(head);
        const input = document.createElement('input'); input.type = 'text'; input.className = 'input'; input.dir = 'rtl'; input.placeholder = T.yourIrabPlaceholder;
        card.appendChild(input);
        wrap.appendChild(card);
        customInputs.push({ word, input });
      });
      customWrite.classList.add('hidden');
      customSolve.classList.remove('hidden');
      q<HTMLElement>('[data-custom-msg]').className = 'hidden pr-msg';
    }

    async function gradeCustom() {
      const userAnalysis = customInputs.map((w) => ({ word: w.word, irab: w.input.value.trim() })).filter((w) => w.irab.length > 0);
      const msg = q<HTMLElement>('[data-custom-msg]');
      if (!userAnalysis.length) { msg.textContent = T.needWords; msg.className = 'pr-msg'; return; }
      msg.className = 'hidden pr-msg';
      const btn = q<HTMLButtonElement>('[data-custom-grade]');
      const label = q<HTMLElement>('[data-custom-grade-label]');
      btn.disabled = true; label.textContent = T.grading;
      try {
        const res = await fetch(`${WORKER}/api/grade-custom-irab`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', ...(idToken ? { Authorization: `Bearer ${idToken}` } : {}) },
          body: JSON.stringify({ sentence: customSentence, userAnalysis }),
        });
        if (res.status === 429) { msg.className = 'hidden pr-msg'; showUpgrade(); return; }
        if (!res.ok) { msg.textContent = T.error; msg.className = 'pr-msg'; return; }
        const json = await res.json();
        const data = json?.data ?? json;
        renderCustomResults(data, customSentence);
        celebrate(typeof data?.score === 'number' ? data.score : 0);
      } catch {
        msg.textContent = T.error; msg.className = 'pr-msg';
      } finally {
        btn.disabled = false; label.textContent = T.gradeCustom;
      }
    }

    // ── Results ────────────────────────────────────────────────
    const resultsOverall = q<HTMLElement>('[data-results-overall]');
    const resultsWords = q<HTMLElement>('[data-results-words]');
    const pct = (n: number) => `${Math.round(n * 100)}%`;

    function summary(score: number, label: string, feedback?: string) {
      resultsOverall.replaceChildren();
      const c = el('div', 'pr-summary');
      const circ = 2 * Math.PI * 52;
      const ring = el('div', 'pr-ring');
      ring.innerHTML =
        `<svg viewBox="0 0 120 120"><circle class="pr-ring-bg" cx="60" cy="60" r="52"/>` +
        `<circle class="pr-ring-fg" cx="60" cy="60" r="52" stroke-dasharray="${circ}" stroke-dashoffset="${circ}"/></svg>` +
        `<span class="pr-ring-num">0%</span>`;
      c.appendChild(ring);
      c.appendChild(el('div', 'pr-summary-label', label));
      const fb = feedback || feedbackFor(score);
      if (fb) { const p = el('p', 'pr-summary-fb'); p.dir = 'auto'; p.textContent = fb; c.appendChild(p); }
      resultsOverall.appendChild(c);
      const fg = ring.querySelector<SVGCircleElement>('.pr-ring-fg');
      const num = ring.querySelector<HTMLElement>('.pr-ring-num')!;
      requestAnimationFrame(() => { if (fg) (fg as any).style.strokeDashoffset = String(circ * (1 - Math.max(0, Math.min(1, score)))); });
      countUp(num, Math.round(score * 100));
    }

    /** Sound + confetti payoff after results render. */
    function celebrate(score: number) {
      sfx.finish(score);
      if (score >= 0.8) confetti();
    }
    function resultRow(label: string, value: string) {
      const row = el('div', 'pr-result-row');
      row.appendChild(el('span', 'pr-result-label', label));
      const v = el('span'); v.dir = 'rtl'; v.textContent = value; row.appendChild(v);
      return row;
    }

    function renderCuratedResults(sentence: string, score: number, results: any[]) {
      lastShareSentence = sentence; lastSharePct = Math.round(score * 100);
      summary(score, T.score);
      resultsWords.replaceChildren();
      results.forEach((r, i) => {
        const card = el('div', `pr-result ${r.isCorrect ? 'ok' : 'bad'}`);
        card.style.animationDelay = `${Math.min(i, 10) * 60}ms`;
        const head = el('div', 'pr-result-head');
        const tok = el('span', 'pr-word-token'); tok.dir = 'rtl'; tok.textContent = r.word;
        head.append(tok, el('span', `pr-result-mark ${r.isCorrect ? 'ok' : 'bad'}`, r.isCorrect ? '✓' : '✗'));
        card.appendChild(head);
        card.appendChild(resultRow(T.yourAnswer, `${r.attempt.type || '—'} · ${r.attempt.role || '—'} · ${r.attempt.caseMarker || '—'}`));
        if (!r.isCorrect) card.appendChild(resultRow(T.correct, `${r.correct?.type || '—'} · ${r.correct?.role || '—'} · ${r.correct?.caseMarker || '—'}`));
        if (r.correct?.explanation) { const p = el('p', 'pr-result-exp'); p.dir = 'rtl'; p.textContent = r.correct.explanation; card.appendChild(p); }
        resultsWords.appendChild(card);
      });
      try {
        addHistory({ kind: 'practice', uid: currentUid, sentence, score,
          correctCount: results.filter((r) => r.isCorrect).length, totalCount: results.length,
          data: { score, wordFeedback: results.map((r) => ({ word: r.word, isCorrect: r.isCorrect, userIrab: `${r.attempt.type} · ${r.attempt.role} · ${r.attempt.caseMarker}`, correctIrab: `${r.correct?.type || ''} · ${r.correct?.role || ''} · ${r.correct?.caseMarker || ''}`, explanation: r.correct?.explanation || '' })) } });
      } catch {}
      showPhase('results');
    }

    function renderCustomResults(data: any, sentence: string) {
      const score = typeof data?.score === 'number' ? data.score : 0;
      lastShareSentence = sentence; lastSharePct = Math.round(score * 100);
      summary(score, data?.level || T.score, data?.overallFeedback || undefined);
      resultsWords.replaceChildren();
      const wf = Array.isArray(data?.wordFeedback) ? data.wordFeedback : [];
      wf.forEach((w: any, i: number) => {
        const ok = w?.isCorrect === true;
        const card = el('div', `pr-result ${ok ? 'ok' : 'bad'}`);
        card.style.animationDelay = `${Math.min(i, 10) * 60}ms`;
        const head = el('div', 'pr-result-head');
        const tok = el('span', 'pr-word-token'); tok.dir = 'rtl'; tok.textContent = w?.word || '';
        head.append(tok, el('span', `pr-result-mark ${ok ? 'ok' : 'bad'}`, ok ? '✓' : '✗'));
        card.appendChild(head);
        card.appendChild(resultRow(T.yourAnswer, w?.userIrab || '—'));
        if (!ok && w?.correctIrab) card.appendChild(resultRow(T.correct, w.correctIrab));
        if (w?.explanation) { const p = el('p', 'pr-result-exp'); p.dir = 'rtl'; p.textContent = w.explanation; card.appendChild(p); }
        resultsWords.appendChild(card);
      });
      try {
        addHistory({ kind: 'practice', uid: currentUid, sentence, score: data?.score, level: data?.level,
          correctCount: wf.filter((w: any) => w?.isCorrect).length, totalCount: wf.length, data });
      } catch {}
      showPhase('results');
    }

    // ── Wiring ─────────────────────────────────────────────────
    q<HTMLButtonElement>('[data-go="curated"]').addEventListener('click', () => { sfx.tap(); openCurated(); });
    q<HTMLButtonElement>('[data-go="custom"]').addEventListener('click', () => { sfx.tap(); openCustom(); });

    // Sound on/off toggle (persisted).
    const muteBtn = q<HTMLButtonElement>('[data-pr-mute]');
    const syncMute = () => { const m = isMuted(); muteBtn.classList.toggle('is-muted', m); muteBtn.setAttribute('aria-pressed', String(!m)); };
    syncMute();
    muteBtn.addEventListener('click', () => { setMuted(!isMuted()); syncMute(); if (!isMuted()) sfx.tap(); });

    // Tactile spring-press on the primary action buttons.
    springPress(root.querySelectorAll('[data-go], [data-solve-check], [data-custom-grade], [data-custom-split], [data-again], [data-result-share], [data-result-copy]'));
    // The upgrade gate is the shared <Paywall> island. Hand it the signed-in
    // user (so checkout can tag the buyer) and let it own the Paddle flow.
    function showUpgrade() {
      if (isPremium) return;
      (window as any).IrabPaywall?.show({
        uid: authUser?.uid,
        email: authUser?.email || undefined,
      });
    }
    root.querySelectorAll<HTMLButtonElement>('[data-back]').forEach((b) => b.addEventListener('click', () => showPhase(b.dataset.back!)));
    q<HTMLButtonElement>('[data-custom-split]').addEventListener('click', splitCustom);

    // Empty-state chips: fill the textarea with a curated example, then focus it.
    customWrite.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>('[data-practice-example]');
      if (!chip) return;
      const ex = EXAMPLES.find((x) => x.id === chip.dataset.practiceExample);
      if (!ex) return;
      sfx.tap();
      const ta = q<HTMLTextAreaElement>('[data-custom-input]');
      ta.value = ex.vocalizedSentence || ex.text;
      ta.focus();
    });
    q<HTMLButtonElement>('[data-custom-grade]').addEventListener('click', gradeCustom);
    q<HTMLButtonElement>('[data-solve-check]').addEventListener('click', checkCurated);
    q<HTMLButtonElement>('[data-again]').addEventListener('click', () => {
      // Stay in the same mode: curated → back to the sentence list (pick another);
      // custom → a fresh write screen. Only fall back to the chooser if unknown.
      if (lastMode === 'curated') showPhase('browse');
      else if (lastMode === 'custom') openCustom();
      else showPhase('choose');
    });

    // ── Result share / copy (text-based) ───────────────────────
    const shareText = () => lang === 'ar'
      ? `أحرزتُ ${toAr(lastSharePct)}٪ في إعراب «${lastShareSentence}» — تدرّب على irab.app`
      : `I scored ${lastSharePct}% parsing “${lastShareSentence}” — practice i'rab on irab.app`;
    const copiedMsg = lang === 'ar' ? 'تم النسخ ✓' : 'Copied ✓';
    const flashLabel = (labelEl: HTMLElement) => {
      const original = labelEl.textContent || '';
      labelEl.textContent = copiedMsg;
      setTimeout(() => { labelEl.textContent = original; }, 1600);
    };
    const shareUrl = () => lang === 'ar' ? 'https://irab.app/practice' : 'https://irab.app/en/practice';
    q<HTMLButtonElement>('[data-result-share]').addEventListener('click', async () => {
      sfx.tap();
      const text = shareText();
      if (navigator.share) {
        try { await navigator.share({ title: 'irab.app', text, url: shareUrl() }); return; } catch { /* cancelled → fall through */ }
      }
      try {
        await navigator.clipboard.writeText(`${text}\n${shareUrl()}`);
        flashLabel(q<HTMLElement>('[data-result-share-label]'));
      } catch { /* ignore */ }
    });
    q<HTMLButtonElement>('[data-result-copy]').addEventListener('click', async () => {
      sfx.tap();
      try {
        await navigator.clipboard.writeText(`${shareText()}\n${shareUrl()}`);
        flashLabel(q<HTMLElement>('[data-result-copy-label]'));
      } catch { /* ignore */ }
    });

    // ── Auth boot (runs once; no flicker) ──────────────────────
    let booted = false;
    (async () => {
      if (!maybeSignedIn()) { loadingEl.classList.add('hidden'); gateEl.classList.remove('hidden'); return; }
      try {
        const [{ onAuth }, { fetchMe }] = await Promise.all([import('../lib/auth'), import('../lib/entitlement')]);
        onAuth((u) => {
          if (!u) { if (!booted) { loadingEl.classList.add('hidden'); gateEl.classList.remove('hidden'); } return; }
          authUser = u;
          currentUid = u.uid;
          u.getIdToken().then((tk) => { idToken = tk; }).catch(() => {});
          if (booted) return; // ignore auth refreshes — never reset the user's place
          booted = true;
          loadingEl.classList.add('hidden');
          toolEl.classList.remove('hidden');
          // Premium + sentence bank load in the BACKGROUND — never block / flicker the first screen.
          fetchMe(u).then((me) => { if (me?.premium) { isPremium = true; quotaEl.textContent = T.unlimited; } }).catch(() => {});
          ensureBank().catch(() => {});
          // Initial screen — set synchronously so there is no chooser flash.
          try {
            const histId = new URLSearchParams(location.search).get('h');
            if (histId) { const item = getHistoryItem(histId); if (item?.kind === 'practice' && item.data) { renderCustomResults(item.data, item.sentence); return; } }
          } catch {}
          const mode = new URLSearchParams(location.search).get('mode');
          if (mode === 'curated') openCurated();
          else if (mode === 'custom') openCustom();
          else showPhase('choose');
        });
      } catch { loadingEl.classList.add('hidden'); gateEl.classList.remove('hidden'); }
    })();
  }
</script>
