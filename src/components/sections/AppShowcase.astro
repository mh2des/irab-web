---
/**
 * AppShowcase: the hover-driven phone cluster + download block.
 *
 * The cluster animation is a faithful port of docs/irab-showcase (entrance on
 * scroll-in, replay on hover, cursor parallax, idle float). Styles are global
 * because the script toggles `.is-play` dynamically and the class names are
 * already namespaced (`irab-showcase`, `is-*`), so scoping would only get in
 * the way. The surrounding layout uses the site's normal utilities.
 */
import Container from '../Container.astro';
import Section from '../Section.astro';

interface Props {
  lang?: 'en' | 'ar';
}
const { lang = 'ar' } = Astro.props;

const GOOGLE = 'https://play.google.com/store/apps/details?id=com.irabapp.arabic';
const APPLE  = 'https://apps.apple.com/app/id6765811277';

const t = lang === 'ar'
  ? {
      eyebrow: 'التطبيق',
      title: 'إعراب كامِلًا، في جيبك.',
      lead: 'كل ما رأيته هنا: والمزيد: داخل تطبيق إعراب: تحليل كلمة بكلمة، شرح الجملة، وبطاقات إعراب جاهزة للمشاركة.',
      scan: 'امسح الرمز للتحميل',
      appStore: 'App Store', googlePlay: 'Google Play',
      hintApple: 'iPhone · iPad', hintGoogle: 'Android',
      googleBtn: 'حمّل من Google Play', appleBtn: 'حمّل من App Store',
    }
  : {
      eyebrow: 'The app',
      title: 'The whole of Irab, in your pocket.',
      lead: "Everything you saw here: and more: inside the Irab app: word by word analysis, sentence explanations, and share-ready i'rab cards.",
      scan: 'Scan to download',
      appStore: 'App Store', googlePlay: 'Google Play',
      hintApple: 'iPhone · iPad', hintGoogle: 'Android',
      googleBtn: 'Get on Google Play', appleBtn: 'Download on the App Store',
    };
---
<Section id="app">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-[0.85fr_1.15fr] gap-12 lg:gap-12 items-center">

      {/* Phone cluster animation */}
      <div class="showcase-frame order-first lg:order-last" data-reveal>
        <!-- ======================= COMPONENT START ======================= -->
        <div class="irab-showcase">
          <div class="is-glow" aria-hidden="true"></div>
          <div class="is-cluster">
            <div class="is-phone is-phone--l"><img src="/showcase/phone-share.webp"  alt="بطاقة مشاركة الإعراب في تطبيق إعراب" width="720" height="1509" loading="lazy" decoding="async"></div>
            <div class="is-phone is-phone--c"><img src="/showcase/phone-home.webp"   alt="الشاشة الرئيسية لتطبيق إعراب" width="720" height="1509" loading="lazy" decoding="async"></div>
            <div class="is-phone is-phone--r"><img src="/showcase/phone-result.webp" alt="شاشة نتيجة الإعراب في تطبيق إعراب" width="720" height="1509" loading="lazy" decoding="async"></div>
          </div>
        </div>
        <!-- ======================== COMPONENT END ======================== -->
      </div>

      {/* Download block */}
      <div class="text-center lg:text-start">
        <p class="eyebrow mb-4 justify-center lg:justify-start" data-reveal>{t.eyebrow}</p>
        <h2 class="font-arabic-display text-[clamp(1.7rem,3.8vw,2.8rem)] leading-[1.3] tracking-tight" data-reveal data-reveal-delay="100">
          {t.title}
        </h2>
        <p class="mt-6 font-arabic text-body-lg text-ink/70 dark:text-mist/70 leading-loose max-w-md mx-auto lg:mx-0" data-reveal data-reveal-delay="200">
          {t.lead}
        </p>

        {/* QR cards: desktop (scan with your phone) */}
        <div class="hidden md:flex gap-4 mt-10 justify-center lg:justify-start" data-reveal data-reveal-delay="300">
          <a href={APPLE} target="_blank" rel="noopener" class="qr-card lift" aria-label={t.appleBtn}>
            <img src="/showcase/apple-qr.png" alt="" width="220" height="220" loading="lazy" decoding="async" class="qr-img"/>
            <span class="qr-store">{t.appStore}</span>
            <span class="qr-hint">{t.hintApple}</span>
          </a>
          <a href={GOOGLE} target="_blank" rel="noopener" class="qr-card lift" aria-label={t.googleBtn}>
            <img src="/showcase/google-qr.png" alt="" width="220" height="220" loading="lazy" decoding="async" class="qr-img"/>
            <span class="qr-store">{t.googlePlay}</span>
            <span class="qr-hint">{t.hintGoogle}</span>
          </a>
        </div>
        <p class="hidden md:block mt-4 font-arabic text-small text-ink/50 dark:text-mist/50 text-center lg:text-start" data-reveal data-reveal-delay="350">{t.scan}</p>

        {/* Store buttons: mobile (tap to install) */}
        <div class="flex md:hidden flex-col sm:flex-row gap-3 mt-10" data-reveal data-reveal-delay="300">
          <a href={GOOGLE} target="_blank" rel="noopener"
             class="inline-flex items-center justify-center gap-3 px-7 py-4 bg-purple hover:bg-purple-deep text-white font-arabic font-medium tracking-tight rounded-full lift">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3 20.5V3.5c0-.59.34-1.11.84-1.35L13.69 12 3.84 21.85c-.5-.25-.84-.76-.84-1.35M16.81 15.12L6.05 21.34l8.49-8.49 2.27 2.27M20.16 10.81c.34.27.59.66.59 1.19s-.25.92-.59 1.19l-2.31 1.34-2.61-2.55 2.61-2.55 2.31 1.38M6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z"/></svg>
            <span>{t.googleBtn}</span>
          </a>
          <a href={APPLE} target="_blank" rel="noopener"
             class="inline-flex items-center justify-center gap-3 px-7 py-4 border-2 border-ink/15 hover:border-purple/50 dark:border-mist/15 dark:hover:border-purple text-ink dark:text-mist font-arabic font-medium tracking-tight rounded-full lift">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09M12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25"/></svg>
            <span>{t.appleBtn}</span>
          </a>
        </div>
      </div>
    </div>
  </Container>
</Section>

<style>
  /* The phones float directly on the page now: no panel, just breathing room. */
  .showcase-frame { padding: 0 0.5rem; }

  .qr-card {
    display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
    padding: 1rem 1.15rem 0.9rem;
    border-radius: 20px;
    background: var(--color-paper);
    border: 1px solid var(--color-stone);
  }
  :global(.dark) .qr-card { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }
  .qr-img { width: 8.5rem; height: 8.5rem; border-radius: 10px; }
  .qr-store { font-weight: 700; font-size: 0.95rem; color: var(--color-ink); margin-top: 0.2rem; }
  :global(.dark) .qr-store { color: var(--color-mist); }
  .qr-hint { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: .04em; color: color-mix(in srgb, var(--color-ink) 45%, transparent); }
  :global(.dark) .qr-hint { color: color-mix(in srgb, var(--color-mist) 45%, transparent); }
</style>

<!-- Cluster animation styles: global on purpose (see component note). -->
<style is:global>
.irab-showcase{
  position:relative;
  width:100%;
  aspect-ratio:139/118;
  overflow:visible;
}
/* Soft brand spotlight behind the floating phones (no dark panel). */
.irab-showcase .is-glow{
  position:absolute; left:2%; top:4%; width:96%; height:92%;
  background:
    radial-gradient(46% 50% at 56% 42%, rgba(124,77,255,.20), transparent 70%),
    radial-gradient(42% 48% at 24% 68%, rgba(31,120,155,.16), transparent 72%);
  opacity:0;
  filter:blur(8px);
  transition:opacity 1s ease .2s, transform 1.2s ease;
  pointer-events:none;
}
.irab-showcase.is-play .is-glow{opacity:1}
.irab-showcase:hover .is-glow{transform:scale(1.06)}

.irab-showcase .is-cluster{
  position:absolute; inset:0;
  transform:scale(.045); transform-origin:50% 52%; opacity:0;
}
.irab-showcase.is-play .is-cluster{
  animation:is-cluster-in .95s cubic-bezier(.32,1.42,.45,1) forwards;
}
@keyframes is-cluster-in{
  0%{transform:scale(.045);opacity:0}
  28%{opacity:1}
  100%{transform:scale(1);opacity:1}
}

.irab-showcase .is-phone{
  position:absolute;
  transform:translate(var(--px,0px),var(--py,0px)) rotate(var(--rot,0deg));
  transition:transform .45s cubic-bezier(.2,.65,.3,1);
  will-change:transform;
}
.irab-showcase .is-phone img{
  display:block; width:100%; height:auto;
  filter:drop-shadow(0 34px 44px rgba(40,28,70,.30)) drop-shadow(0 12px 18px rgba(40,28,70,.16));
}
.irab-showcase .is-phone--l{ --rot:-12.5deg; width:30%; left:5%;  top:20%; z-index:1; }
.irab-showcase .is-phone--c{ --rot:4deg;     width:34%; left:33%; top:3%;  z-index:3; }
.irab-showcase .is-phone--r{ --rot:13deg;    width:30%; left:64%; top:14%; z-index:2; }

.irab-showcase.is-play .is-phone--l img{animation:is-float 7.5s ease-in-out 1.1s infinite alternate}
.irab-showcase.is-play .is-phone--c img{animation:is-float 8.5s ease-in-out 1.4s infinite alternate}
.irab-showcase.is-play .is-phone--r img{animation:is-float 7s   ease-in-out 1.7s infinite alternate}
@keyframes is-float{from{transform:translateY(-4px)}to{transform:translateY(6px)}}

@media (prefers-reduced-motion:reduce){
  .irab-showcase .is-cluster,
  .irab-showcase.is-play .is-cluster{animation:none;transform:none;opacity:1}
  .irab-showcase .is-glow{opacity:1;transition:none}
  .irab-showcase:hover .is-glow{transform:none}
  .irab-showcase.is-play .is-phone img{animation:none}
  .irab-showcase .is-phone{transition:none}
}
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fine   = window.matchMedia('(hover:hover) and (pointer:fine)').matches;

  document.querySelectorAll<HTMLElement>('.irab-showcase').forEach((card) => {
    const cluster = card.querySelector<HTMLElement>('.is-cluster')!;
    const phones  = Array.from(card.querySelectorAll<HTMLElement>('.is-phone'));
    let animating = false;

    cluster.addEventListener('animationstart', (e) => { if (e.animationName === 'is-cluster-in') animating = true; });
    cluster.addEventListener('animationend',   (e) => { if (e.animationName === 'is-cluster-in') animating = false; });

    function play() {
      if (reduce) { card.classList.add('is-play'); return; }
      card.classList.remove('is-play');
      void cluster.offsetWidth;          /* reflow -> restart keyframes */
      card.classList.add('is-play');
    }

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => { if (en.isIntersecting) { play(); io.disconnect(); } });
      }, { threshold: 0.35 });
      io.observe(card);
    } else { play(); }

    card.addEventListener('mouseenter', () => { if (!reduce && !animating) play(); });

    if (!reduce && fine) {
      const depths = [9, 15, 11];
      let raf: number | null = null, mx = 0, my = 0;
      const apply = () => {
        raf = null;
        phones.forEach((p, i) => {
          p.style.setProperty('--px', (-mx * depths[i]).toFixed(1) + 'px');
          p.style.setProperty('--py', (-my * depths[i]).toFixed(1) + 'px');
        });
      };
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        mx = (e.clientX - r.left) / r.width  - 0.5;
        my = (e.clientY - r.top ) / r.height - 0.5;
        if (!raf) raf = requestAnimationFrame(apply);
      });
      card.addEventListener('mouseleave', () => {
        mx = 0; my = 0;
        if (!raf) raf = requestAnimationFrame(apply);
      });
    }
  });
</script>
