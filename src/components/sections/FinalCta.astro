---
import Container from '../Container.astro';
import Section from '../Section.astro';
---
<Section id="cta" size="lg" class="relative overflow-hidden bg-ink dark:bg-mist text-paper dark:text-coal">
  {/* Watermark accent: bottom-right corner, low opacity */}
  <img
    src="/brand-watermark.png"
    alt=""
    aria-hidden="true"
    class="pointer-events-none select-none absolute -right-12 -bottom-16 w-[40%] max-w-[480px] opacity-[0.06] dark:opacity-[0.08] invert dark:invert-0"
  />
  <Container>
    <div class="text-center">
      <p
        lang="ar"
        dir="rtl"
        class="font-arabic-display font-bold text-[clamp(4rem,12vw,10rem)] leading-[0.9] mb-12"
        data-reveal
      >
        ابدأ الآن
      </p>

      <h2 class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.1] tracking-tight max-w-2xl mx-auto" data-reveal data-reveal-delay="100">
        The first day you use Irab is the day Arabic clicks differently.
      </h2>

      <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-delay="200">
        <a
          href="https://play.google.com/store/apps/details?id=com.irabapp.arabic"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 px-8 py-4 bg-purple hover:bg-purple-deep text-white font-medium tracking-tight rounded-full transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 20.5V3.5c0-.59.34-1.11.84-1.35L13.69 12 3.84 21.85c-.5-.25-.84-.76-.84-1.35M16.81 15.12L6.05 21.34l8.49-8.49 2.27 2.27M20.16 10.81c.34.27.59.66.59 1.19s-.25.92-.59 1.19l-2.31 1.34-2.61-2.55 2.61-2.55 2.31 1.38M6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z"/></svg>
          <span>Get on Google Play</span>
        </a>
        <a
          href="https://apps.apple.com/app/id6765811277"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 px-8 py-4 border-2 border-paper/45 hover:border-paper bg-paper/5 hover:bg-paper/15 dark:border-coal/45 dark:hover:border-coal dark:bg-coal/5 dark:hover:bg-coal/15 font-medium tracking-tight rounded-full transition-colors duration-200"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09M12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25"/></svg>
          <span>Download on the App Store</span>
        </a>
      </div>

      <p class="mt-8 font-mono text-caption opacity-75">
        Free plan · No signup required · Offline dialect dictionary
      </p>
    </div>
  </Container>
</Section>
