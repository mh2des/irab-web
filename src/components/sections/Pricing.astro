---
import Container from '../Container.astro';
import Section from '../Section.astro';

const free = [
  '3 daily i\'rab analyses',
  '5 daily Smart Dictionary lookups',
  'Unlimited Traditional + Dialect dictionaries',
  'Library of 47 classical grammar books (25,000+ chapters)',
  'Voice input',
  'Practice Levels 1-2 and Campaign Bab 1-2',
  'No ads.',
];

const plus = [
  'Unlimited i\'rab analyses',
  'Unlimited Smart Dictionary lookups',
  'Full 576-sentence practice bank + custom i\'rab grading',
  'All 7 challenge abwaab and premium explanations',
  'OCR camera, PDF export, and unwatermarked image sharing',
  'Progress analytics, leaderboard placement, and extra streak freeze',
  'Mastery certificates on the annual plan',
];
---
<Section id="pricing" class="bg-paper-soft/40 dark:bg-coal-soft/30 border-y border-stone/60 dark:border-coal-edge/60">
  <Container>
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="eyebrow mb-4" data-reveal>Pricing</p>
      <h2 class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.1] tracking-tight" data-reveal data-reveal-delay="100">
        Free to try. Honest to pay for.
      </h2>
      <p class="mt-6 text-body-lg text-ink/70 dark:text-mist/70" data-reveal data-reveal-delay="200">
        Two plans. No decoy middle tier.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {/* Free */}
      <div
        class="relative p-8 md:p-10 rounded-2xl border-2 border-teal/30 dark:border-teal/40 bg-paper dark:bg-coal-soft flex flex-col"
        data-reveal
      >
        <span class="absolute -top-3 left-8 px-3 py-1 bg-teal text-white text-caption font-mono tracking-wider rounded-full">START HERE</span>
        <div class="flex items-baseline justify-between gap-3 mb-2 mt-2">
          <h3 class="font-display text-h2 leading-tight">Free</h3>
          <p class="font-mono text-caption text-teal uppercase tracking-widest">Forever</p>
        </div>
        <p class="text-body text-ink/70 dark:text-mist/70 mb-8">Enough to start studying seriously, with clear daily limits.</p>

        <ul class="space-y-3 mb-10 flex-1">
          {free.map((f) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 text-ink/40 dark:text-mist/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12l5 5L20 7"/></svg>
              <span class="text-body">{f}</span>
            </li>
          ))}
        </ul>

        <a
          href="https://play.google.com/store/apps/details?id=com.irabapp.arabic"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-6 py-3 bg-teal hover:bg-teal-deep text-white font-medium tracking-tight rounded-full transition-colors duration-200"
        >
          Get the free app
        </a>
      </div>

      {/* Plus */}
      <div
        class="relative p-8 md:p-10 rounded-2xl border-2 border-purple bg-paper dark:bg-coal-soft flex flex-col"
        data-reveal data-reveal-delay="100"
      >
        <span class="absolute -top-3 left-8 px-3 py-1 bg-purple text-white text-caption font-mono tracking-wider rounded-full">FOR SERIOUS LEARNERS</span>

        <div class="flex items-baseline justify-between gap-3 mb-2 mt-2">
          <h3 class="font-display text-h2 leading-tight">Irab Plus</h3>
          <p class="font-mono text-caption text-ink/40 dark:text-mist/40 uppercase tracking-widest">From $4.99/mo</p>
        </div>
        <p class="text-body text-ink/70 dark:text-mist/70 mb-8">Everything in Free, plus the full learning system and higher ceilings.</p>

        <ul class="space-y-3 mb-10 flex-1">
          {plus.map((p) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 text-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12l5 5L20 7"/></svg>
              <span class="text-body">{p}</span>
            </li>
          ))}
        </ul>

        <a
          href="https://play.google.com/store/apps/details?id=com.irabapp.arabic"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-6 py-3 bg-purple hover:bg-purple-deep text-white font-medium tracking-tight rounded-full transition-colors duration-200"
        >
          Start 7-day free trial
        </a>
      </div>
    </div>

    <p class="text-center mt-10 font-mono text-caption text-ink/50 dark:text-mist/50" data-reveal>
      Cancel anytime · 7-day free trial on annual · Regional pricing may vary
    </p>
  </Container>
</Section>
