---
/**
 * Paywall: the shared "you've used your free daily tries" upgrade gate.
 *
 * One polished, fully-responsive modal reused by every gated tool (analyzer,
 * dictionary, practice). It exposes a tiny global API so any tool's <script>
 * can summon it on a 429 without duplicating markup, styles, or the Paddle
 * checkout flow:
 *
 *     window.IrabPaywall.show({ uid?, email?, onActivated? })
 *     window.IrabPaywall.hide()
 *
 * When uid/email are omitted it reads the current Firebase user itself, so most
 * callers just call `window.IrabPaywall?.show()`. On a completed Paddle
 * checkout it shows an "activating" state, polls the entitlement, then reloads
 * (or runs onActivated). For signed-out clickers it routes to login.
 *
 * Mounted ONCE per page — render it inside each tool component (a page only
 * ever shows one tool), and the init script self-guards against double-mount.
 */
import { PADDLE_ENABLED } from '../lib/paddle';

interface Props { lang?: 'ar' | 'en'; }
const { lang = 'ar' } = Astro.props;
const dir = lang === 'ar' ? 'rtl' : 'ltr';
const login = lang === 'ar' ? '/login' : '/en/login';
const pricing = lang === 'ar' ? '/pricing' : '/en/pricing';
const titleFont = lang === 'ar' ? 'font-arabic-display' : 'font-display';

const t = lang === 'ar'
  ? {
      eyebrow: 'إعراب بلس',
      title: 'واصِل بلا حدود',
      body: 'أنهيت محاولاتك المجانية لليوم. اشترك لتُحلّل وتتدرّب بلا حدود — مع تصحيح إعرابك بالذكاء الاصطناعي، الميزة التي تميّزنا.',
      benefits: [
        'تحليل وتدريب بلا حدود كل يوم',
        'تصحيح ذكي مفصّل لإعراب كل كلمة',
        'بنك التدريب الكامل: ٥٧٦ جملة',
        'المعجم الذكي ومسح OCR وتصدير PDF',
        'شهادات الإتقان على الخطة السنوية',
        'حساب واحد على الويب والتطبيق',
      ],
      annual: 'سنوي',
      monthly: 'شهري',
      annualPrice: '٣٧٫٩٩$',
      monthlyPrice: '٤٫٩٩$',
      annualPer: '≈ ٣٫١٧$ شهريًّا',
      perMonth: '/ شهر',
      annualMeta: 'تجربة ٧ أيام مجانًا، ألغِ متى شئت',
      monthlyMeta: 'يُجدَّد شهريًّا، ألغِ متى شئت',
      save: 'وفّر ٣٧٪',
      popular: 'الأكثر اختيارًا',
      annualCta: 'ابدأ تجربة ٧ أيام مجانًا',
      monthlyCta: 'اشترك شهريًّا',
      secure: 'دفع آمن عبر Paddle · إلغاء في أي وقت · تفعيل فوري',
      pricing: 'عرض كل الخطط',
      activatingTitle: 'تم الدفع — جارٍ تفعيل اشتراكك',
      activatingBody: 'سيُفتح الوصول غير المحدود خلال لحظات…',
      close: 'إغلاق',
    }
  : {
      eyebrow: 'Irab Plus',
      title: 'Keep going, no limits',
      body: "You've used today's free tries. Subscribe to analyze and practice without limits — with AI feedback on your own i'rab, the feature that sets us apart.",
      benefits: [
        'Unlimited analysis & practice, every day',
        'Detailed AI feedback on every word',
        'Full practice bank: 576 sentences',
        'Smart dictionary, OCR scan & PDF export',
        'Mastery certificates on the annual plan',
        'One account across web & app',
      ],
      annual: 'Annual',
      monthly: 'Monthly',
      annualPrice: '$37.99',
      monthlyPrice: '$4.99',
      annualPer: '≈ $3.17/mo',
      perMonth: '/mo',
      annualMeta: '7-day free trial, cancel anytime',
      monthlyMeta: 'Renews monthly, cancel anytime',
      save: 'Save 37%',
      popular: 'Most popular',
      annualCta: 'Start 7-day free trial',
      monthlyCta: 'Subscribe monthly',
      secure: 'Secure checkout by Paddle · Cancel anytime · Instant unlock',
      pricing: 'See all plans',
      activatingTitle: 'Payment received — activating your subscription',
      activatingBody: 'Unlimited access will unlock in a few moments…',
      close: 'Close',
    };
---

<div data-pw-root data-lang={lang} data-login={login} dir={dir}
     class="pw-backdrop pw-hidden" role="dialog" aria-modal="true" aria-labelledby="pw-title">
  <section class="pw-dialog">
    <button type="button" data-pw-close class="pw-close" aria-label={t.close}>
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

    {/* ── Main view ── */}
    <div data-pw-main class="pw-grid">
      {/* Left: the pitch */}
      <aside class="pw-aside">
        <span class="pw-eyebrow">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12 2l2.4 6.8L21 9l-5.2 4 1.8 7L12 16.6 6.4 20l1.8-7L3 9l6.6-.2z"/></svg>
          {t.eyebrow}
        </span>
        <h2 id="pw-title" class:list={[titleFont, 'pw-title']}>{t.title}</h2>
        <p class="pw-body">{t.body}</p>
        <ul class="pw-benefits">
          {t.benefits.map((b) => (
            <li class="pw-benefit">
              <svg class="pw-benefit-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </aside>

      {/* Right: the plans */}
      <div class="pw-main">
        {PADDLE_ENABLED ? (
          <div class="pw-plans">
            <button type="button" data-pw-plan="annual" class="pw-plan pw-plan-featured">
              <span class="pw-plan-flag">{t.popular}</span>
              <span class="pw-plan-row">
                <span class="pw-plan-name">{t.annual}</span>
                <span class="pw-plan-save">{t.save}</span>
              </span>
              <span class="pw-plan-priceline">
                <span class="pw-plan-price">{t.annualPrice}</span>
                <span class="pw-plan-per">{t.annualPer}</span>
              </span>
              <span class="pw-plan-meta">{t.annualMeta}</span>
              <span class="pw-plan-cta pw-cta-primary">{t.annualCta}</span>
            </button>
            <button type="button" data-pw-plan="monthly" class="pw-plan">
              <span class="pw-plan-row">
                <span class="pw-plan-name">{t.monthly}</span>
              </span>
              <span class="pw-plan-priceline">
                <span class="pw-plan-price">{t.monthlyPrice}</span>
                <span class="pw-plan-per">{t.perMonth}</span>
              </span>
              <span class="pw-plan-meta">{t.monthlyMeta}</span>
              <span class="pw-plan-cta pw-cta-ghost">{t.monthlyCta}</span>
            </button>
          </div>
        ) : (
          <a href={pricing} class="pw-plan-link">{t.pricing}</a>
        )}
        <p class="pw-fineprint">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          {t.secure}
        </p>
      </div>
    </div>

    {/* ── Activating state ── */}
    <div data-pw-activating class="pw-activating pw-hidden">
      <div class="pw-activating-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <h3 class:list={[titleFont, 'pw-activating-title']}>{t.activatingTitle}</h3>
      <p>{t.activatingBody}</p>
      <div class="pw-spinner" aria-hidden="true"></div>
    </div>
  </section>
</div>

<style is:global>
  .pw-backdrop {
    position: fixed; inset: 0; z-index: 9999;
    display: grid; place-items: center;
    padding: clamp(0.75rem, 3vw, 2rem);
    background: color-mix(in srgb, var(--color-coal) 58%, transparent);
    backdrop-filter: blur(6px) saturate(1.1);
    -webkit-backdrop-filter: blur(6px) saturate(1.1);
    overflow-y: auto;
    animation: pw-fade 0.22s ease both;
  }
  .pw-backdrop.pw-hidden { display: none; }
  @keyframes pw-fade { from { opacity: 0; } to { opacity: 1; } }

  .pw-dialog {
    position: relative;
    width: min(960px, 100%);
    max-height: calc(100dvh - 1.5rem);
    overflow: auto;
    border-radius: 28px;
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    box-shadow: var(--shadow-lift);
    animation: pw-rise 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .dark .pw-dialog { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }
  @keyframes pw-rise { from { opacity: 0; transform: translateY(18px) scale(0.985); } to { opacity: 1; transform: none; } }

  .pw-close {
    position: absolute; inset-inline-end: 0.85rem; inset-block-start: 0.85rem; z-index: 2;
    width: 2.4rem; height: 2.4rem; display: grid; place-items: center;
    border-radius: 50%; cursor: pointer;
    color: color-mix(in srgb, var(--color-ink) 60%, transparent);
    background: color-mix(in srgb, var(--color-paper) 80%, transparent);
    border: 1px solid var(--color-card-edge);
    transition: color 0.15s, transform 0.15s, background 0.15s;
  }
  .pw-close:hover { color: var(--color-ink); transform: rotate(90deg); }
  .dark .pw-close { color: color-mix(in srgb, var(--color-mist) 70%, transparent); background: color-mix(in srgb, var(--color-coal) 70%, transparent); border-color: var(--color-coal-edge); }
  .dark .pw-close:hover { color: var(--color-mist); }
  .pw-close svg { width: 1.15rem; height: 1.15rem; }

  /* ── Layout: two columns on desktop, stacked on mobile ── */
  .pw-grid { display: grid; grid-template-columns: 1.04fr 0.96fr; }
  @media (max-width: 800px) { .pw-grid { grid-template-columns: 1fr; } }

  /* Left pitch pane */
  .pw-aside {
    padding: clamp(1.5rem, 3.5vw, 2.75rem);
    background:
      radial-gradient(120% 90% at 0% 0%, color-mix(in srgb, var(--color-purple) 12%, transparent) 0%, transparent 55%),
      color-mix(in srgb, var(--color-purple) 4%, var(--color-paper-soft));
    border-inline-end: 1px solid var(--color-card-edge);
  }
  .dark .pw-aside {
    background:
      radial-gradient(120% 90% at 0% 0%, color-mix(in srgb, var(--color-purple) 22%, transparent) 0%, transparent 55%),
      var(--color-coal);
    border-inline-end-color: var(--color-coal-edge);
  }
  @media (max-width: 800px) { .pw-aside { border-inline-end: none; border-block-end: 1px solid var(--color-card-edge); } .dark .pw-aside { border-block-end-color: var(--color-coal-edge); } }

  .pw-eyebrow {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.02em;
    padding: 0.32rem 0.7rem; border-radius: 999px;
    color: var(--color-purple-deep);
    background: color-mix(in srgb, var(--color-purple) 14%, transparent);
  }
  .dark .pw-eyebrow { color: color-mix(in srgb, var(--color-purple) 88%, white); background: color-mix(in srgb, var(--color-purple) 24%, var(--color-coal)); }
  .pw-eyebrow svg { width: 0.95rem; height: 0.95rem; }

  .pw-title { margin-top: 1rem; font-size: clamp(1.85rem, 4.2vw, 2.85rem); line-height: 1.06; color: var(--color-ink); }
  .dark .pw-title { color: var(--color-mist); }
  .pw-body { margin-top: 0.85rem; font-size: 1rem; line-height: 1.65; color: color-mix(in srgb, var(--color-ink) 74%, transparent); }
  .dark .pw-body { color: color-mix(in srgb, var(--color-mist) 74%, transparent); }

  .pw-benefits { list-style: none; margin: 1.35rem 0 0; padding: 0; display: grid; gap: 0.7rem; }
  .pw-benefit { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.95rem; line-height: 1.5; color: color-mix(in srgb, var(--color-ink) 84%, transparent); }
  .dark .pw-benefit { color: color-mix(in srgb, var(--color-mist) 84%, transparent); }
  .pw-benefit-ic {
    width: 1.35rem; height: 1.35rem; flex: none; padding: 0.18rem; border-radius: 50%;
    color: var(--color-teal); background: color-mix(in srgb, var(--color-teal) 14%, transparent);
  }
  .dark .pw-benefit-ic { background: color-mix(in srgb, var(--color-teal) 26%, transparent); color: color-mix(in srgb, var(--color-teal) 80%, white); }

  /* Right plans pane */
  .pw-main { padding: clamp(1.5rem, 3.5vw, 2.75rem); display: flex; flex-direction: column; justify-content: center; }
  .pw-plans { display: grid; gap: 0.85rem; }

  .pw-plan {
    position: relative; display: flex; flex-direction: column; gap: 0.35rem;
    text-align: start; cursor: pointer; width: 100%;
    padding: 1.15rem 1.25rem; border-radius: 18px;
    background: var(--color-card);
    border: 1.5px solid var(--color-card-edge);
    transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
  }
  .dark .pw-plan { background: var(--color-coal); border-color: var(--color-coal-edge); }
  .pw-plan:hover { transform: translateY(-3px); box-shadow: var(--shadow-card); border-color: color-mix(in srgb, var(--color-purple) 55%, var(--color-card-edge)); }
  .pw-plan:disabled { opacity: 0.6; cursor: progress; transform: none; }
  .pw-plan-featured { border-color: var(--color-purple); box-shadow: 0 0 0 1px var(--color-purple) inset; }
  .dark .pw-plan-featured { border-color: var(--color-purple); }

  .pw-plan-flag {
    position: absolute; inset-block-start: -0.7rem; inset-inline-start: 1.1rem;
    font-size: 0.7rem; font-weight: 800; letter-spacing: 0.03em;
    padding: 0.2rem 0.6rem; border-radius: 999px;
    color: white; background: var(--color-purple);
    box-shadow: var(--shadow-card);
  }
  .pw-plan-row { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .pw-plan-name { font-size: 0.95rem; font-weight: 700; color: var(--color-ink); }
  .dark .pw-plan-name { color: var(--color-mist); }
  .pw-plan-save {
    font-size: 0.72rem; font-weight: 800; padding: 0.15rem 0.5rem; border-radius: 999px;
    color: var(--color-teal-deep); background: color-mix(in srgb, var(--color-teal) 16%, transparent);
  }
  .dark .pw-plan-save { color: color-mix(in srgb, var(--color-teal) 82%, white); background: color-mix(in srgb, var(--color-teal) 26%, transparent); }
  .pw-plan-priceline { display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; }
  .pw-plan-price { font-size: 1.7rem; font-weight: 800; line-height: 1; color: var(--color-ink); }
  .dark .pw-plan-price { color: var(--color-mist); }
  .pw-plan-per { font-size: 0.85rem; color: color-mix(in srgb, var(--color-ink) 60%, transparent); }
  .dark .pw-plan-per { color: color-mix(in srgb, var(--color-mist) 60%, transparent); }
  .pw-plan-meta { font-size: 0.82rem; color: color-mix(in srgb, var(--color-ink) 58%, transparent); }
  .dark .pw-plan-meta { color: color-mix(in srgb, var(--color-mist) 58%, transparent); }

  .pw-plan-cta {
    margin-top: 0.65rem; text-align: center; font-weight: 700; font-size: 0.95rem;
    padding: 0.7rem 1rem; border-radius: 999px;
    transition: filter 0.15s, background 0.15s;
  }
  .pw-cta-primary { color: white; background: var(--color-purple); }
  .pw-plan:hover .pw-cta-primary { filter: brightness(1.07); }
  .pw-cta-ghost { color: var(--color-purple-deep); background: color-mix(in srgb, var(--color-purple) 10%, transparent); }
  .dark .pw-cta-ghost { color: color-mix(in srgb, var(--color-purple) 88%, white); background: color-mix(in srgb, var(--color-purple) 20%, transparent); }

  .pw-plan-link {
    display: block; text-align: center; font-weight: 700;
    padding: 0.9rem 1rem; border-radius: 999px;
    color: white; background: var(--color-purple);
  }
  .pw-plan-link:hover { filter: brightness(1.07); }

  .pw-fineprint {
    display: flex; align-items: center; justify-content: center; gap: 0.45rem;
    margin-top: 1.1rem; text-align: center; font-size: 0.78rem;
    color: color-mix(in srgb, var(--color-ink) 56%, transparent);
  }
  .dark .pw-fineprint { color: color-mix(in srgb, var(--color-mist) 56%, transparent); }
  .pw-fineprint svg { width: 0.9rem; height: 0.9rem; flex: none; }

  /* Activating state */
  .pw-activating { padding: clamp(2.5rem, 6vw, 4rem) 1.5rem; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .pw-activating.pw-hidden { display: none; }
  .pw-activating-mark {
    width: 4rem; height: 4rem; display: grid; place-items: center; border-radius: 50%;
    color: white; background: var(--color-teal); margin-bottom: 1.1rem;
    animation: pw-pop 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .pw-activating-mark svg { width: 2rem; height: 2rem; }
  @keyframes pw-pop { from { transform: scale(0.4); opacity: 0; } to { transform: none; opacity: 1; } }
  .pw-activating-title { font-size: clamp(1.5rem, 3.5vw, 2.1rem); line-height: 1.15; color: var(--color-ink); }
  .dark .pw-activating-title { color: var(--color-mist); }
  .pw-activating p { margin-top: 0.6rem; color: color-mix(in srgb, var(--color-ink) 66%, transparent); }
  .dark .pw-activating p { color: color-mix(in srgb, var(--color-mist) 68%, transparent); }
  .pw-spinner {
    margin-top: 1.5rem; width: 1.6rem; height: 1.6rem; border-radius: 50%;
    border: 3px solid color-mix(in srgb, var(--color-purple) 22%, transparent);
    border-top-color: var(--color-purple); animation: pw-spin 0.8s linear infinite;
  }
  @keyframes pw-spin { to { transform: rotate(360deg); } }

  @media (prefers-reduced-motion: reduce) {
    .pw-backdrop, .pw-dialog, .pw-activating-mark { animation: none; }
    .pw-plan:hover { transform: none; }
    .pw-close:hover { transform: none; }
    .pw-spinner { animation-duration: 1.6s; }
  }
</style>

<script>
  import { PADDLE_ENABLED } from '../lib/paddle';

  // Self-guard: only the first instance on a page wires up the global API.
  if (!(window as any).IrabPaywall) {
    const root = document.querySelector<HTMLElement>('[data-pw-root]');
    if (root) {
      const lang = root.dataset.lang === 'en' ? 'en' : 'ar';
      const loginHref = root.dataset.login || '/login';
      const q = <T extends Element>(s: string) => root.querySelector<T>(s)!;
      const mainView = q<HTMLElement>('[data-pw-main]');
      const activating = q<HTMLElement>('[data-pw-activating]');

      let onActivated: (() => void) | null = null;
      let passedUid: string | null = null;
      let passedEmail: string | null = null;

      function hide() {
        root!.classList.add('pw-hidden');
        document.documentElement.style.removeProperty('overflow');
      }
      function show(opts?: { uid?: string; email?: string; onActivated?: () => void }) {
        onActivated = opts?.onActivated ?? null;
        passedUid = opts?.uid ?? null;
        passedEmail = opts?.email ?? null;
        mainView.classList.remove('pw-hidden');
        activating.classList.add('pw-hidden');
        root!.classList.remove('pw-hidden');
        document.documentElement.style.overflow = 'hidden';
        setTimeout(() => root!.querySelector<HTMLButtonElement>('[data-pw-plan="annual"]')?.focus(), 80);
      }

      // Close: button, backdrop click, Escape.
      q<HTMLButtonElement>('[data-pw-close]').addEventListener('click', hide);
      root.addEventListener('click', (ev) => { if (ev.target === root) hide(); });
      document.addEventListener('keydown', (ev) => {
        if (ev.key === 'Escape' && !root!.classList.contains('pw-hidden')) hide();
      });

      // Resolve the current Firebase user (prefer values passed to show()).
      async function currentUser(): Promise<{ uid: string; email: string | null } | null> {
        if (passedUid) return { uid: passedUid, email: passedEmail };
        try {
          const { auth } = await import('../lib/firebase');
          const u = auth.currentUser;
          return u ? { uid: u.uid, email: u.email } : null;
        } catch { return null; }
      }

      async function pollEntitlementThenReload() {
        try {
          const [{ auth }, { fetchMe }] = await Promise.all([
            import('../lib/firebase'), import('../lib/entitlement'),
          ]);
          const u = auth.currentUser;
          if (u) {
            for (let i = 0; i < 12; i++) {
              await new Promise((r) => setTimeout(r, 3000));
              try { const me = await fetchMe(u); if (me?.premium) break; } catch { /* keep waiting */ }
            }
          }
        } catch { /* fall through to reload */ }
        if (onActivated) { try { onActivated(); return; } catch { /* fall through */ } }
        window.location.reload();
      }

      if (PADDLE_ENABLED) {
        root.querySelectorAll<HTMLButtonElement>('[data-pw-plan]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const user = await currentUser();
            if (!user) { window.location.href = loginHref; return; }
            const plan = btn.dataset.pwPlan === 'monthly' ? 'monthly' : 'annual';
            btn.disabled = true;
            try {
              const { openCheckout } = await import('../lib/paddle');
              await openCheckout({
                plan,
                firebaseUid: user.uid,
                email: user.email || undefined,
                lang,
                onComplete: () => {
                  mainView.classList.add('pw-hidden');
                  activating.classList.remove('pw-hidden');
                  pollEntitlementThenReload();
                },
              });
            } catch (e) {
              console.error('paddle checkout failed', e);
            } finally {
              btn.disabled = false;
            }
          });
        });
      }

      (window as any).IrabPaywall = { show, hide };
    }
  }
</script>
