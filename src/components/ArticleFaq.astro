---
/**
 * Article FAQ, drop-in FAQ section + JSON-LD schema injection.
 */
import Container from './Container.astro';

interface FaqItem { q: string; a: string; }

interface Props {
  items: FaqItem[];
  lang?: 'en' | 'ar';
}

const { items, lang = 'ar' } = Astro.props;

const t = lang === 'ar'
  ? { eyebrow: 'أسئلة شائعة', title: 'أسئلة متكررة' }
  : { eyebrow: 'Common questions', title: 'Frequently asked' };

const titleClass = lang === 'ar' ? 'font-arabic-display' : 'font-display';
const bodyClass  = lang === 'ar' ? 'font-arabic leading-loose' : '';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<section class="py-16 md:py-20 border-t border-stone dark:border-coal-edge">
  <Container size="narrow">
    <p class="eyebrow mb-4">{t.eyebrow}</p>
    <h2 class:list={[titleClass, 'text-[clamp(1.75rem,3.5vw,2.5rem)] tracking-tight mb-10']}>{t.title}</h2>

    <div class="divide-y divide-stone dark:divide-coal-edge border-y border-stone dark:border-coal-edge">
      {items.map((f) => (
        <details class="group py-5 cursor-pointer">
          <summary class="flex items-start justify-between gap-4 list-none [&::-webkit-details-marker]:hidden">
            <h3 class:list={[titleClass, 'text-h3 leading-snug']}>{f.q}</h3>
            <span class="shrink-0 mt-1 transition-transform duration-300 group-open:rotate-45">
              <svg class="w-4 h-4 text-ink/40 dark:text-mist/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            </span>
          </summary>
          <p class:list={[bodyClass, 'mt-3 text-body text-ink/70 dark:text-mist/70 pe-10']}>{f.a}</p>
        </details>
      ))}
    </div>
  </Container>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
