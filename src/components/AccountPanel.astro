---
/**
 * AccountPanel — the signed-in profile (/account). Clean, boxed sections:
 * identity, subscription, quick links, sign out. Redirects to /login if not
 * authed. Data attributes are unchanged so the auth script keeps working.
 */
interface Props { lang?: 'ar' | 'en'; }
const { lang = 'ar' } = Astro.props;
const login = lang === 'ar' ? '/login' : '/en/login';
const home = lang === 'ar' ? '/' : '/en';
const appHref = lang === 'ar' ? '/app' : '/en/app';
const historyHref = lang === 'ar' ? '/history' : '/en/history';
const pricing = '/pricing';

const t = lang === 'ar'
  ? {
      eyebrow: 'حسابي', loading: 'جارٍ التحميل…',
      plan: 'الاشتراك', planChecking: 'جارٍ التحقّق…',
      openApp: 'افتح تطبيقي', appDesc: 'أدواتك وإحصاءاتك',
      history: 'سجلّي', historyDesc: 'تحليلاتك وتمارينك السابقة',
      upgrade: 'الترقية إلى إعراب بلس',
      signOut: 'تسجيل الخروج',
      resend: 'إعادة إرسال رابط التوثيق',
    }
  : {
      eyebrow: 'My account', loading: 'Loading…',
      plan: 'Subscription', planChecking: 'Checking…',
      openApp: 'Open my app', appDesc: 'Your tools and stats',
      history: 'My history', historyDesc: 'Your past analyses and practice',
      upgrade: 'Upgrade to Irab Plus',
      signOut: 'Sign out',
      resend: 'Resend verification link',
    };
const dir = lang === 'ar' ? 'rtl' : 'ltr';
const chev = lang === 'ar' ? 'M15 18l-6-6 6-6' : 'M9 18l6-6-6-6';
---
<div data-account-root data-lang={lang} data-login={login} dir={dir} class="acct">
  {/* Loading skeleton */}
  <div data-loading class="acct-card acct-id" aria-busy="true" aria-label={t.loading}>
    <div class="skeleton acct-avatar"></div>
    <div class="flex-1 space-y-2.5 min-w-0">
      <div class="skeleton h-6 w-2/5 rounded-md"></div>
      <div class="skeleton h-4 w-3/5 rounded-md"></div>
    </div>
  </div>

  <div data-panel class="hidden panel-in space-y-4">
    {/* Identity */}
    <section class="acct-card acct-id">
      <div data-avatar class="acct-avatar acct-avatar-real"></div>
      <div class="acct-id-main">
        <h1 data-name class="acct-name"></h1>
        <p data-email dir="ltr" class="acct-email"></p>
        <div class="acct-verify">
          <span data-verify-badge class="badge"></span>
          <button type="button" data-resend class="acct-resend hidden">{t.resend}</button>
        </div>
      </div>
    </section>

    {/* Subscription */}
    <section class="acct-card">
      <div class="acct-row">
        <p class="acct-eyebrow">{t.plan}</p>
        <span data-plan-badge class="badge hidden"></span>
      </div>
      <p data-plan class="acct-plan-name">{t.planChecking}</p>
      <p data-plan-note class="acct-note"></p>
      <a data-upgrade href={pricing} class="btn-primary btn-block mt-4 hidden">{t.upgrade}</a>
    </section>

    {/* Quick links */}
    <section class="acct-links">
      <a href={appHref} class="acct-link">
        <span class="acct-link-ic acct-link-ic-purple" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg></span>
        <span class="acct-link-main"><span class="acct-link-title">{t.openApp}</span><span class="acct-link-desc">{t.appDesc}</span></span>
        <svg class="acct-link-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={chev}/></svg>
      </a>
      <a href={historyHref} class="acct-link">
        <span class="acct-link-ic acct-link-ic-teal" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l4 2"/></svg></span>
        <span class="acct-link-main"><span class="acct-link-title">{t.history}</span><span class="acct-link-desc">{t.historyDesc}</span></span>
        <svg class="acct-link-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={chev}/></svg>
      </a>
    </section>

    {/* Sign out */}
    <div class="text-center pt-1">
      <button type="button" data-signout class="acct-signout">{t.signOut}</button>
    </div>
  </div>
</div>

<style>
  .acct { width: 100%; max-width: 30rem; margin-inline: auto; }
  .acct-card {
    background: var(--color-card); border: 1px solid var(--color-card-edge);
    border-radius: 1.1rem; box-shadow: var(--shadow-card); padding: 1.5rem;
  }
  :global(.dark) .acct-card { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }

  /* Identity */
  .acct-id { display: flex; align-items: center; gap: 1.1rem; }
  .acct-avatar { width: 4.5rem; height: 4.5rem; border-radius: 999px; flex: none; }
  .acct-avatar-real {
    display: grid; place-items: center; font-family: var(--font-sans); font-weight: 800; font-size: 1.9rem;
    color: #fff; background: linear-gradient(140deg, var(--color-purple), var(--color-purple-deep));
    box-shadow: 0 10px 22px -10px var(--color-purple);
  }
  .acct-id-main { min-width: 0; }
  .acct-name { font-family: var(--font-sans); font-weight: 800; font-size: 1.65rem; line-height: 1.2; color: var(--color-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  :global(.dark) .acct-name { color: var(--color-mist); }
  .acct-email { margin-top: 0.15rem; font-size: 1.05rem; color: color-mix(in srgb, var(--color-ink) 60%, transparent); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  :global(.dark) .acct-email { color: color-mix(in srgb, var(--color-mist) 62%, transparent); }
  .acct-verify { margin-top: 0.7rem; display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .acct-resend { font-size: 1rem; font-weight: 700; color: var(--color-purple-deep); }
  :global(.dark) .acct-resend { color: color-mix(in srgb, var(--color-purple) 84%, white); }

  /* Subscription */
  .acct-row { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; }
  .acct-eyebrow { font-weight: 800; font-size: var(--text-caption); color: color-mix(in srgb, var(--color-ink) 60%, transparent); }
  :global(.dark) .acct-eyebrow { color: color-mix(in srgb, var(--color-mist) 64%, transparent); }
  .acct-plan-name { margin-top: 0.35rem; font-family: var(--font-display); font-weight: 700; font-size: 1.9rem; line-height: 1.1; color: var(--color-ink); }
  :global(.dark) .acct-plan-name { color: var(--color-mist); }
  .acct-note { margin-top: 0.5rem; font-size: 1.1rem; line-height: 1.7; color: color-mix(in srgb, var(--color-ink) 70%, transparent); }
  :global(.dark) .acct-note { color: color-mix(in srgb, var(--color-mist) 72%, transparent); }

  /* Quick links */
  .acct-links { display: grid; gap: 0.6rem; }
  .acct-link {
    display: flex; align-items: center; gap: 0.9rem; padding: 0.95rem 1.1rem; border-radius: 1rem;
    background: var(--color-card); border: 1px solid var(--color-card-edge); box-shadow: var(--shadow-card);
    text-decoration: none; transition: transform .18s var(--ease-out-quart), border-color .18s, box-shadow .18s;
  }
  :global(.dark) .acct-link { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }
  .acct-link:hover { transform: translateY(-2px); border-color: color-mix(in srgb, var(--color-purple) 40%, var(--color-card-edge)); box-shadow: var(--shadow-lift); }
  .acct-link-ic { width: 2.6rem; height: 2.6rem; border-radius: 0.8rem; flex: none; display: grid; place-items: center; }
  .acct-link-ic svg { width: 1.3rem; height: 1.3rem; }
  .acct-link-ic-purple { color: var(--color-purple-deep); background: color-mix(in srgb, var(--color-purple) 12%, white); }
  .acct-link-ic-teal { color: var(--color-teal); background: color-mix(in srgb, var(--color-teal) 12%, white); }
  :global(.dark) .acct-link-ic-purple { background: color-mix(in srgb, var(--color-purple) 22%, var(--color-coal)); }
  :global(.dark) .acct-link-ic-teal { background: color-mix(in srgb, var(--color-teal) 22%, var(--color-coal)); }
  .acct-link-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  .acct-link-title { font-weight: 800; font-size: 1.2rem; color: var(--color-ink); }
  :global(.dark) .acct-link-title { color: var(--color-mist); }
  .acct-link-desc { font-size: 1rem; color: color-mix(in srgb, var(--color-ink) 58%, transparent); }
  :global(.dark) .acct-link-desc { color: color-mix(in srgb, var(--color-mist) 62%, transparent); }
  .acct-link-chev { width: 1.15rem; height: 1.15rem; flex: none; color: color-mix(in srgb, var(--color-ink) 40%, transparent); }
  :global(.dark) .acct-link-chev { color: color-mix(in srgb, var(--color-mist) 45%, transparent); }

  .acct-signout { font-size: 1.1rem; font-weight: 700; color: color-mix(in srgb, var(--color-ink) 58%, transparent); padding: 0.6rem 1rem; transition: color .18s; }
  :global(.dark) .acct-signout { color: color-mix(in srgb, var(--color-mist) 60%, transparent); }
  .acct-signout:hover { color: #dc2626; }
</style>

<script>
  import { onAuth, logout, resendVerification } from '../lib/auth';
  import { fetchMe } from '../lib/entitlement';
  import { rememberSignedIn, forgetSignedIn } from '../lib/session';

  const root = document.querySelector<HTMLElement>('[data-account-root]');
  if (root) {
    const lang = root.dataset.lang === 'en' ? 'en' : 'ar';
    const login = root.dataset.login || '/login';
    const q = <T extends Element>(s: string) => root.querySelector<T>(s)!;
    const loading = q<HTMLElement>('[data-loading]');
    const panel = q<HTMLElement>('[data-panel]');
    const sentMsg = lang === 'ar' ? 'أُرسل رابط التوثيق إلى بريدك ✓' : 'Verification link sent ✓';
    const vText = lang === 'ar'
      ? { yes: 'البريد موثّق', no: 'البريد غير موثّق' }
      : { yes: 'Email verified', no: 'Email not verified' };
    const planText = lang === 'ar'
      ? { free: 'مجاني', plus: 'إعراب بلس',
          noteFree: 'لديك ٣ تحليلات يوميًّا. رقِّ حسابك لإعرابٍ غير محدود، بنك التدريب الكامل، والشهادات السنوية.',
          notePlus: 'اشتراكك مفعّل على جميع أجهزتك: الويب والتطبيق. ✓' }
      : { free: 'Free', plus: 'Irab Plus',
          noteFree: 'You get 3 analyses a day. Upgrade for unlimited i\'rab, the full practice bank, and annual certificates.',
          notePlus: 'Your subscription is active on all your devices: web and app. ✓' };

    onAuth((u) => {
      if (!u) { forgetSignedIn(); window.location.replace(login); return; }
      rememberSignedIn();
      loading.classList.add('hidden');
      panel.classList.remove('hidden');

      const name = u.displayName || (u.email ? u.email.split('@')[0] : (lang === 'ar' ? 'مستخدم' : 'User'));
      q<HTMLElement>('[data-name]').textContent = name;
      q<HTMLElement>('[data-email]').textContent = u.email || '';
      q<HTMLElement>('[data-avatar]').textContent = (name.trim()[0] || '?').toUpperCase();

      const badge = q<HTMLElement>('[data-verify-badge]');
      const resend = q<HTMLButtonElement>('[data-resend]');
      if (u.emailVerified) {
        badge.textContent = vText.yes;
        badge.className = 'badge badge-good';
      } else {
        badge.textContent = vText.no;
        badge.className = 'badge badge-warn';
        resend.classList.remove('hidden');
        resend.addEventListener('click', async () => {
          try { await resendVerification(u); resend.textContent = sentMsg; resend.disabled = true; } catch {}
        }, { once: true });
      }

      const planEl = q<HTMLElement>('[data-plan]');
      const planBadge = q<HTMLElement>('[data-plan-badge]');
      const planNoteEl = q<HTMLElement>('[data-plan-note]');
      const upgrade = q<HTMLAnchorElement>('[data-upgrade]');
      fetchMe(u).then((me) => {
        const premium = me?.premium === true;
        planEl.textContent = premium ? planText.plus : planText.free;
        planNoteEl.textContent = premium ? planText.notePlus : planText.noteFree;
        if (premium) {
          planBadge.textContent = lang === 'ar' ? 'مفعّل' : 'Active';
          planBadge.className = 'badge badge-brand';
          planEl.classList.add('text-purple-deep', 'dark:text-purple');
        } else {
          upgrade.classList.remove('hidden');
        }
      });
    });

    q<HTMLButtonElement>('[data-signout]').addEventListener('click', async () => {
      await logout();
      forgetSignedIn();
      window.location.assign(login);
    });
  }
</script>
