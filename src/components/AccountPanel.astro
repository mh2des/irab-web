---
/**
 * AccountPanel: signed in user's hub. Identity + email verification + plan +
 * sign out. Redirects to /login if not authenticated. Rebuilt on the design
 * system: real .card surfaces, .badge / .btn primitives, readable text, and an
 * entrance reveal: no more blend-in bg-paper card or faint sub-floor text.
 */
interface Props { lang?: 'ar' | 'en'; }
const { lang = 'ar' } = Astro.props;
const login = lang === 'ar' ? '/login' : '/en/login';
const home = lang === 'ar' ? '/' : '/en';
const appHref = lang === 'ar' ? '/app' : '/en/app';
const pricing = lang === 'ar' ? '/pricing' : '/pricing';

const t = lang === 'ar'
  ? {
      title: 'حسابي', loading: 'جارٍ التحميل…',
      plan: 'الاشتراك', planChecking: 'جارٍ التحقّق…',
      openApp: 'فتح تطبيقي', upgrade: 'الترقية إلى إعراب بلس',
      signOut: 'تسجيل الخروج', backHome: 'الصفحة الرئيسية',
    }
  : {
      title: 'My account', loading: 'Loading…',
      plan: 'Subscription', planChecking: 'Checking…',
      openApp: 'Open my app', upgrade: 'Upgrade to Irab Plus',
      signOut: 'Sign out', backHome: 'Home',
    };
const dir = lang === 'ar' ? 'rtl' : 'ltr';
const titleClass = lang === 'ar' ? 'font-arabic-display' : 'font-display';
---
<div data-account-root data-lang={lang} data-login={login} dir={dir} class="w-full max-w-lg mx-auto">
  {/* Loading skeleton until auth resolves */}
  <div data-loading class="card p-7 md:p-9" aria-busy="true" aria-label={t.loading}>
    <div class="flex items-center gap-4">
      <div class="skeleton w-16 h-16 rounded-full"></div>
      <div class="flex-1 space-y-2.5">
        <div class="skeleton h-5 w-2/5 rounded-md"></div>
        <div class="skeleton h-4 w-3/5 rounded-md"></div>
      </div>
    </div>
    <div class="skeleton h-px w-full my-7 rounded-none"></div>
    <div class="skeleton h-20 w-full rounded-xl"></div>
  </div>

  <div data-panel class="hidden panel-in">
    {/* Identity card */}
    <div class="card p-7 md:p-9">
      <div class="flex items-center gap-4">
        <div data-avatar class="w-16 h-16 rounded-full bg-purple text-white grid place-items-center text-2xl font-bold shrink-0 shadow-[0_8px_20px_-8px_var(--color-purple)]"></div>
        <div class="min-w-0">
          <p data-name class:list={[titleClass, 'text-h3 leading-tight truncate']}></p>
          <p data-email dir="ltr" class="text-small text-ink/70 dark:text-mist/70 truncate"></p>
        </div>
      </div>

      <div class="mt-5 flex items-center gap-2 flex-wrap">
        <span data-verify-badge class="badge"></span>
        <button type="button" data-resend class="hidden text-small font-semibold text-purple hover:text-purple-deep transition-colors">
          {lang === 'ar' ? 'إعادة إرسال رابط التوثيق' : 'Resend verification link'}
        </button>
      </div>

      {/* Subscription block */}
      <div class="mt-7 pt-7 border-t border-card-edge dark:border-coal-edge">
        <p class="text-small font-semibold text-ink/70 dark:text-mist/70 mb-2">{t.plan}</p>
        <div class="flex items-center gap-3">
          <p data-plan class:list={[titleClass, 'text-h3']}>{t.planChecking}</p>
          <span data-plan-badge class="badge hidden"></span>
        </div>
        <p data-plan-note class="text-small text-ink/70 dark:text-mist/70 mt-2 leading-relaxed"></p>
        {/* Upgrade CTA (free users only) */}
        <a data-upgrade href={pricing} class="btn-primary btn-block mt-5 hidden">{t.upgrade}</a>
      </div>
    </div>

    {/* Actions */}
    <div class="mt-5 flex flex-col sm:flex-row gap-3">
      <a href={appHref} class="btn-primary btn-block sm:flex-1">{t.openApp}</a>
      <a href={home} class="btn-ghost btn-block sm:w-auto">{t.backHome}</a>
    </div>
    <div class="mt-3 text-center">
      <button type="button" data-signout class="text-small font-semibold text-ink/60 dark:text-mist/60 hover:text-red-600 dark:hover:text-red-400 transition-colors py-2">{t.signOut}</button>
    </div>
  </div>
</div>

<script>
  import { onAuth, logout, resendVerification } from '../lib/auth';
  import { fetchMe } from '../lib/entitlement';
  import { rememberSignedIn, forgetSignedIn } from '../lib/session';

  const root = document.querySelector<HTMLElement>('[data-account-root]');
  if (root) {
    const lang = root.dataset.lang === 'en' ? 'en' : 'ar';
    const login = root.dataset.login || '/login';
    const q = <T extends Element>(s: string) => root.querySelector<T>(s)!;
    const loading = q<HTMLElement>('[data-loading]');
    const panel = q<HTMLElement>('[data-panel]');
    const sentMsg = lang === 'ar' ? 'أُرسل رابط التوثيق إلى بريدك ✓' : 'Verification link sent ✓';
    const vText = lang === 'ar'
      ? { yes: 'البريد موثّق', no: 'البريد غير موثّق' }
      : { yes: 'Email verified', no: 'Email not verified' };
    const planText = lang === 'ar'
      ? { free: 'مجاني', plus: 'إعراب بلس',
          noteFree: 'لديك ٣ تحليلات يوميًّا. رقِّ حسابك لإعرابٍ غير محدود، بنك التدريب الكامل، والشهادات السنوية.',
          notePlus: 'اشتراكك مفعّل على جميع أجهزتك: الويب والتطبيق. ✓' }
      : { free: 'Free', plus: 'Irab Plus',
          noteFree: 'You get 3 analyses a day. Upgrade for unlimited i\'rab, the full practice bank, and annual certificates.',
          notePlus: 'Your subscription is active on all your devices: web and app. ✓' };

    onAuth((u) => {
      if (!u) { forgetSignedIn(); window.location.replace(login); return; }
      rememberSignedIn();
      loading.classList.add('hidden');
      panel.classList.remove('hidden');

      const name = u.displayName || (u.email ? u.email.split('@')[0] : (lang === 'ar' ? 'مستخدم' : 'User'));
      q<HTMLElement>('[data-name]').textContent = name;
      q<HTMLElement>('[data-email]').textContent = u.email || '';
      q<HTMLElement>('[data-avatar]').textContent = (name[0] || '?').toUpperCase();

      const badge = q<HTMLElement>('[data-verify-badge]');
      const resend = q<HTMLButtonElement>('[data-resend]');
      if (u.emailVerified) {
        badge.textContent = vText.yes;
        badge.className = 'badge badge-good';
      } else {
        badge.textContent = vText.no;
        badge.className = 'badge badge-warn';
        resend.classList.remove('hidden');
        resend.addEventListener('click', async () => {
          try { await resendVerification(u); resend.textContent = sentMsg; resend.disabled = true; } catch {}
        }, { once: true });
      }

      // Subscription status: read from the worker (RevenueCat by uid).
      const planEl = q<HTMLElement>('[data-plan]');
      const planBadge = q<HTMLElement>('[data-plan-badge]');
      const planNoteEl = q<HTMLElement>('[data-plan-note]');
      const upgrade = q<HTMLAnchorElement>('[data-upgrade]');
      fetchMe(u).then((me) => {
        const premium = me?.premium === true;
        planEl.textContent = premium ? planText.plus : planText.free;
        planNoteEl.textContent = premium ? planText.notePlus : planText.noteFree;
        if (premium) {
          planBadge.textContent = lang === 'ar' ? 'مفعّل' : 'Active';
          planBadge.className = 'badge badge-brand';
          planEl.classList.add('text-purple-deep', 'dark:text-purple');
        } else {
          upgrade.classList.remove('hidden');
        }
      });
    });

    q<HTMLButtonElement>('[data-signout]').addEventListener('click', async () => {
      await logout();
      forgetSignedIn();
      window.location.assign(login);
    });
  }
</script>
