---
/**
 * /app — the signed-in web app home (Arabic). Dashboard of all tools + plan +
 * usage. Login-gated, noindex (private surface). Firebase loads only here.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import AppHub from '../components/AppHub.astro';
---
<BaseLayout lang="ar" title="تطبيقي · إعراب" description="كلّ أدوات إعراب في مكان واحد.">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Nav lang="ar" />
  <main class="px-6 py-12 md:py-16">
    <AppHub lang="ar" />
  </main>
  <Footer lang="ar" />
</BaseLayout>
