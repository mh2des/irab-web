---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import AuthForm from '../components/AuthForm.astro';
---
<BaseLayout lang="ar" title="تسجيل الدخول · إعراب" description="سجّل الدخول إلى حسابك في إعراب أو أنشئ حساباً جديداً للوصول إلى ميزاتك عبر الويب والتطبيق.">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Nav lang="ar" />
  <main class="px-6 py-14 md:py-20">
    <h1 class="text-center font-arabic-display text-[clamp(1.8rem,4vw,2.6rem)] leading-tight mb-3">أهلاً بك في إعراب</h1>
    <p class="text-center text-ink/60 dark:text-mist/60 mb-10">حسابٌ واحد للويب والتطبيق.</p>
    <AuthForm lang="ar" />
  </main>
  <Footer lang="ar" />
</BaseLayout>
