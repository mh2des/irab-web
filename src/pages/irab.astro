---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import ArticleHero from '../components/ArticleHero.astro';
import ArticleSection from '../components/ArticleSection.astro';
import ArticleCta from '../components/ArticleCta.astro';
import ArticleFaq from '../components/ArticleFaq.astro';

const faqs = [
  { q: 'ما معنى كلمة "إعراب"؟', a: 'الإعراب لغةً: الإبانة والإيضاح. اصطلاحًا: نظام بيان الموقع النحوي للكلمة في الجملة من خلال الحركات والعلامات في آخرها. هو الذي يبيّن الفاعل من المفعول، والمضاف من المضاف إليه، ويميّز المعاني التي يفصلها العرب بهذه الحركات.' },
  { q: 'هل أحتاج إلى الإعراب لفهم القرآن؟', a: 'تستطيع تلاوة القرآن بدونه، لكنّك لن تفهمه فهمًا حقيقيًّا إلّا به. تغيّر الحركة الواحدة في القرآن قد يبدّل التفسير. والعلماء قديمًا وحديثًا يعتبرون الإعراب أساسًا غير قابل للتجاوز في طلب علم القرآن.' },
  { q: 'ما الفرق بين الإعراب والنحو؟', a: 'النحو هو علم القواعد كاملًا, قواعد بناء الجملة والعلاقات بين كلماتها. الإعراب هو نتيجة تطبيق هذا العلم: تحديد حالة كل كلمة ووظيفتها. النحو هو العلم، والإعراب هو الممارسة.' },
  { q: 'هل الإعراب مهم للفصحى الحديثة؟', a: 'نعم خصوصًا في الكتابة الرسمية والصحافة والكتب الأكاديمية وكلام أهل العلم والقرآن. اللهجات اليومية تُسقط أحيانًا الحركات الإعرابية، لكنّ القراءة الجادّة بدون إعراب فكّ رموزٍ لا قراءة.' },
  { q: 'كم يحتاج تعلّم الإعراب من الوقت؟', a: 'مع الممارسة اليومية ومنهج منظّم (كتب المدينة، البيّنة، الآجرومية)، يصل أكثر المتعلّمين إلى المستوى المتوسط في ٦-١٢ شهرًا. الإتقان, قدرة إعراب الآيات الصعبة فورًا, يحتاج ٢-٣ سنوات من الدراسة المستمرة.' },
  { q: 'هل أدوات الذكاء الاصطناعي مثل إعراب تغني عن المعلّم؟', a: 'لا. لكنّها تسرّع مرحلة التدريب تسريعًا كبيرًا. المعلّم يضع لك الإطار ويصحّح فهمك. أدوات الإعراب الذكي تعطيك تقييمًا فوريًّا على مئات الجمل يوميًّا, حجم تدريب يستحيل بلوغه مع المعلّم وحده.' },
];
---
<BaseLayout
  lang="ar"
  hasEn
  title="ما هو الإعراب؟ دليل شامل لتحليل الجملة العربية · إعراب"
  description="الإعراب هو نظام عربي لبيان الحالة النحوية لكلّ كلمة في الجملة. دليل شامل لمعنى الإعراب، الحالات الأربع، وأهميّته للقرآن، وكيف تبدأ تعلّمه اليوم."
>
  <Nav lang="ar" />

  <ArticleHero
    lang="ar"
    eyebrow="مرجع"
    title="ما هو الإعراب؟"
    summary="الإعراب هو النظام النحوي الذي يحدّد حالة كلّ كلمة ووظيفتها في الجملة العربية. حيث تستعمل الإنجليزية ترتيب الكلمات للدلالة على المعنى، تستعمل العربية الحركات الإعرابية. هذا الدليل يغطّي ما هو الإعراب، الحالات الأربع، أهميّته في علم القرآن، وكيف تبدأ تعلّمه اليوم."
  />

  <ArticleSection
    lang="ar"
    id="definition"
    title="الجواب المختصر"
    lead="الإعراب نظام يحدّد لكلّ كلمة في الجملة حالتها النحوية ووظيفتها. يبيّن إن كانت الكلمة فاعلًا أو مفعولًا أو مضافًا إليه، ويفسّر علاقتها بسائر الكلمات. بدون الإعراب تكون الجملة العربية غامضة؛ مع الإعراب يكون المعنى دقيقًا واضحًا."
  >
    <p>كلمة "إعراب" مشتقّة من الجذر <code class="ar">ع-ر-ب</code> بمعنى الإبانة والإيضاح. النحاة الذين أسّسوا هذا العلم في القرنين السابع والثامن الميلاديّين, سيبويه والخليل وأهل البصرة, اعتبروه فعلًا <em>إيضاحًا</em> لما تفعله كلّ كلمة.</p>

    <p>حيث تعتمد الإنجليزية على ترتيب الكلمات (the dog bit the man مختلف عن the man bit the dog)، تعتمد العربية على الحركات الإعرابية (<span class="ar">حركات الإعراب</span>). الحركات تنتقل مع الكلمة، فتستطيع تقديم وتأخير الجملة دون أن يضطرب المعنى.</p>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="four-cases"
    title="الحالات الأربع للإعراب"
    lead="للعربية أربع حالات إعرابية: المرفوع والمنصوب والمجرور والمجزوم (للأفعال فقط). تعلّم كلّ حالة بحركة معيّنة في آخر الكلمة. المرفوع بالضمّة، المنصوب بالفتحة، المجرور بالكسرة، المجزوم بالسكون، مع أنواع متفاوتة في المثنى والجمع وأشباه الجمع."
  >
    <p><strong>المرفوع</strong>, للمبتدأ والخبر والفاعل وأسماء أخرى. علامته الضمّة (ـُ) في الأصل.</p>
    <p><strong>المنصوب</strong>, للمفعول به والظرف واسم إنّ وأخواتها وغيرها. علامته الفتحة (ـَ).</p>
    <p><strong>المجرور</strong>, للاسم بعد حرف الجرّ وللمضاف إليه. علامته الكسرة (ـِ).</p>
    <p><strong>المجزوم</strong>, للأفعال فقط. بعد <span class="ar">لم</span> ولا الناهية والشرط. علامته السكون (ـْ).</p>
    <p>إضافة إلى ذلك، تكون الكلمة <strong>مبنيّة</strong> أحيانًا, لا تتغيّر حركتها مهما تغيّر موقعها. الحروف كـ<span class="ar">إنّ</span> وأسماء الإشارة كـ<span class="ar">هذا</span> مبنيّة.</p>
  </ArticleSection>

  <ArticleCta lang="ar">
    <span slot="title">شاهد الإعراب يعمل.</span>
    ألصق أيّ جملة عربية, حتى آية قرآنية, في التجربة المباشرة على الصفحة الرئيسية. سنعرب لك كلّ كلمة في الوقت الفعلي بنفس المحرّك في التطبيق.
  </ArticleCta>

  <ArticleSection
    lang="ar"
    id="why-quran"
    title="لِمَ الإعراب أساس فهم القرآن"
    lead="كلّ كلمة في القرآن مُعربة بدقّة وفق قواعد علم النحو. التغيّرات الإعرابية الدقيقة في الآيات تحمل دلالات تفسيرية كبيرة, تغيير حركة واحد قد يغيّر المعنى أو التركيب أو القراءة. لتفهم القرآن كما فهمه السلف، تحتاج إلى الإعراب."
  >
    <p>تأمّل قوله تعالى: <span class="ar">صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ</span>. <span class="ar">صِرَٰطَ</span> منصوبة بدلًا من <span class="ar">ٱلصِّرَٰطَ</span> السابقة. من لا يعرف الإعراب يقرؤها مبتدأ مرفوعًا. من يعرف الإعراب يدرك البدلية ويفهم البلاغة.</p>
    <p>هذا النمط يتكرّر في القرآن آلاف المرّات. الإضافة، الجار والمجرور، حروف المعاني، أساليب الشرط, كلّها تحتاج معرفة بالإعراب لتقرأها بفهم. <a href="/quran-parser">جرّب أداة إعراب القرآن المجانية</a>.</p>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="how-to-learn"
    title="كيف تبدأ تعلّم الإعراب اليوم"
    lead="ابدأ بمنهج منظّم كسلسلة كتب المدينة، أو مناهج البيّنة، أو الآجرومية. اقرنه بتدريب يومي على نصّ حقيقي, يفضّل آيات قرآنية قصيرة, مع أداة إعراب لتتحقّق من جوابك. اهدف إلى ٣٠ دقيقة يوميًّا، ستّة أيّام في الأسبوع. أكثر الطلاب يصلون إلى الفصاحة المتوسّطة في سنة."
  >
    <ol>
      <li><strong>أتقن الحروف والحركات أوّلًا.</strong> لن ترى الإعراب إن لم تستطع قراءته. الحركات ليست خيارًا في الدراسة الجادّة.</li>
      <li><strong>اختر منهجًا واحدًا وأكمله.</strong> كتب المدينة الأسهل. البيّنة منظّمة للناطقين بالإنجليزية. الآجرومية أسرع طريق كلاسيكي.</li>
      <li><strong>تدرّب يوميًّا على نصّ حقيقي.</strong> آية قصيرة كلّ يوم. حاول إعرابها بنفسك ثمّ تحقّق بأداة <a href="/">إعراب</a>.</li>
      <li><strong>احفظ وارسخ.</strong> المفردات القرآنية والقواعد الكبرى (تصاريف الفعل، إعراب الاسم) لا غنى عنها.</li>
      <li><strong>اطلب معلّمًا أو حلقة.</strong> منصّات: البيّنة TV، Studio Arabiya، أو مجلس مسجد محلّي.</li>
    </ol>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="common-mistakes"
    title="أخطاء شائعة عند المبتدئين"
    lead="أكبر خطأ هو محاولة حفظ جداول الإعراب بدلًا من تعلّم تطبيق القواعد. أخطاء أخرى: الخلط بين النحو والصرف، إهمال الحركات في التدريب، تجاهل الحروف، وتجنّب تدريب الإضافة. تجنّبها وستتعلّم أسرع من ٩٠٪ من الطلاب."
  >
    <ul>
      <li><strong>الحفظ بدل التطبيق.</strong> الإعراب نظام يُطبَّق لا قائمة تُحفظ. تدرّب على الجمل لا على الجداول.</li>
      <li><strong>الخلط بين النحو والصرف.</strong> النحو علم العلاقات بين الكلمات، الصرف علم بنية الكلمة. علمان متمايزان كلاهما لازم.</li>
      <li><strong>إسقاط الحركات.</strong> إن قرأت العربية بلا حركات وخمّنت، فأنت تفكّ رموزًا لا تُعرب. ابقَ على النصّ المضبوط حتى تشتدّ الحاسّة.</li>
      <li><strong>إهمال الحروف.</strong> الحروف كـ<span class="ar">إنّ، أنّ، كأنّ</span> تغيّر القواعد جذريًّا. تساوي ٣٠٪ من العمل.</li>
      <li><strong>تجنّب الإضافة.</strong> تركيبات المضاف والمضاف إليه تُسقط المبتدئين باستمرار. تدرّب عليها حتى تصير تلقائية.</li>
    </ul>
  </ArticleSection>

  <ArticleFaq lang="ar" items={faqs} />

  <Footer lang="ar" />
</BaseLayout>
