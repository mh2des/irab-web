---
/**
 * /practice: mode-first practice landing (Arabic).
 *
 * Indexed SEO surface for interactive i'rab practice. Firebase must stay out of
 * this static page; the signed-in tool lives at /practice/play.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Schema from '../components/Schema.astro';
import Nav from '../components/Nav.astro';
import ArticleFaq from '../components/ArticleFaq.astro';
import Footer from '../components/sections/Footer.astro';

const faqs = [
  { q: 'ما أوّل وضع أبدأ به؟', a: 'ابدأ بوضع «اكتب جملتك» إذا أردت اختبار جملة من اختيارك والحصول على تصحيح ذكي. اختر «الجمل الجاهزة» إذا أردت تدريبًا أسرع بخيارات محددة.' },
  { q: 'هل التدريب مجاني؟', a: 'نعم، يمكن البدء مجانًا بعد تسجيل الدخول. يفتح Irab Plus حصصًا أوسع ومزايا تدريب أكثر.' },
  { q: 'هل أحتاج إلى معرفة كل أبواب النحو؟', a: 'لا. وضع الجمل الجاهزة يساعدك على التدرب بخيارات واضحة، ووضع الجملة الخاصة يشرح لك الأخطاء كلمة بكلمة.' },
  { q: 'هل التصحيح فوري؟', a: 'نعم. بعد إرسال إجاباتك تحصل على نتيجة وتصحيح لكل كلمة مع توضيح الإجابة الصحيحة.' },
];

const learningResource = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  name: 'تمارين الإعراب التفاعلية مع تصحيح فوري: إعراب',
  url: 'https://irab.app/practice',
  inLanguage: 'ar',
  learningResourceType: ['Exercise', 'Quiz', 'Game'],
  teaches: ['الإعراب', 'النحو', 'الصرف'],
  educationalLevel: 'مبتدئ إلى متقدّم',
  isAccessibleForFree: true,
  description:
    'اختر بين كتابة جملتك أو التدريب على جمل جاهزة، ثم أعرِب الكلمات واحصل على تصحيح فوري.',
  provider: { '@type': 'Organization', name: 'Irab', url: 'https://irab.app' },
};
---
<BaseLayout
  lang="ar"
  hasEn
  title="تمارين الإعراب التفاعلية · إعراب"
  description="تدرّب على الإعراب بطريقتين: اكتب جملتك لتحصل على تصحيح ذكي، أو اختر من جمل جاهزة وأجب من خيارات واضحة."
>
  <Schema slot="head" />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(learningResource)} is:inline />

  <Nav lang="ar" />

  <main>
    <section class="px-6 pt-16 pb-12 md:pt-24 md:pb-16 text-center">
      <div class="max-w-3xl mx-auto">
        <p class="eyebrow justify-center mb-5">تدرّب على الإعراب</p>
        <h1 class="font-arabic font-bold text-[clamp(2.5rem,7vw,5rem)] leading-[1.05] tracking-tight text-ink dark:text-mist mb-6">
          أعرِبْ بنفسك، لا أن تقرأ الإعراب فقط.
        </h1>
        <p class="font-arabic text-body-lg text-ink/72 dark:text-mist/72 leading-loose max-w-2xl mx-auto mb-9">
          الميزة الأساسية هي أن تكتب إعرابك بنفسك ثم تحصل على تصحيح ذكي. وبعدها يمكنك استخدام الجمل الجاهزة لتدريب أسرع بخيارات منظّمة.
        </p>
        <a href="/practice/play" class="btn-primary btn-lg">ابدأ التدريب الآن</a>
      </div>
    </section>

    <section class="px-6 pb-14">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-4">
        <a href="/practice/play?mode=custom" class="practice-mode-card practice-mode-primary">
          <span class="practice-mode-pill">الميزة الذهبية</span>
          <h2 class="font-arabic font-bold text-3xl md:text-4xl leading-tight text-ink dark:text-mist">اكتب إعرابك وخذ تصحيحًا ذكيًّا</h2>
          <p class="font-arabic text-ink/68 dark:text-mist/70 leading-loose">أدخل أي جملة عربية، اكتب تحليلك لكل كلمة، ثم راجع أين أصبت وأين أخطأت مع شرح واضح.</p>
          <span class="practice-mode-cta">ابدأ بهذا الوضع <span aria-hidden="true">←</span></span>
        </a>
        <a href="/practice/play?mode=curated" class="practice-mode-card">
          <span class="practice-mode-pill">الخيار الثاني</span>
          <h2 class="font-arabic font-bold text-3xl md:text-4xl leading-tight text-ink dark:text-mist">جمل جاهزة بخيارات واضحة</h2>
          <p class="font-arabic text-ink/68 dark:text-mist/70 leading-loose">اختر من بنك الجمل وتدرّب بسرعة على النوع والموقع والعلامة، مناسب للمراجعة اليومية.</p>
          <span class="practice-mode-cta">افتح الجمل الجاهزة <span aria-hidden="true">←</span></span>
        </a>
      </div>
    </section>

    <section class="px-6 py-8 border-y border-ink/8 dark:border-mist/10 bg-white/70 dark:bg-ink-soft/55">
      <div class="max-w-6xl mx-auto grid gap-4 md:grid-cols-3">
        <div>
          <p class="text-label text-purple font-semibold mb-2">تسجيل الدخول</p>
          <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">يحفظ محاولاتك ويطبّق حصص التدريب اليومية.</p>
        </div>
        <div>
          <p class="text-label text-purple font-semibold mb-2">تصحيح كلمة بكلمة</p>
          <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">ترى إجابتك بجانب الصواب مباشرة، بلا تشتيت.</p>
        </div>
        <div>
          <p class="text-label text-purple font-semibold mb-2">تدريب قصير</p>
          <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">جلسة مركّزة تكفي لتثبيت قاعدة أو اختبار فهمك.</p>
        </div>
      </div>
    </section>

    <section class="px-6 py-14 md:py-20">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-[0.78fr_1.22fr] gap-10">
        <div>
          <p class="text-label uppercase tracking-[0.18em] text-purple font-semibold mb-4">كيف يعمل</p>
          <h2 class="font-arabic font-bold text-3xl md:text-5xl leading-tight text-ink dark:text-mist">التدريب مصمّم للحل، لا للقراءة فقط.</h2>
        </div>
        <div class="grid sm:grid-cols-3 gap-4">
          <div class="rounded-lg border border-ink/10 dark:border-mist/12 bg-white dark:bg-ink-soft p-5">
            <p class="text-3xl font-display text-purple mb-4">01</p>
            <h3 class="font-semibold text-ink dark:text-mist mb-2">اختر الوضع</h3>
            <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">اكتب جملتك أو افتح جملة جاهزة من البنك.</p>
          </div>
          <div class="rounded-lg border border-ink/10 dark:border-mist/12 bg-white dark:bg-ink-soft p-5">
            <p class="text-3xl font-display text-purple mb-4">02</p>
            <h3 class="font-semibold text-ink dark:text-mist mb-2">أجب بنفسك</h3>
            <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">حلّل الكلمات بدل الاكتفاء بمشاهدة الجواب.</p>
          </div>
          <div class="rounded-lg border border-ink/10 dark:border-mist/12 bg-white dark:bg-ink-soft p-5">
            <p class="text-3xl font-display text-purple mb-4">03</p>
            <h3 class="font-semibold text-ink dark:text-mist mb-2">راجع التصحيح</h3>
            <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">اعرف أين أصبت وأين تحتاج إلى مراجعة.</p>
          </div>
        </div>
      </div>
    </section>

    <ArticleFaq items={faqs} lang="ar" />
  </main>

  <Footer lang="ar" />
</BaseLayout>

<style>
  .practice-mode-card {
    display: flex;
    min-height: 19rem;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.35rem, 3vw, 2rem);
    border-radius: 1rem;
    text-decoration: none;
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    box-shadow: var(--shadow-card);
    transition: transform .2s var(--ease-out-quart), border-color .2s, box-shadow .2s;
  }
  .practice-mode-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--color-teal) 42%, var(--color-card-edge));
    box-shadow: var(--shadow-lift);
  }
  :global(.dark) .practice-mode-card {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .practice-mode-primary {
    border-color: color-mix(in srgb, var(--color-purple) 42%, var(--color-card-edge));
  }
  .practice-mode-pill {
    width: fit-content;
    padding: 0.28rem 0.75rem;
    border-radius: 999px;
    color: var(--color-purple-deep);
    background: color-mix(in srgb, var(--color-purple) 12%, white);
    font-size: var(--text-caption);
    font-weight: 900;
  }
  :global(.dark) .practice-mode-pill {
    color: color-mix(in srgb, var(--color-purple) 84%, white);
    background: color-mix(in srgb, var(--color-purple) 20%, var(--color-coal));
  }
  .practice-mode-cta {
    margin-top: auto;
    color: var(--color-purple-deep);
    font-weight: 900;
  }
  :global(.dark) .practice-mode-cta {
    color: color-mix(in srgb, var(--color-purple) 84%, white);
  }
</style>
