---
/**
 * /library: the classical grammar library (Arabic). Browse all 47 reference
 * works (nahw, sarf, balagha, i'rab) by category + search; each opens in a
 * client-side reader that streams the book's chapters from the same source the
 * app uses. Indexed for SEO (the long-tail "كتاب ... pdf/قراءة" intent).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import Container from '../components/Container.astro';
import { BOOKS, TOTAL_CHAPTERS, CATEGORIES, categoryCounts, categoryMeta } from '../lib/library';
import { toArabicDigits } from '../lib/quran';

const counts = categoryCounts();
const reader = (id: string) => `/library/read?b=${encodeURIComponent(id)}`;

const collection = {
  '@context': 'https://schema.org', '@type': 'CollectionPage',
  name: 'المكتبة النحوية: إعراب',
  description: 'مكتبة من ٤٧ كتابًا كلاسيكيًّا في النحو والصرف والبلاغة والإعراب، تُقرأ مجانًا على إعراب.',
  url: 'https://irab.app/library',
};

---
<BaseLayout
  lang="ar"
  hasEn
  title="المكتبة النحوية: ٤٧ كتابًا في النحو والصرف والبلاغة | إعراب"
  description="اقرأ ٤٧ كتابًا كلاسيكيًّا في النحو والصرف والبلاغة والإعراب مجانًا على إعراب: ابن هشام، ابن عقيل، الآجرومية، وغيرها: مفصّلة بابًا بابًا مع بحث وتصنيف."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(collection)} is:inline />
  <Nav lang="ar" />

  <main class="library-page">
    <section class="library-hero">
      <Container size="wide">
        <div class="library-hero-grid">
          <div class="library-copy">
            <p class="eyebrow mb-4" data-reveal>المكتبة</p>
            <h1 class="font-arabic-display library-title" data-reveal data-reveal-delay="80">
              مكتبة كتب العربية
            </h1>
            <p class="library-lead" data-reveal data-reveal-delay="160">
              مجموعة مختارة من كتب النحو والصرف والبلاغة والإعراب، مرتّبة بوضوح لتقرأ الكتاب كاملًا أو تصل إلى مرجعك بسرعة.
            </p>
          </div>

          <div class="library-panel" data-reveal data-reveal-delay="220">
            <div class="panel-head">
              <span>فهرس منظّم</span>
              <strong>{toArabicDigits(BOOKS.length)} كتاب</strong>
            </div>
            <div class="panel-list">
              {CATEGORIES.map((c) => (
                <div style={`--c:${c.color}`}>
                  <span>{c.key}</span>
                  <strong>{toArabicDigits(counts[c.key] ?? 0)} كتاب</strong>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="library-stats" data-reveal data-reveal-delay="280">
          <div>
            <strong>{toArabicDigits(BOOKS.length)}</strong>
            <span>كتاب كلاسيكي</span>
          </div>
          <div>
            <strong>{toArabicDigits(TOTAL_CHAPTERS)}</strong>
            <span>فصل قابل للقراءة</span>
          </div>
          <div>
            <strong>{toArabicDigits(CATEGORIES.length)}</strong>
            <span>فروع علمية</span>
          </div>
          <div>
            <strong>مجاني</strong>
            <span>يفتح مباشرة في المتصفّح</span>
          </div>
        </div>
      </Container>
    </section>

    <section class="library-browse">
      <Container size="wide">
        <div class="library-toolbar" data-lib-controls>
          <div class="search-wrap">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.3-4.3"/><circle cx="11" cy="11" r="7"/></svg>
            <input type="search" data-lib-search placeholder="ابحث عن كتاب أو مؤلّف..." dir="rtl" />
          </div>

          <div class="filter-row" data-lib-filters aria-label="تصنيف الكتب">
            <button type="button" class="lib-chip is-active" data-cat="all">
              <span>كل الكتب</span>
              <em>{toArabicDigits(BOOKS.length)}</em>
            </button>
            {CATEGORIES.map((c) => (
              <button type="button" class="lib-chip" data-cat={c.key} style={`--c:${c.color}`}>
                <span>{c.key}</span>
                <em>{toArabicDigits(counts[c.key] ?? 0)}</em>
              </button>
            ))}
          </div>
        </div>

        <div class="library-band" data-reveal>
          <div>
            <span>مصادر موثوقة</span>
            <p>كتب نحوية وبلاغية وصرفية من أمهات المراجع.</p>
          </div>
          <div>
            <span>قراءة مرتّبة</span>
            <p>كل كتاب مفصول إلى أبواب وفصول داخل القارئ.</p>
          </div>
          <div>
            <span>وصول سريع</span>
            <p>بحث وتصنيف واضح بدل قائمة طويلة مربكة.</p>
          </div>
        </div>

        <div class="library-grid" data-lib-grid>
          {BOOKS.map((b) => {
            const m = categoryMeta(b.category);
            const author = b.author && b.author !== 'غير معروف' ? b.author : 'مرجع عربي كلاسيكي';
            return (
              <a href={reader(b.id)} class="book-card"
                 data-book data-cat={b.category}
                 data-title={b.title} data-author={b.author} data-level={b.level}
                 style={`--c:${m.color};`}>
                <span class="book-cover">
                  <span class="book-cover-cat">{b.category}</span>
                  <h3 class="book-cover-title" lang="ar" dir="rtl">{b.title}</h3>
                  <span class="book-cover-author" lang="ar" dir="rtl">{author}</span>
                </span>
                <span class="book-line">
                  <span class="book-line-meta">{b.level} · {toArabicDigits(b.totalChapters)} فصل</span>
                  <span class="book-line-cta">اقرأ <span aria-hidden="true">←</span></span>
                </span>
              </a>
            );
          })}
        </div>

        <p data-lib-empty class="hidden library-empty">لا توجد كتب مطابقة.</p>
      </Container>
    </section>
  </main>

  <Footer lang="ar" />
</BaseLayout>

<style>
  .library-page { overflow: clip; }
  .library-hero {
    position: relative;
    padding: clamp(3.5rem, 8vw, 6.5rem) 0 2rem;
    border-bottom: 1px solid var(--color-stone);
    background: color-mix(in srgb, var(--color-paper) 78%, white);
  }
  :global(.dark) .library-hero {
    background: color-mix(in srgb, var(--color-coal) 82%, var(--color-coal-soft));
    border-bottom-color: var(--color-coal-edge);
  }
  .library-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(21rem, 0.8fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .library-copy { max-width: 44rem; }
  .library-title {
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 1.04;
    color: var(--color-ink);
    letter-spacing: 0;
  }
  :global(.dark) .library-title { color: var(--color-mist); }
  .library-lead {
    max-width: 42rem;
    margin-top: 1.4rem;
    font-size: clamp(1.35rem, 2.2vw, 1.85rem);
    line-height: 1.9;
    color: color-mix(in srgb, var(--color-ink) 72%, transparent);
  }
  :global(.dark) .library-lead { color: color-mix(in srgb, var(--color-mist) 72%, transparent); }

  .library-panel {
    padding: clamp(1.2rem, 3vw, 1.7rem);
    border: 1px solid var(--color-card-edge);
    background: var(--color-card);
    border-radius: 1rem;
    box-shadow: var(--shadow-lift);
  }
  :global(.dark) .library-panel {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-stone);
  }
  :global(.dark) .panel-head { border-bottom-color: var(--color-coal-edge); }
  .panel-head span,
  .panel-list span {
    color: color-mix(in srgb, var(--color-ink) 58%, transparent);
    font-size: var(--text-caption);
    font-weight: 800;
  }
  :global(.dark) .panel-head span,
  :global(.dark) .panel-list span {
    color: color-mix(in srgb, var(--color-mist) 62%, transparent);
  }
  .panel-head strong {
    font-family: var(--font-arabic);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    color: var(--color-ink);
  }
  :global(.dark) .panel-head strong { color: var(--color-mist); }
  .panel-list {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .panel-list div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 0.95rem;
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--c) 8%, var(--color-paper));
    border: 1px solid color-mix(in srgb, var(--c) 18%, transparent);
  }
  :global(.dark) .panel-list div {
    background: color-mix(in srgb, var(--c) 13%, var(--color-coal-soft));
    border-color: color-mix(in srgb, var(--c) 24%, transparent);
  }
  .panel-list strong {
    color: var(--color-ink);
    font-family: var(--font-arabic);
    font-size: 1.05rem;
  }
  :global(.dark) .panel-list strong {
    color: var(--color-mist);
  }

  .library-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .library-stats div {
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    border-radius: 0.75rem;
    padding: 1.05rem 1.2rem;
  }
  :global(.dark) .library-stats div {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .library-stats strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2.1rem;
    line-height: 1;
    color: var(--color-purple);
  }
  .library-stats span {
    display: block;
    margin-top: 0.45rem;
    font-size: var(--text-caption);
    color: color-mix(in srgb, var(--color-ink) 62%, transparent);
  }
  :global(.dark) .library-stats span { color: color-mix(in srgb, var(--color-mist) 68%, transparent); }

  .library-browse {
    padding: 2rem 0 5rem;
    background: color-mix(in srgb, var(--color-paper) 94%, white);
  }
  :global(.dark) .library-browse {
    background: var(--color-coal);
  }
  .library-toolbar {
    display: grid;
    grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .search-wrap {
    min-height: 4rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0 1.1rem;
    border-radius: 0.9rem;
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    box-shadow: var(--shadow-card);
  }
  :global(.dark) .search-wrap {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .search-wrap svg {
    width: 1.25rem;
    height: 1.25rem;
    flex: none;
    stroke: color-mix(in srgb, var(--color-ink) 55%, transparent);
    stroke-width: 2;
    fill: none;
  }
  :global(.dark) .search-wrap svg { stroke: color-mix(in srgb, var(--color-mist) 60%, transparent); }
  .search-wrap input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--color-ink);
    font-size: var(--text-small);
  }
  :global(.dark) .search-wrap input { color: var(--color-mist); }
  .search-wrap input::placeholder { color: color-mix(in srgb, var(--color-ink) 42%, transparent); }
  :global(.dark) .search-wrap input::placeholder { color: color-mix(in srgb, var(--color-mist) 42%, transparent); }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.55rem;
  }
  .lib-chip {
    min-height: 3.4rem;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 1rem;
    border-radius: 0.8rem;
    color: var(--color-ink);
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    box-shadow: var(--shadow-soft);
    transition: transform .18s, border-color .18s, background-color .18s, color .18s;
  }
  :global(.dark) .lib-chip {
    color: var(--color-mist);
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .lib-chip:hover { transform: translateY(-2px); border-color: var(--c, var(--color-purple)); }
  .lib-chip.is-active {
    color: #fff;
    background: var(--c, var(--color-purple));
    border-color: var(--c, var(--color-purple));
  }
  .lib-chip span { font-size: var(--text-caption); font-weight: 800; }
  .lib-chip em {
    min-width: 1.7rem;
    height: 1.7rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    background: color-mix(in srgb, currentColor 10%, transparent);
  }

  .library-band {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border-radius: 0.9rem;
    border: 1px solid var(--color-card-edge);
    background: var(--color-card-edge);
    margin: 1.25rem 0 1.6rem;
  }
  :global(.dark) .library-band {
    border-color: var(--color-coal-edge);
    background: var(--color-coal-edge);
  }
  .library-band div {
    background: color-mix(in srgb, var(--color-card) 86%, var(--color-paper));
    padding: 1.1rem 1.2rem;
  }
  :global(.dark) .library-band div { background: var(--color-coal-soft); }
  .library-band span {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--color-purple);
    font-weight: 900;
    font-size: var(--text-caption);
  }
  .library-band p {
    color: color-mix(in srgb, var(--color-ink) 62%, transparent);
    font-size: var(--text-caption);
    line-height: 1.55;
  }
  :global(.dark) .library-band p { color: color-mix(in srgb, var(--color-mist) 66%, transparent); }

  .library-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.6rem);
    animation: lib-grid-in .42s var(--ease-out-quart) both;
  }
  @keyframes lib-grid-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

  .book-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    text-decoration: none;
    border-radius: 0.6rem;
  }
  .book-card:focus-visible { outline: 2px solid var(--c); outline-offset: 4px; }

  /* The cover IS the object — a generated spine/cover per book, no card chrome
     around it. This is what kills the "noisy text rows stacking" feel. */
  .book-cover {
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    aspect-ratio: 3 / 4;
    padding: 1rem 0.95rem;
    border-radius: 0.45rem 0.85rem 0.85rem 0.45rem;
    overflow: hidden;
    color: #fff;
    background:
      radial-gradient(115% 75% at 78% 4%, color-mix(in srgb, #fff 24%, transparent) 0%, transparent 46%),
      linear-gradient(152deg, color-mix(in srgb, var(--c) 96%, #fff) 0%, color-mix(in srgb, var(--c) 56%, #000) 100%);
    box-shadow: var(--shadow-card);
    transition: transform .22s var(--ease-out-quart), box-shadow .22s;
  }
  /* Spine: a darker band hugging the binding (right edge in RTL). */
  .book-cover::before {
    content: "";
    position: absolute;
    inset-block: 0;
    inset-inline-end: 0;
    width: 0.85rem;
    background: linear-gradient(to right, rgba(0,0,0,0) 0%, rgba(0,0,0,0.34) 100%);
    box-shadow: inset 1px 0 0 rgba(255,255,255,0.16);
    z-index: 2;
  }
  /* Faint weave so the flat colour reads as cloth, not a swatch. */
  .book-cover::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.4;
    background: repeating-linear-gradient(135deg, rgba(255,255,255,0.06) 0 1px, transparent 1px 7px);
    z-index: 1;
  }
  .book-card:hover .book-cover { transform: translateY(-6px); box-shadow: var(--shadow-lift); }

  .book-cover-cat {
    position: relative; z-index: 3;
    align-self: flex-start;
    padding: 0.18rem 0.6rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    color: #fff;
    background: rgba(255,255,255,0.2);
  }
  .book-cover-title {
    position: relative; z-index: 3;
    margin: 0.85rem 0 0;
    padding-inline-end: 0.35rem;
    font-family: var(--font-arabic-display);
    font-weight: 700;
    font-size: clamp(1.15rem, 1rem + 0.7vw, 1.55rem);
    line-height: 1.4;
    text-wrap: balance;
    text-shadow: 0 1px 12px rgba(0,0,0,0.22);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
  }
  .book-cover-author {
    position: relative; z-index: 3;
    margin-top: auto;
    padding-top: 0.7rem;
    font-size: 0.8rem;
    line-height: 1.4;
    color: rgba(255,255,255,0.82);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .book-line {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding-inline: 0.15rem;
  }
  .book-line-meta {
    color: color-mix(in srgb, var(--color-ink) 56%, transparent);
    font-size: var(--text-caption);
  }
  :global(.dark) .book-line-meta { color: color-mix(in srgb, var(--color-mist) 58%, transparent); }
  .book-line-cta {
    color: var(--c);
    font-weight: 800;
    font-size: var(--text-caption);
    white-space: nowrap;
  }
  .book-line-cta span { display: inline-block; transition: transform .18s; }
  .book-card:hover .book-line-cta span { transform: translateX(-3px); }
  .library-empty {
    padding: 4rem 1rem;
    text-align: center;
    color: color-mix(in srgb, var(--color-ink) 62%, transparent);
    font-size: var(--text-body);
  }
  :global(.dark) .library-empty { color: color-mix(in srgb, var(--color-mist) 66%, transparent); }

  @media (max-width: 1080px) {
    .library-hero-grid,
    .library-toolbar { grid-template-columns: 1fr; }
    .filter-row { justify-content: flex-start; }
    .library-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 720px) {
    .library-hero { padding-top: 2.5rem; }
    .library-stats,
    .library-band { grid-template-columns: 1fr; }
    .library-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .library-toolbar { gap: 0.75rem; }
  }
</style>

<script>
  const root = document;
  const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-book]'));
  const chips = Array.from(root.querySelectorAll<HTMLButtonElement>('.lib-chip'));
  const search = root.querySelector<HTMLInputElement>('[data-lib-search]');
  const empty = root.querySelector<HTMLElement>('[data-lib-empty]');
  let activeCat = 'all';

  const norm = (s: string) => (s || '')
    .replace(/[ً-ْٰـ]/g, '')
    .replace(/[إأآ]/g, 'ا').replace(/ى/g, 'ي').replace(/ة/g, 'ه')
    .toLowerCase().trim();

  function apply() {
    const qv = norm(search?.value || '');
    let shown = 0;
    cards.forEach((c) => {
      const okCat = activeCat === 'all' || c.dataset.cat === activeCat;
      const hay = norm((c.dataset.title || '') + ' ' + (c.dataset.author || '') + ' ' + (c.dataset.level || ''));
      const okSearch = !qv || hay.includes(qv);
      const show = okCat && okSearch;
      c.style.display = show ? '' : 'none';
      if (show) shown++;
    });
    if (empty) empty.classList.toggle('hidden', shown > 0);
  }

  chips.forEach((chip) => chip.addEventListener('click', () => {
    activeCat = chip.dataset.cat || 'all';
    chips.forEach((c) => c.classList.toggle('is-active', c === chip));
    apply();
  }));
  search?.addEventListener('input', apply);
</script>
