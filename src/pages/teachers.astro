---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import ArticleHero from '../components/ArticleHero.astro';
import ArticleSection from '../components/ArticleSection.astro';
import ArticleFaq from '../components/ArticleFaq.astro';
import Container from '../components/Container.astro';

const faqs = [
  { q: 'كيف تعمل حسابات المؤسّسات المجانية؟', a: 'نقدّم للمدارس الشرعية وأكاديميات القرآن الإلكترونية حسابات Plus مجانية لمعلّميها مقابل رابط من صفحة المراجع أو المنهج لديكم. راسلنا على hello@irab.app باسم المؤسّسة وعدد الطلاب.' },
  { q: 'هل أستطيع تتبّع تقدّم طلابي؟', a: 'لا. لا يحتوي إعراب على لوحة معلّم أو قوائم طلاب أو تتبّع صفّي للتقدّم. يستطيع الطلاب فقط مشاركة نتائج الإعراب وشهادات الإتقان معك مباشرة.' },
  { q: 'هل الذكاء الاصطناعي دقيق بما يكفي لتصحيح أعمال الطلاب؟', a: 'استعمله تمريرة أولى سريعة لا حكمًا نهائيًا آليًا. لمعظم جمل المستوى الطلابي يعطي بنية مفيدة بسرعة، أمّا الحالات الغامضة أو التراكيب الكلاسيكية المتقدّمة فتحتاج حكمك أنت.' },
  { q: 'هل لديكم أسعار مؤسّساتية لتراخيص الطلاب؟', a: 'نسعد بمناقشة ترتيبات جماعية للمدارس والمدارس الشرعية والأكاديميات. راسلنا hello@irab.app بعدد طلابك ونتّفق معًا على سعر عادل. لا نملك حاليًّا تعرفة مؤسّساتية ثابتة، كلّ ترتيب يُتّفق عليه على حدة.' },
  { q: 'هل سيستبدلني إعراب كمعلّم؟', a: 'لا، وليس هذا الهدف. إعراب مضاعِف للتدريب، يعطي الطلاب تكرارًا وتغذية راجعة ومراجع أكثر خارج الصف. الإطار التربوي والتحفيز والتصحيح الذي يقدّمه المعلّم الحقيقي يبقى بلا بديل.' },
  { q: 'هل أستطيع دمج إعراب مع منهجي الحالي؟', a: 'نعم. المعلّمون الذين يستعملون كتب المدينة، البيّنة، الآجرومية، قطر الندى، وألفية ابن مالك يسندون إعراب كتدريب تكميلي. مكتبة التطبيق المرجعية قابلة للبحث بالموضوع، فيستطيع الطلاب البحث عن قواعد محدّدة من أي دورة.' },
];
---
<BaseLayout
  lang="ar"
  hasEn
  title="إعراب للمعلّمين · افحص الإعراب في ثوانٍ · حسابات مؤسّسات مجانية"
  description="إعراب أداة قواعد عربية بالذكاء الاصطناعي يستعملها المعلّمون لمراجعة واجبات الإعراب، اختبار تحليل الجمل، وإعطاء الطلاب تدريبًا إضافيًا. حسابات مؤسّسة مجانية للمدارس الشرعية والأكاديميات."
>
  <Nav lang="ar" />

  <ArticleHero
    lang="ar"
    eyebrow="للمؤسّسات"
    title="إعراب للمعلّمين."
    summary="معلّمو المدارس الشرعية والمدرّسون في الأكاديميات الإلكترونية يستعملون إعراب لمراجعة محاولات الطلاب في الإعراب، اختبار تحليل الجمل قبل الصف، وإعطاء الطلاب تدريبًا إضافيًا. المؤسّسات المؤهّلة تحصل على حسابات معلّمين مجانية مقابل رابط من صفحة المراجع."
  />

  <ArticleSection
    lang="ar"
    id="what-it-does"
    title="ما الذي يستعمله المعلّمون فعلًا"
    lead="ثلاثة أشياء أساسًا: مراجعة الواجبات أسرع، اختبار الإعراب قبل الصف، وإعطاء الطلاب أداة تدريب ذاتية خارج الحصة. لا يحتوي إعراب على لوحة معلّم؛ مشاركة النتائج والشهادات تبقى من جهة الطالب."
  >
    <ul>
      <li><strong>افحص في ثوانٍ.</strong> ألصق الجملة العربية. قارن تحليل إعراب مع نموذج إجابتك أو عمل الطالب المرسل إليك.</li>
      <li><strong>اختبار الإعراب.</strong> قبل تدريس جملة أو آية، أدخلها إلى إعراب وقارن التحليل بتحليلك.</li>
      <li><strong>تدريب طلابي ذاتي.</strong> ٥٧٦ جملة مُقيَّمة في التطبيق. الطلاب يتدرّبون على أوقاتهم. وقت الحصّة للمواد الأصعب.</li>
      <li><strong>شهادات إتقان.</strong> طلاب الخطة السنوية المؤهّلون يستطيعون كسب شهادات قابلة للمشاركة بعد إكمال مستوى بدقّة قوية في كل موضوع.</li>
      <li><strong>المكتبة المرجعية.</strong> ٤٧ كتابًا كلاسيكيًّا في النحو والصرف والبلاغة والإعراب، قابلة للبحث، مع وضع قراءة ومفضلة.</li>
    </ul>
  </ArticleSection>

  <Container size="narrow">
    <div class="my-16 bg-teal text-white rounded-2xl p-8 md:p-10">
      <p class="font-mono text-caption opacity-70 uppercase tracking-widest mb-4">برنامج المؤسّسات المجاني</p>
      <h3 class="font-arabic font-bold text-h2 leading-tight mb-4">حسابات Plus مجانية للمؤسّسات المؤهّلة.</h3>
      <p class="font-arabic text-body-lg opacity-90 max-w-2xl mb-6 leading-loose">
        نقدّم للمدارس الشرعية والمدارس الإسلامية وأكاديميات القرآن الإلكترونية حسابات معلّمين مجانية. مقابل: رابط لإعراب من صفحة المراجع أو المنهج أو قائمة الأدوات الموصى بها لديكم.
      </p>
      <p class="font-arabic text-body opacity-80 mb-6">
        تقدّم بالطلب على <a href="mailto:hello@irab.app" class="underline underline-offset-4 hover:no-underline">hello@irab.app</a> باسم المؤسّسة، الموقع، وعدد الطلاب التقريبي.
      </p>
      <a href="mailto:hello@irab.app?subject=طلب%20حساب%20مؤسّسة%20مجاني"
         class="inline-flex items-center gap-2 px-6 py-3 bg-white hover:bg-paper text-teal font-arabic font-medium tracking-tight rounded-full transition-colors duration-200">
        راسلنا للتقديم
        <svg class="w-4 h-4 rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </Container>

  <ArticleSection
    lang="ar"
    id="curriculum-fit"
    title="يندمج مع أيّ منهج تدرّسه"
    lead="المعلّمون المستعملون كتب المدينة، البيّنة، الآجرومية، قطر الندى، وألفية ابن مالك جميعًا يستعملون إعراب كتدريب تكميلي. مكتبة التطبيق المرجعية منظّمة بالموضوع، فيستطيع الطلاب البحث عن قواعد محدّدة من أي منهج. إعراب لا يستبدل منهجك, بل يسرّع مرحلة التدريب فيه."
  >
    <p>اقترانات شائعة يذكرها المعلّمون:</p>
    <ul>
      <li><strong>كتب المدينة الجزء الأوّل ← مستويات التدريب الأولى.</strong> المبتدئون يتدرّبون على جمل بسيطة مع تعلّم المفردات وأدوار الحالة الأساسية.</li>
      <li><strong>المدينة ٢ إلى ٣ ← الوضع التدريبي.</strong> الطلاب المتوسّطون يحصلون على تقييم ذكي لجمل أكثر تعقيدًا.</li>
      <li><strong>الآجرومية ← تحليل الآيات الملصقة.</strong> طلاب الكلاسيكية يطبّقون القواعد على أمثلة قرآنية ويقارنون جوابهم بنتيجة إعراب منظمة.</li>
      <li><strong>البيّنة ← المكتبة المرجعية.</strong> الطلاب يبحثون عن القواعد بين الجلسات.</li>
    </ul>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="institutional-pricing"
    title="الأسعار للمؤسّسات"
    lead="السعر القياسي لـ Irab Plus هو ٤٫٩٩$ شهريًّا أو ٣٥٫٩٩$ سنويًّا لكلّ مستخدم، مع تجربة مجانية ٧ أيّام على الخطّة السنوية. للمدارس والمدارس الشرعية والأكاديميات التي تريد حسابات Plus جماعية لطلابها، نضع سعرًا مخصّصًا حسب كلّ حالة. راسلنا بالأرقام نرسل لك عرضًا عادلًا."
  >
    <p>السعر القياسي: <strong>٤٫٩٩$ شهريًّا أو ٣٥٫٩٩$ سنويًّا</strong> لكلّ مستخدم. تجربة مجانية ٧ أيّام على السنوي.</p>
    <p>المؤسّسات: <strong>سعر مخصّص</strong>. لا نملك نظام شرائح ثابت، نتفاوض حسب عدد الطلاب ومدّة الاشتراك وميزانية مؤسّستك.</p>
    <p>للحصول على عرض، راسل <a href="mailto:hello@irab.app">hello@irab.app</a> بعدد الطلاب والدولة.</p>
  </ArticleSection>

  <ArticleFaq lang="ar" items={faqs} />

  <Footer lang="ar" />
</BaseLayout>
