---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import ArticleHero from '../components/ArticleHero.astro';
import ArticleSection from '../components/ArticleSection.astro';
import ArticleCta from '../components/ArticleCta.astro';
---
<BaseLayout
  lang="ar"
  title="منهجيتنا: كيف نبني المحتوى ونتحقّق منه · إعراب"
  description="كيف يعمل محرّك الإعراب الذكي، وما مصدر إعراب القرآن في الموقع، وكيف نتحقّق من صحّة النصوص القرآنية حرفًا حرفًا قبل النشر."
>
  <Nav lang="ar" />

  <ArticleHero
    lang="ar"
    eyebrow="الشفافية"
    title="منهجيتنا"
    summary="نؤمن أنّ أدوات تعلّم العربية يجب أن تكون شفّافة في مصادرها ودقيقة في نصوصها. هذه الصفحة تشرح كيف يعمل محرّك التحليل في إعراب، وما مصدر مرجع إعراب القرآن، وكيف نتحقّق من كلّ آية قبل أن تظهر أمامك."
  />

  <ArticleSection
    lang="ar"
    id="engine"
    title="محرّك الإعراب الذكي"
    lead="جوهر إعراب هو محرّك تحليل يعمل بالذكاء الاصطناعي: تكتب أيّ جملة عربية فيعربها لك كلمةً كلمة في ثوانٍ، ويعطيك تقييمًا فوريًّا عندما تتدرّب على الإعراب بنفسك."
  >
    <p>المحرّك مبنيّ على نماذج لغوية حديثة وُجّهت خصّيصًا لقواعد النحو العربي، وتُراجع مخرجاته باستمرار على جملٍ معيارية من كتب النحو المعتمدة. وعندما تجيب عن تمارين الإعراب في التطبيق، يقارن المحرّك إجابتك بالتحليل الصحيح ويشرح لك موضع الخطأ تحديدًا, لا مجرّد "صحيح / خطأ".</p>
    <p>التحليل الآلي اجتهاد تقنيّ قابل للخطأ، ولهذا نوفّر داخل التطبيق زرّ إبلاغ عن أيّ تحليل تراه غير دقيق، وتُراجع البلاغات يدويًّا.</p>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="quran-source"
    title="مصدر إعراب القرآن"
    lead="صفحات إعراب القرآن في هذا الموقع وفي التطبيق تستند إلى مرجع واحد معتمد: الجدول في إعراب القرآن وصرفه وبيانه للشيخ محمود صافي رحمه الله (دار الرشيد، دمشق)، وهو من أوسع مراجع إعراب القرآن المطبوعة, خمسة عشر مجلّدًا."
  >
    <p>اخترنا مصدرًا واحدًا موثوقًا بدل التلفيق من مصادر متعدّدة، حتى يكون التحليل متّسق المنهج من أوّل المصحف إلى آخره، ويُنسب الفضل لأهله. كلّ صفحة آية في الموقع تذكر المصدر صراحة.</p>
    <p>ما تقرؤه من ملخّصات تمهيدية (TL;DR) وأسئلة شائعة في صفحات الآيات فهو ممّا حرّرناه نحن خصّيصًا للموقع، وليس منقولًا من الجدول.</p>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="verification"
    title="التحقّق من النص القرآني"
    lead="لا يُنشر نصّ قرآني في إعراب قبل مطابقته آليًّا، حرفًا حرفًا، مع النصّ القياسي المعتمد من مشروع تنزيل (Tanzil) برواية حفص عن عاصم."
  >
    <p>بنينا خطّ معالجة كاملًا يستخرج المرجع، ويوحّد الرسم الإملائي، ثم يطابق كلّ آية من الآيات الـ٦٢٣٦ مع النصّ العثماني القياسي. أيّ اختلاف, ولو في حرف أو حركة, يوقف النشر حتى يُصحَّح. تغطية التحليل على مستوى الكلمة المفردة تتجاوز ٩٩٪ من آيات المصحف (أكثر من ١٠٠ ألف كلمة محلَّلة).</p>
    <p>هذا التحقّق غير قابل للتفاوض عندنا: تطبيق يخدم القرآن لا يجوز أن يعرض آية فيها خطأ.</p>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="who"
    title="من يقف خلف إعراب"
    lead="إعراب مشروع مستقلّ يبنيه مهندس برمجيات مسلم، بدأ من حاجة شخصية: أداة تجعل التمكّن من الإعراب ممكنًا لكلّ دارس، لا حكرًا على من وجد المعلّم والوقت."
  >
    <p>التطبيق متوفّر على متجري Google Play وApp Store، ويستخدمه آلاف الدارسين. نرحّب بكلّ تصحيح أو اقتراح على <a href="mailto:hello@irab.app">hello@irab.app</a>, وإذا كنت من أهل العلم ووجدت في المحتوى ما يحتاج مراجعة، فمراسلتك لنا صدقة نشكرك عليها.</p>
  </ArticleSection>

  <ArticleCta lang="ar">
    <span slot="title">جرّب المحرّك بنفسك.</span>
    ألصق أيّ جملة عربية في التجربة المباشرة على الصفحة الرئيسية، أو حمّل التطبيق وتدرّب على الإعراب بتقييم فوري.
  </ArticleCta>

  <Footer lang="ar" />
</BaseLayout>
