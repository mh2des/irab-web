---
/**
 * /practice/play: the interactive practice tool (Arabic). Type a sentence,
 * do the i'rab yourself, get AI-graded word-by-word feedback. Login-gated,
 * noindex (the indexed SEO surface is /practice). Firebase loads only here.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import PracticePlay from '../../components/PracticePlay.astro';
---
<BaseLayout lang="ar" title="تدرّب على الإعراب · إعراب" description="أَعرِبْ بنفسك واحصل على تصحيحٍ فوري وشرحٍ لكلّ كلمة بالذكاء الاصطناعي.">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Nav lang="ar" />
  <main class="px-4 sm:px-6 py-8 md:py-12">
    <PracticePlay lang="ar" />
  </main>
  <Footer lang="ar" />
</BaseLayout>
