---
/**
 * /tool: the free AI i'rab analyzer landing page (Arabic).
 *
 * The hero conversion + SEO surface for tool-intent queries
 * (أداة إعراب / محلل إعراب / إعراب تلقائي / إعراب الجمل). Embeds the same live
 * analyzer as the homepage demo, answer-first, with WebApplication + FAQPage
 * structured data. This is the page that contests the AI-i'rab-tool space.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Schema from '../components/Schema.astro';
import Nav from '../components/Nav.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';
import ArticleHero from '../components/ArticleHero.astro';
import LiveDemo from '../components/sections/LiveDemo.astro';
import ArticleFaq from '../components/ArticleFaq.astro';
import Footer from '../components/sections/Footer.astro';

const faqs = [
  { q: 'ما هي أداة إعراب الجمل؟', a: 'أداة مجانية على إعراب تأخذ أيّ جملة عربية وتعطيك إعرابها كلمة بكلمة بالذكاء الاصطناعي: نوع كل كلمة، وظيفتها النحوية، إعرابها، علامتها، تشكيلها الكامل، وشرحًا واضحًا للجملة. ألصق الجملة في الأعلى واضغط «أعرب».' },
  { q: 'هل الأداة مجانية؟', a: 'نعم. لك تحليلان مجانيّان فورًا دون تسجيل، وبتسجيل الدخول تحصل على ٣ تحليلات يوميًّا: وكلها بالإعراب الكامل نفسه. ولإعرابٍ غير محدود، وبنك التدريب الكامل، وتقييم إعرابك أنت، اشترك في Irab Plus على الويب أو حمّل تطبيق إعراب على iOS وAndroid.' },
  { q: 'هل تُعرِب أيّ جملة أم النص القرآني فقط؟', a: 'تُعرِب أيّ نصّ عربي فصيح تلصقه: جملة عادية أو بيت شعر أو آية قرآنية. الأداة عامّة للعربية الكلاسيكية، وإعراب القرآن متوفّر أيضًا كمكتبة مرجعية على الموقع.' },
  { q: 'ما مدى دقّة الإعراب الآلي؟', a: 'المحرّك مصمّم خصّيصًا لقواعد النحو العربي ويعطي تحليلًا مفصّلًا دقيقًا في غالب المواضع، لكنّ الذكاء الاصطناعي قد يخطئ في المواضع المحتملة. اعتبره مساعد دراسة سريعًا للتحقّق من إعرابك، لا بديلًا عن معلّم مؤهّل في المواضع الدقيقة.' },
  { q: 'هل أحتاج إلى حساب أو تسجيل؟', a: 'لا. جرّب الأداة مباشرة على هذه الصفحة دون تسجيل. لمزيد من التحليلات والتدريب بتقييم فوري، حمّل تطبيق إعراب المجاني.' },
];

const webApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'محلّل الإعراب بالذكاء الاصطناعي: إعراب',
  alternateName: ['أداة إعراب', "Irab i'rab analyzer"],
  url: 'https://irab.app/tool',
  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web',
  inLanguage: ['ar', 'en'],
  description:
    'أداة مجانية لإعراب الجمل العربية بالذكاء الاصطناعي كلمة بكلمة: النوع، الوظيفة، الإعراب، العلامة، والتشكيل الكامل.',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'Irab', url: 'https://irab.app' },
};

const whys = [
  { t: 'إعرابٌ كامل، لا مجرّد وسم', b: 'النوع، الوظيفة، الإعراب، العلامة وسببها، والتشكيل الكامل: مع التقدير والعلل والوجوه الإعرابية حين تتعدّد.' },
  { t: 'بدقّة العالِم وفوريّة الآلة', b: 'محرّكٌ مصمَّم خصّيصًا لقواعد النحو العربي على المذهب الراجح، يُعرِب جملك الخاصة إعرابًا مفصّلًا في ثوانٍ.' },
  { t: 'مدعومٌ بمرجع موثوق', b: 'إعراب القرآن على الموقع مبنيّ على مرجع منشور معتمد ومُتحقَّقٍ منه حرفًا حرفًا: لا تخمين.' },
  { t: 'جزء من تطبيق متكامل', b: 'بعد التحليل، تدرّب وأَعرِبْ بنفسك بتقييمٍ فوري، وتحدَّ نفسك واصعد المستويات: على iOS وAndroid.' },
];
---
<BaseLayout
  lang="ar"
  hasEn
  title="أداة إعراب الجمل بالذكاء الاصطناعي: مجاناً · إعراب"
  description="محلّل إعراب مجاني: ألصق أيّ جملة عربية واحصل على إعرابها كلمة بكلمة فورًا: النوع، الوظيفة، الإعراب، العلامة وسببها، والتشكيل الكامل، مع شرحٍ لبنية الجملة."
>
  <Schema slot="head" />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webApp)} is:inline />

  <Nav lang="ar" />

  <ArticleHero
    lang="ar"
    title="محلّل الإعراب بالذكاء الاصطناعي"
    summary="أعرِب أيّ جملة عربية إعرابًا كاملًا كلمة بكلمة: النوع، الوظيفة، الإعراب، العلامة وسببها، والتشكيل الكامل، مع شرحٍ لبنية الجملة: بدقّة العالِم وفوريّة الآلة."
  />

  {/* The live analyzer (its own header is suppressed: the hero above is the page header) */}
  <LiveDemo lang="ar" showHeader={false} />

  {/* Why this analyzer (positions vs weaker tools without naming them) */}
  <Section>
    <Container>
      <div class="max-w-2xl mb-12">
        <p class="eyebrow mb-4">لماذا إعراب</p>
        <h2 class="font-arabic-display text-[clamp(1.7rem,3.8vw,2.8rem)] leading-[1.3] tracking-tight">
          أداة إعراب واحدة تكفيك.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {whys.map((w) => (
          <article class="rounded-2xl border border-stone dark:border-coal-edge bg-paper dark:bg-coal-soft p-7 md:p-8">
            <h3 class="font-arabic-display text-h3 leading-tight mb-3">{w.t}</h3>
            <p class="font-arabic text-body text-ink/70 dark:text-mist/70 leading-loose">{w.b}</p>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <ArticleFaq items={faqs} lang="ar" />

  <Footer lang="ar" />
</BaseLayout>
