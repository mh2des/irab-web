---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import ArticleHero from '../components/ArticleHero.astro';
import ArticleSection from '../components/ArticleSection.astro';
import ArticleCta from '../components/ArticleCta.astro';
import ArticleFaq from '../components/ArticleFaq.astro';

const faqs = [
  { q: 'ما الفرق بين النحو والصرف؟', a: 'النحو علم العلاقات النحوية بين الكلمات في الجملة. الصرف علم بنية الكلمة المفردة وتصاريفها. النحو يسأل: ما إعراب هذه الكلمة ولماذا؟ الصرف يسأل: على أي وزن بُنيت؟ علمان متمايزان لا يغني أحدهما عن الآخر.' },
  { q: 'من أين جاء اسم النحو؟', a: 'في الرواية الكلاسيكية أنّ الإمام عليّ بن أبي طالب أمر أبا الأسود الدؤلي بكتابة أوّل رسالة في القواعد العربية وقال له: "انحُ هذا النحو". فأخذ العلم اسمه من تلك العبارة بمعنى "هذا الطريق" أو "هذا المنهج".' },
  { q: 'هل النحو أصعب من قواعد الإنجليزية؟', a: 'النحو أكثر منهجية من قواعد الإنجليزية, استثناءاته أقلّ وقواعده أكثر اطّرادًا. لكنّه أوسع نطاقًا: العلامات الإعرابية والإضافة والمثنى والمصدر لا توجد في الإنجليزية. أكثر الطلاب يجدونه أصعب أوّلًا، ثمّ أكثر منطقية بعد فهم الأنماط.' },
  { q: 'هل أحتاج النحو لقراءة الفصحى الحديثة؟', a: 'نعم لأي قراءة جادّة, الصحف والكتب والمقالات الأكاديمية والقرآن. اللهجات تسقط الحركات أحيانًا، لكنّ الفصحى المكتوبة تحفظها. بدون النحو ترى المفردات لكن لا تفهم البنية.' },
  { q: 'ما أفضل كتاب كلاسيكي في النحو؟', a: 'الآجرومية لابن آجرّوم هي الكتاب التعليمي الأمثل, قصير، منظّم، ومستعمل في المدارس الشرعية حول العالم منذ ٧٠٠ سنة. بعدها قطر الندى وألفية ابن مالك للمتقدّمين.' },
  { q: 'كم يحتاج تعلّم النحو؟', a: 'أكثر الطلاب يصلون إلى الكفاءة المتوسّطة في ٨-١٤ شهرًا من الدراسة اليومية. الإتقان الكامل, قراءة النصوص الكلاسيكية الصعبة بسهولة, يحتاج ٣-٥ سنوات. الزمن مرتبط بحجم التدريب لا بساعات الدراسة وحدها.' },
];
---
<BaseLayout
  lang="ar"
  hasEn
  title="ما هو النحو؟ علم بناء الجملة العربية · إعراب"
  description="النحو علم بناء الجملة العربية وقواعدها. دليل شامل لأساسيات النحو، أنواع الجملة، والعلاقة بين النحو والإعراب."
>
  <Nav lang="ar" />

  <ArticleHero
    lang="ar"
    eyebrow="مرجع"
    title="ما هو النحو؟"
    summary="النحو هو علم بناء الجملة العربية, مجموعة القواعد التي تحكم كيفية تركيب الكلمات في جمل ذات معنى. يحدّد بنية الجملة، يقرّر الإعراب، ويفسّر العلاقة بين كلّ كلمة. مع الصرف، يشكّل النحو أساس دراسة العربية الكلاسيكية. هذا الدليل يغطّي أساسيّات النحو، أنواع الجملة، وعلاقته بالإعراب."
  />

  <ArticleSection
    lang="ar"
    id="definition"
    title="الجواب المختصر"
    lead="النحو علم القواعد المختصّ ببناء الجملة, كيف تعمل الكلمات وكيف ترتبط داخل الجملة. الإعراب هو الناتج العملي (تحديد حالة كل كلمة)، والنحو هو الإطار النظري الذي يصدر عنه. هو القواعد بأوسع معنى: الأنظمة التي تجعل العربية لغة متماسكة لا قائمة كلمات."
  >
    <p>كلمة <span class="ar">نَحْو</span> تعني لغةً "الطريق" أو "الجهة". صارت اسمًا للعلم بحديث مشهور: حين أمر الإمام عليّ أبا الأسود الدؤلي بتدوين القواعد لحماية القرآن من اللحن، قال له على ما رُوي: <span class="ar">"انحُ هذا النحو"</span>, أي اتّبع هذا المنهج. فأخذ العلم اسمه من العبارة.</p>
    <p>يجيب النحو على أسئلة كـ: ما المبتدأ في هذه الجملة؟ ما الخبر؟ لماذا جاءت الكلمة مكسورة؟ ما عمل هذه الإضافة؟ بينما الإعراب تشخيص، النحو هو الصيدلية, منظومة القواعد وراء كلّ تشخيص.</p>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="vs-sarf"
    title="النحو والصرف, علمان متمايزان"
    lead="النحو يحكم العلاقات بين الكلمات في الجملة. الصرف يحكم بنية الكلمة نفسها واشتقاقها من الجذر. النحو يسأل: ما إعراب هذه الكلمة ولماذا؟ الصرف يسأل: على أيّ وزن بُنيت هذه الكلمة؟ كلاهما لازم في إتقان العربية ولا يغني أحدهما عن الآخر."
  >
    <p><strong>مثال صرفي:</strong> الجذر <span class="ar">ك-ت-ب</span> يولّد <span class="ar">كَتَبَ</span> و<span class="ar">يَكْتُبُ</span> و<span class="ar">كِتَاب</span> و<span class="ar">مَكْتَب</span>. الصرف يدرس هذه الأنماط.</p>
    <p><strong>مثال نحوي:</strong> في جملة <span class="ar">كَتَبَ الطَّالِبُ الدَّرْسَ</span>، النحو يقول إنّ <span class="ar">الطَّالِبُ</span> فاعل مرفوع، و<span class="ar">الدَّرْسَ</span> مفعول به منصوب.</p>
    <p>العلمان متشابكان: النحو يحدّد الدور، والصرف يحدّد البنية المناسبة لذلك الدور. <a href="/irab">الإعراب</a> هو الناتج العملي لتطبيقهما.</p>
  </ArticleSection>

  <ArticleCta lang="ar">
    <span slot="title">شاهد النحو يعمل.</span>
    جرّب التجربة المباشرة على الصفحة الرئيسية. ألصق أي جملة عربية وشاهد قواعد النحو تطبَّق, كل كلمة معرفة، كل علاقة موضّحة، خلال ثوانٍ.
  </ArticleCta>

  <ArticleSection
    lang="ar"
    id="sentence-types"
    title="نوعا الجملة العربية"
    lead="للعربية نوعا جملة أساسيّان: الجملة الاسمية والجملة الفعلية. الاسمية تبدأ باسم وتتألّف من مبتدأ وخبر. الفعلية تبدأ بفعل وتتألّف من فعل وفاعل ومفعول به اختياري. معرفة نوع الجملة هي الخطوة الأولى في أيّ تحليل نحوي."
  >
    <p><strong>الجملة الاسمية:</strong> <span class="ar">الْعِلْمُ نُورٌ</span>. كلٌّ من <span class="ar">الْعِلْمُ</span> (المبتدأ) و<span class="ar">نُورٌ</span> (الخبر) مرفوع.</p>
    <p><strong>الجملة الفعلية:</strong> <span class="ar">قَرَأَ الطَّالِبُ الْكِتَابَ</span>. يبدأ الفعل <span class="ar">قَرَأَ</span>، الفاعل <span class="ar">الطَّالِبُ</span> مرفوع، والمفعول به <span class="ar">الْكِتَابَ</span> منصوب.</p>
    <p>أكثر الآيات القرآنية تبدأ بأفعال، فالجملة الفعلية أكثر شيوعًا في العربية الكلاسيكية. الكتابة الإخبارية الحديثة تميل إلى الاسمية بسبب التقديم البلاغي.</p>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="building-blocks"
    title="مكوّنات النحو الأساسية"
    lead="كل جملة عربية مبنيّة من ثلاثة أصناف: الاسم والفعل والحرف. كلٌّ منها يخضع لقواعد نحوية مختلفة. الاسم يقبل الإعراب بالحالات الأربع. الفعل يقبل التصريف. الحرف لا يُعرب أبدًا, لكنّه يُعمل في غيره."
  >
    <ul>
      <li><strong>الاسم</strong>, يقبل الإعراب بأنواعه. يشمل أسماء الأعلام والأسماء العامّة والصفات وأسماء الإشارة والموصولات. أكثر النحو يدور حوله.</li>
      <li><strong>الفعل</strong>, يتصرّف بحسب الزمن والشخص والعدد. ثلاثة أزمان: الماضي والمضارع والأمر.</li>
      <li><strong>الحرف</strong>, لا يُصرَّف ولا يُعرَب. يشمل حروف الجرّ (<span class="ar">في، على</span>) وحروف العطف (<span class="ar">و، أو</span>) وحروف العمل (<span class="ar">إنّ، أنّ، كأنّ</span>). الحروف كثيرًا ما تُحدِث تغييرات إعرابية في غيرها.</li>
    </ul>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="how-to-learn"
    title="كيف تتعلّم النحو بفاعلية"
    lead="اختر منهجًا منظّمًا واحدًا وأكمله. اقرنه بالتدريب اليومي على نصّ حقيقي. التسلسل الكلاسيكي: الآجرومية → قطر الندى → ألفية ابن مالك. التسلسل الحديث: كتب المدينة → البيّنة → قراءة مخصّصة. أيًّا كان طريقك، الاستمرار يفوق الحدّة. ٣٠ دقيقة يوميًّا لسنة أفضل من ٣ ساعات أسبوعيًّا لثلاث سنوات."
  >
    <ol>
      <li><strong>اختر طريقك.</strong> الكلاسيكي (الآجرومية) للدراسة التقليدية. الحديث (كتب المدينة) للترتيب باللغة الإنجليزية. اختر واحدًا والتزم.</li>
      <li><strong>أتقن الأساسيات حتى تصير تلقائية.</strong> الحالات الأربع. الإضافة. الضمائر. تصاريف الأفعال.</li>
      <li><strong>اقرأ يوميًّا.</strong> ولو جملة. عربية حقيقية لا كتب فقط. الآيات القرآنية مثالية.</li>
      <li><strong>استعمل أداة إعراب لتقييم نفسك.</strong> أدوات مثل <a href="/">إعراب</a> تعطي تقييمًا فوريًّا لم يتوفّر في الدراسة الكلاسيكية.</li>
      <li><strong>اطلب معلّمًا.</strong> اجتماع أسبوعي مع من يعرف النحو يوفّر عليك أشهرًا من الحيرة.</li>
    </ol>
  </ArticleSection>

  <ArticleFaq lang="ar" items={faqs} />

  <Footer lang="ar" />
</BaseLayout>
