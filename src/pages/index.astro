  <style>
    .hero-word {
      opacity: 0;
      -webkit-clip-path: inset(0 100% 0 0);
      clip-path: inset(0 100% 0 0);
      animation:
        hero-fade 200ms 100ms forwards,
        hero-write-rtl 1600ms 100ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes hero-fade { to { opacity: 1; } }

    /* RTL: write the word from right to left (i.e. reveal mask shrinks from the LEFT side in RTL) */
    @keyframes hero-write-rtl {
      from { -webkit-clip-path: inset(0 100% 0 0); clip-path: inset(0 100% 0 0); }
      to   { -webkit-clip-path: inset(0 0 0 0);     clip-path: inset(0 0 0 0); }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-word { opacity: 1; animation: none; -webkit-clip-path: none; clip-path: none; }
    }
  </style>
