---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import DictionarySearch from '../../components/DictionarySearch.astro';
---
<BaseLayout lang="en" title="Smart Dictionary · Irab" description="AI powered Arabic dictionary: meanings, root, examples, and translation for any word.">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Nav lang="en" />
  <main class="px-6 py-14 md:py-20">
    <h1 class="text-center font-display text-[clamp(1.8rem,4vw,2.6rem)] leading-tight mb-3">Smart dictionary</h1>
    <p class="text-center text-ink/60 dark:text-mist/60 mb-10">Meanings, root, examples, and translation for any Arabic word.</p>
    <DictionarySearch lang="en" />
  </main>
  <Footer lang="en" />
</BaseLayout>
