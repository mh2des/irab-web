---
/**
 * /en/library: the classical grammar library (English chrome, Arabic books).
 * Targets the English long-tail for classical Arabic grammar references.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import Container from '../../components/Container.astro';
import { BOOKS, TOTAL_CHAPTERS, CATEGORIES, categoryCounts, categoryMeta, levelEn } from '../../lib/library';

const counts = categoryCounts();
const reader = (id: string) => `/en/library/read?b=${encodeURIComponent(id)}`;

const collection = {
  '@context': 'https://schema.org', '@type': 'CollectionPage',
  name: 'Classical Arabic Grammar Library: Irab',
  description: '47 classical works on Arabic grammar, morphology, rhetoric, and i\'rab, free to read on Irab.',
  url: 'https://irab.app/en/library',
};

const coverPalettes = [
  { bg: '#173847', ink: '#F8F6F1', edge: '#C8B26B' },
  { bg: '#F8F6F1', ink: '#173847', edge: '#7C4DFF' },
  { bg: '#1F789B', ink: '#FFFFFF', edge: '#D8C06B' },
  { bg: '#3F2A62', ink: '#FFFFFF', edge: '#C8B26B' },
  { bg: '#F2EFE8', ink: '#173847', edge: '#C2603C' },
];

const coverFor = (i: number) => coverPalettes[i % coverPalettes.length];
---
<BaseLayout
  lang="en"
  title="Classical Arabic Grammar Library: 47 Works | Irab"
  description="Read 47 classical Arabic works on nahw, sarf, balagha, and i'rab free on Irab: Ibn Hisham, Ibn Aqil, al-Ajurrumiyya and more, chapter by chapter with search and categories."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(collection)} is:inline />
  <Nav lang="en" />

  <main class="library-page">
    <section class="library-hero">
      <Container size="wide">
        <div class="library-hero-grid">
          <div class="library-copy">
            <p class="eyebrow mb-4" data-reveal>Library</p>
            <h1 class="font-display library-title" data-reveal data-reveal-delay="80">
              Classical Arabic books
            </h1>
            <p class="library-lead" data-reveal data-reveal-delay="160">
              A curated reading room for nahw, sarf, balagha, and i'rab references: organized clearly so you can open a full book or find a source fast.
            </p>
          </div>

          <div class="shelf-preview" aria-hidden="true" data-reveal data-reveal-delay="220">
            {BOOKS.slice(0, 5).map((b, i) => {
              const m = categoryMeta(b.category);
              const p = coverFor(i);
              return (
                <div class="preview-book" style={`--c:${m.color};--cover-bg:${p.bg};--cover-ink:${p.ink};--cover-edge:${p.edge};--rot:${i % 2 === 0 ? '-2deg' : '2deg'};`}>
                  <span>{m.en}</span>
                  <strong>{b.title}</strong>
                </div>
              );
            })}
          </div>
        </div>

        <div class="library-stats" data-reveal data-reveal-delay="280">
          <div>
            <strong>{BOOKS.length}</strong>
            <span>classical works</span>
          </div>
          <div>
            <strong>{TOTAL_CHAPTERS.toLocaleString('en')}</strong>
            <span>readable chapters</span>
          </div>
          <div>
            <strong>{CATEGORIES.length}</strong>
            <span>knowledge branches</span>
          </div>
          <div>
            <strong>Free</strong>
            <span>opens directly in browser</span>
          </div>
        </div>
      </Container>
    </section>

    <section class="library-browse">
      <Container size="wide">
        <div class="library-toolbar" data-lib-controls>
          <div class="search-wrap">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.3-4.3"/><circle cx="11" cy="11" r="7"/></svg>
            <input type="search" data-lib-search placeholder="Search a book or author..." />
          </div>

          <div class="filter-row" data-lib-filters aria-label="Book categories">
            <button type="button" class="lib-chip is-active" data-cat="all">
              <span>All books</span>
              <em>{BOOKS.length}</em>
            </button>
            {CATEGORIES.map((c) => (
              <button type="button" class="lib-chip" data-cat={c.key} style={`--c:${c.color}`}>
                <span>{c.en}</span>
                <em>{counts[c.key] ?? 0}</em>
              </button>
            ))}
          </div>
        </div>

        <div class="library-band" data-reveal>
          <div>
            <span>Trusted sources</span>
            <p>Grammar, rhetoric, morphology, and i'rab references in one place.</p>
          </div>
          <div>
            <span>Structured reading</span>
            <p>Every book opens chapter by chapter inside the reader.</p>
          </div>
          <div>
            <span>Fast access</span>
            <p>Search and filtering replace a long, hard-to-scan list.</p>
          </div>
        </div>

        <div class="library-grid" data-lib-grid>
          {BOOKS.map((b, i) => {
            const m = categoryMeta(b.category);
            const p = coverFor(i);
            const author = b.author && b.author !== 'غير معروف' ? b.author : 'Classical Arabic reference';
            return (
              <a href={reader(b.id)} class="book-card"
                 data-book data-cat={b.category}
                 data-title={b.title} data-author={b.author} data-level={b.level}
                 data-reveal data-reveal-delay={String(Math.min(i, 8) * 35)}
                 style={`--c:${m.color};--cover-bg:${p.bg};--cover-ink:${p.ink};--cover-edge:${p.edge};`}>
                <div class="book-cover" lang="ar" dir="rtl">
                  <div class="cover-mark">{b.category}</div>
                  <h2>{b.title}</h2>
                  <p>{author}</p>
                </div>
                <div class="book-info">
                  <div class="book-meta">
                    <span class="book-badge">{m.en}</span>
                    <span>{b.totalChapters.toLocaleString('en')} ch.</span>
                  </div>
                  <h3 lang="ar" dir="rtl">{b.title}</h3>
                  <p lang="ar" dir="rtl">{author}</p>
                  <div class="book-foot">
                    <span>{levelEn(b.level)}</span>
                    <strong>Read book <span aria-hidden="true">→</span></strong>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <p data-lib-empty class="hidden library-empty">No matching books.</p>
      </Container>
    </section>
  </main>

  <Footer lang="en" />
</BaseLayout>

<style>
  .library-page { overflow: clip; }
  .library-hero {
    position: relative;
    padding: clamp(3.5rem, 8vw, 6.5rem) 0 2rem;
    border-bottom: 1px solid var(--color-stone);
    background: color-mix(in srgb, var(--color-paper) 78%, white);
  }
  :global(.dark) .library-hero {
    background: color-mix(in srgb, var(--color-coal) 82%, var(--color-coal-soft));
    border-bottom-color: var(--color-coal-edge);
  }
  .library-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(21rem, 0.8fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .library-copy { max-width: 44rem; }
  .library-title {
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 1.04;
    color: var(--color-ink);
    letter-spacing: 0;
  }
  :global(.dark) .library-title { color: var(--color-mist); }
  .library-lead {
    max-width: 42rem;
    margin-top: 1.4rem;
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-ink) 72%, transparent);
  }
  :global(.dark) .library-lead { color: color-mix(in srgb, var(--color-mist) 72%, transparent); }

  .shelf-preview {
    min-height: 22rem;
    display: flex;
    align-items: end;
    justify-content: center;
    gap: 0.7rem;
    padding: 2rem 1.4rem 1.2rem;
    border: 1px solid var(--color-card-edge);
    background: var(--color-card);
    border-radius: 1rem;
    box-shadow: var(--shadow-lift);
  }
  :global(.dark) .shelf-preview {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .preview-book {
    width: clamp(3.3rem, 6vw, 5rem);
    height: clamp(12rem, 22vw, 17rem);
    transform: rotate(var(--rot));
    border-radius: 0.45rem 0.75rem 0.75rem 0.45rem;
    background: var(--cover-bg);
    color: var(--cover-ink);
    border: 1px solid color-mix(in srgb, var(--cover-edge) 70%, black);
    border-inline-start: 0.55rem solid var(--cover-edge);
    box-shadow: 0 18px 34px -22px rgb(23 56 71 / 0.55);
    writing-mode: vertical-rl;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 0.45rem;
    font-family: var(--font-arabic-display);
  }
  .preview-book strong {
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.25;
    font-weight: 700;
  }
  .preview-book span {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    opacity: 0.86;
  }

  .library-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .library-stats div {
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    border-radius: 0.75rem;
    padding: 1.05rem 1.2rem;
  }
  :global(.dark) .library-stats div {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .library-stats strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2.1rem;
    line-height: 1;
    color: var(--color-purple);
  }
  .library-stats span {
    display: block;
    margin-top: 0.45rem;
    font-size: var(--text-caption);
    color: color-mix(in srgb, var(--color-ink) 62%, transparent);
  }
  :global(.dark) .library-stats span { color: color-mix(in srgb, var(--color-mist) 68%, transparent); }

  .library-browse { padding: 2rem 0 5rem; }
  .library-toolbar {
    display: grid;
    grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .search-wrap {
    min-height: 4rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0 1.1rem;
    border-radius: 0.9rem;
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    box-shadow: var(--shadow-card);
  }
  :global(.dark) .search-wrap {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .search-wrap svg {
    width: 1.25rem;
    height: 1.25rem;
    flex: none;
    stroke: color-mix(in srgb, var(--color-ink) 55%, transparent);
    stroke-width: 2;
    fill: none;
  }
  :global(.dark) .search-wrap svg { stroke: color-mix(in srgb, var(--color-mist) 60%, transparent); }
  .search-wrap input {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--color-ink);
    font-size: var(--text-small);
  }
  :global(.dark) .search-wrap input { color: var(--color-mist); }
  .search-wrap input::placeholder { color: color-mix(in srgb, var(--color-ink) 42%, transparent); }
  :global(.dark) .search-wrap input::placeholder { color: color-mix(in srgb, var(--color-mist) 42%, transparent); }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.55rem;
  }
  .lib-chip {
    min-height: 3.4rem;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 1rem;
    border-radius: 0.8rem;
    color: var(--color-ink);
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    box-shadow: var(--shadow-soft);
    transition: transform .18s, border-color .18s, background-color .18s, color .18s;
  }
  :global(.dark) .lib-chip {
    color: var(--color-mist);
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .lib-chip:hover { transform: translateY(-2px); border-color: var(--c, var(--color-purple)); }
  .lib-chip.is-active {
    color: #fff;
    background: var(--c, var(--color-purple));
    border-color: var(--c, var(--color-purple));
  }
  .lib-chip span { font-size: var(--text-caption); font-weight: 800; }
  .lib-chip em {
    min-width: 1.7rem;
    height: 1.7rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    background: color-mix(in srgb, currentColor 10%, transparent);
  }

  .library-band {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border-radius: 0.9rem;
    border: 1px solid var(--color-card-edge);
    background: var(--color-card-edge);
    margin: 1.25rem 0 1.6rem;
  }
  :global(.dark) .library-band {
    border-color: var(--color-coal-edge);
    background: var(--color-coal-edge);
  }
  .library-band div {
    background: color-mix(in srgb, var(--color-card) 86%, var(--color-paper));
    padding: 1.1rem 1.2rem;
  }
  :global(.dark) .library-band div { background: var(--color-coal-soft); }
  .library-band span {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--color-purple);
    font-weight: 900;
    font-size: var(--text-caption);
  }
  .library-band p {
    color: color-mix(in srgb, var(--color-ink) 62%, transparent);
    font-size: var(--text-caption);
    line-height: 1.55;
  }
  :global(.dark) .library-band p { color: color-mix(in srgb, var(--color-mist) 66%, transparent); }

  .library-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  .book-card {
    display: grid;
    grid-template-columns: 7.2rem minmax(0, 1fr);
    gap: 1.05rem;
    min-height: 15.5rem;
    padding: 1rem;
    border-radius: 0.9rem;
    text-decoration: none;
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    box-shadow: var(--shadow-card);
    transition: transform .18s, border-color .18s, box-shadow .18s;
  }
  :global(.dark) .book-card {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .book-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--c) 62%, var(--color-card-edge));
    box-shadow: var(--shadow-lift);
  }
  .book-cover {
    position: relative;
    min-height: 13.5rem;
    padding: 1rem 0.72rem 0.85rem;
    border-radius: 0.45rem 0.8rem 0.8rem 0.45rem;
    background: var(--cover-bg);
    color: var(--cover-ink);
    border: 1px solid color-mix(in srgb, var(--cover-edge) 72%, black);
    border-inline-start: 0.55rem solid var(--cover-edge);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--cover-ink) 10%, transparent);
    overflow: hidden;
  }
  .book-cover::before,
  .book-cover::after {
    content: "";
    position: absolute;
    inset-inline: 0.7rem;
    height: 1px;
    background: color-mix(in srgb, var(--cover-edge) 76%, transparent);
  }
  .book-cover::before { top: 3.2rem; }
  .book-cover::after { bottom: 2.6rem; }
  .cover-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.6rem;
    min-height: 2rem;
    padding: 0.1rem 0.55rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--cover-edge) 78%, transparent);
    font-size: 0.9rem;
    font-weight: 900;
  }
  .book-cover h2 {
    margin-top: 1.35rem;
    font-family: var(--font-arabic-display);
    font-size: clamp(1.35rem, 2.8vw, 1.9rem);
    line-height: 1.28;
    font-weight: 700;
  }
  .book-cover p {
    position: absolute;
    inset-inline: 0.85rem;
    bottom: 0.75rem;
    font-size: 0.85rem;
    line-height: 1.4;
    opacity: 0.82;
  }
  .book-info {
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding: 0.15rem 0 0.1rem;
  }
  .book-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
    color: color-mix(in srgb, var(--color-ink) 55%, transparent);
    font-size: var(--text-caption);
    line-height: 1.4;
  }
  :global(.dark) .book-meta { color: color-mix(in srgb, var(--color-mist) 60%, transparent); }
  .book-badge {
    color: var(--c);
    background: color-mix(in srgb, var(--c) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 24%, transparent);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    font-weight: 900;
    white-space: nowrap;
  }
  .book-info h3 {
    color: var(--color-ink);
    font-family: var(--font-arabic-display);
    font-size: clamp(1.55rem, 2.5vw, 2rem);
    line-height: 1.32;
  }
  :global(.dark) .book-info h3 { color: var(--color-mist); }
  .book-info p {
    margin-top: 0.25rem;
    color: color-mix(in srgb, var(--color-ink) 58%, transparent);
    font-size: var(--text-caption);
    line-height: 1.55;
  }
  :global(.dark) .book-info p { color: color-mix(in srgb, var(--color-mist) 62%, transparent); }
  .book-foot {
    margin-top: auto;
    padding-top: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-top: 1px solid var(--color-stone);
  }
  :global(.dark) .book-foot { border-top-color: var(--color-coal-edge); }
  .book-foot span {
    color: color-mix(in srgb, var(--color-ink) 55%, transparent);
    font-size: var(--text-caption);
  }
  :global(.dark) .book-foot span { color: color-mix(in srgb, var(--color-mist) 58%, transparent); }
  .book-foot strong {
    color: var(--color-purple);
    font-size: var(--text-caption);
    white-space: nowrap;
  }
  .library-empty {
    padding: 4rem 1rem;
    text-align: center;
    color: color-mix(in srgb, var(--color-ink) 62%, transparent);
    font-size: var(--text-body);
  }
  :global(.dark) .library-empty { color: color-mix(in srgb, var(--color-mist) 66%, transparent); }

  @media (max-width: 1080px) {
    .library-hero-grid,
    .library-toolbar { grid-template-columns: 1fr; }
    .filter-row { justify-content: flex-start; }
    .library-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 720px) {
    .library-hero { padding-top: 2.5rem; }
    .shelf-preview { min-height: 17rem; padding-inline: 0.8rem; }
    .preview-book { width: 3.25rem; height: 12rem; }
    .library-stats,
    .library-band,
    .library-grid { grid-template-columns: 1fr; }
    .book-card { grid-template-columns: 6.8rem minmax(0, 1fr); min-height: 14rem; }
    .book-cover { min-height: 12rem; }
    .library-toolbar { gap: 0.75rem; }
  }
  @media (max-width: 430px) {
    .book-card { grid-template-columns: 1fr; }
    .book-cover { min-height: 14rem; }
  }
</style>

<script>
  const root = document;
  const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-book]'));
  const chips = Array.from(root.querySelectorAll<HTMLButtonElement>('.lib-chip'));
  const search = root.querySelector<HTMLInputElement>('[data-lib-search]');
  const empty = root.querySelector<HTMLElement>('[data-lib-empty]');
  let activeCat = 'all';

  const norm = (s: string) => (s || '')
    .replace(/[ً-ْٰـ]/g, '')
    .replace(/[إأآ]/g, 'ا').replace(/ى/g, 'ي').replace(/ة/g, 'ه')
    .toLowerCase().trim();

  function apply() {
    const qv = norm(search?.value || '');
    let shown = 0;
    cards.forEach((c) => {
      const okCat = activeCat === 'all' || c.dataset.cat === activeCat;
      const hay = norm((c.dataset.title || '') + ' ' + (c.dataset.author || '') + ' ' + (c.dataset.level || ''));
      const okSearch = !qv || hay.includes(qv);
      const show = okCat && okSearch;
      c.style.display = show ? '' : 'none';
      if (show) shown++;
    });
    if (empty) empty.classList.toggle('hidden', shown > 0);
  }

  chips.forEach((chip) => chip.addEventListener('click', () => {
    activeCat = chip.dataset.cat || 'all';
    chips.forEach((c) => c.classList.toggle('is-active', c === chip));
    apply();
  }));
  search?.addEventListener('input', apply);
</script>
