---
/**
 * /en/practice: mode-first practice landing (English).
 *
 * Indexed SEO surface for interactive i'rab practice. Firebase must stay out of
 * this static page; the signed-in tool lives at /en/practice/play.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';
import Nav from '../../components/Nav.astro';
import ArticleFaq from '../../components/ArticleFaq.astro';
import Footer from '../../components/sections/Footer.astro';

const faqs = [
  { q: 'Which practice mode should I start with?', a: 'Start with Write Your Sentence if you want AI feedback on a sentence you choose. Pick Curated Sentences when you want faster practice with fixed answer choices.' },
  { q: 'Is practice free?', a: 'Yes. You can start free after signing in. Irab Plus unlocks larger daily limits and more practice access.' },
  { q: 'Do I need to know every grammar chapter first?', a: 'No. Curated Sentences gives you structured choices, while Write Your Sentence explains mistakes word by word.' },
  { q: 'Is the correction instant?', a: 'Yes. After submitting your answers, you get a score and a word-by-word correction showing the right answer.' },
];

const learningResource = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  name: "Interactive Arabic i'rab practice with instant feedback: Irab",
  url: 'https://irab.app/en/practice',
  inLanguage: 'en',
  learningResourceType: ['Exercise', 'Quiz', 'Game'],
  teaches: ["i'rab", 'Arabic grammar', 'nahw'],
  educationalLevel: 'beginner to advanced',
  isAccessibleForFree: true,
  description:
    "Choose between writing your own sentence or practicing curated sentences, then parse the words and get instant correction.",
  provider: { '@type': 'Organization', name: 'Irab', url: 'https://irab.app' },
};
---
<BaseLayout
  lang="en"
  title="Interactive Arabic i'rab Practice · Irab"
  description="Practice i'rab two ways: write your own sentence for AI correction, or choose curated sentences and answer from clear options."
>
  <Schema slot="head" />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(learningResource)} is:inline />

  <Nav lang="en" />

  <main>
    <section class="px-6 pt-16 pb-12 md:pt-24 md:pb-16 text-center">
      <div class="max-w-3xl mx-auto">
        <p class="eyebrow justify-center mb-5">Practice i'rab</p>
        <h1 class="font-display text-[clamp(2.5rem,7vw,5rem)] leading-[1.05] tracking-tight text-ink dark:text-mist mb-6">
          Parse it yourself — don't just read the answer.
        </h1>
        <p class="text-body-lg text-ink/72 dark:text-mist/72 leading-relaxed max-w-2xl mx-auto mb-9">
          The core feature is writing your own i'rab and getting intelligent feedback. Ready-made sentences are the second path for faster guided drills.
        </p>
        <a href="/en/practice/play" class="btn-primary btn-lg">Start practicing</a>
      </div>
    </section>

    <section class="px-6 pb-14">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-4">
        <a href="/en/practice/play?mode=custom" class="practice-mode-card practice-mode-primary">
          <span class="practice-mode-pill">Golden feature</span>
          <h2 class="font-display text-3xl md:text-4xl leading-tight text-ink dark:text-mist">Write your i'rab and get AI feedback</h2>
          <p class="text-ink/68 dark:text-mist/70 leading-relaxed">Enter any Arabic sentence, write your analysis for each word, then review exactly what was right and what needs work.</p>
          <span class="practice-mode-cta">Start with this mode <span aria-hidden="true">→</span></span>
        </a>
        <a href="/en/practice/play?mode=curated" class="practice-mode-card">
          <span class="practice-mode-pill">Second option</span>
          <h2 class="font-display text-3xl md:text-4xl leading-tight text-ink dark:text-mist">Ready-made sentences with clear choices</h2>
          <p class="text-ink/68 dark:text-mist/70 leading-relaxed">Choose from the sentence bank and drill type, role, and case marker with guided options.</p>
          <span class="practice-mode-cta">Open ready-made sentences <span aria-hidden="true">→</span></span>
        </a>
      </div>
    </section>

    <section class="px-6 py-8 border-y border-ink/8 dark:border-mist/10 bg-white/70 dark:bg-ink-soft/55">
      <div class="max-w-6xl mx-auto grid gap-4 md:grid-cols-3">
        <div>
          <p class="text-label text-purple font-semibold mb-2">Sign in</p>
          <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">Save attempts and apply the correct daily practice limits.</p>
        </div>
        <div>
          <p class="text-label text-purple font-semibold mb-2">Word-by-word feedback</p>
          <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">See your answer beside the correct one without clutter.</p>
        </div>
        <div>
          <p class="text-label text-purple font-semibold mb-2">Short sessions</p>
          <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">A focused round is enough to test one rule or sharpen recall.</p>
        </div>
      </div>
    </section>

    <section class="px-6 py-14 md:py-20">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-[0.78fr_1.22fr] gap-10">
        <div>
          <p class="text-label uppercase tracking-[0.18em] text-purple font-semibold mb-4">How it works</p>
          <h2 class="font-display text-3xl md:text-5xl leading-tight text-ink dark:text-mist">Practice is built for solving, not just reading.</h2>
        </div>
        <div class="grid sm:grid-cols-3 gap-4">
          <div class="rounded-lg border border-ink/10 dark:border-mist/12 bg-white dark:bg-ink-soft p-5">
            <p class="text-3xl font-display text-purple mb-4">01</p>
            <h3 class="font-semibold text-ink dark:text-mist mb-2">Pick a mode</h3>
            <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">Write your own sentence or open one from the bank.</p>
          </div>
          <div class="rounded-lg border border-ink/10 dark:border-mist/12 bg-white dark:bg-ink-soft p-5">
            <p class="text-3xl font-display text-purple mb-4">02</p>
            <h3 class="font-semibold text-ink dark:text-mist mb-2">Answer yourself</h3>
            <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">Analyze the words instead of only viewing an answer.</p>
          </div>
          <div class="rounded-lg border border-ink/10 dark:border-mist/12 bg-white dark:bg-ink-soft p-5">
            <p class="text-3xl font-display text-purple mb-4">03</p>
            <h3 class="font-semibold text-ink dark:text-mist mb-2">Review correction</h3>
            <p class="text-sm leading-6 text-ink/62 dark:text-mist/62">See what was correct and what needs another pass.</p>
          </div>
        </div>
      </div>
    </section>

    <ArticleFaq items={faqs} lang="en" />
  </main>

  <Footer lang="en" />
</BaseLayout>

<style>
  .practice-mode-card {
    display: flex;
    min-height: 19rem;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.35rem, 3vw, 2rem);
    border-radius: 1rem;
    text-decoration: none;
    background: var(--color-card);
    border: 1px solid var(--color-card-edge);
    box-shadow: var(--shadow-card);
    transition: transform .2s var(--ease-out-quart), border-color .2s, box-shadow .2s;
  }
  .practice-mode-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--color-teal) 42%, var(--color-card-edge));
    box-shadow: var(--shadow-lift);
  }
  :global(.dark) .practice-mode-card {
    background: var(--color-coal-soft);
    border-color: var(--color-coal-edge);
  }
  .practice-mode-primary {
    border-color: color-mix(in srgb, var(--color-purple) 42%, var(--color-card-edge));
  }
  .practice-mode-pill {
    width: fit-content;
    padding: 0.28rem 0.75rem;
    border-radius: 999px;
    color: var(--color-purple-deep);
    background: color-mix(in srgb, var(--color-purple) 12%, white);
    font-size: var(--text-caption);
    font-weight: 900;
  }
  :global(.dark) .practice-mode-pill {
    color: color-mix(in srgb, var(--color-purple) 84%, white);
    background: color-mix(in srgb, var(--color-purple) 20%, var(--color-coal));
  }
  .practice-mode-cta {
    margin-top: auto;
    color: var(--color-purple-deep);
    font-weight: 900;
  }
  :global(.dark) .practice-mode-cta {
    color: color-mix(in srgb, var(--color-purple) 84%, white);
  }
</style>
