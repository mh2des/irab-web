---
/**
 * /en/practice — do-it-yourself i'rab + instant AI feedback (English).
 *
 * Targets "Arabic grammar practice / i'rab exercises / learn i'rab" for the
 * English learner + Islamic-studies audience no Arabic-only competitor serves,
 * and showcases the do-it-yourself-then-graded loop + gamification.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';
import Nav from '../../components/Nav.astro';
import ArticleHero from '../../components/ArticleHero.astro';
import ArticleSection from '../../components/ArticleSection.astro';
import ArticleCta from '../../components/ArticleCta.astro';
import ArticleFaq from '../../components/ArticleFaq.astro';
import Footer from '../../components/sections/Footer.astro';

const faqs = [
  { q: "How do I practice i'rab?", a: "In the Irab app you pick a sentence, then parse its words yourself: for each word you choose its type (noun/verb/particle), syntactic role, and case marker. The AI then grades you instantly and explains every mistake. That's active recall — real practice, not passive reading." },
  { q: 'Is practice free?', a: 'Yes — you start free with daily practice levels and sentences. Irab Plus unlocks the full 576-sentence bank, graded feedback on your own sentences, and all challenge chapters.' },
  { q: "What's the difference between reading i'rab and practicing it?", a: 'Reading a ready-made answer gives shallow familiarity that fades. Doing the i\'rab yourself and being corrected builds real grammatical intuition and moves the rule into long-term memory — which the answer-only AI tools never do.' },
  { q: 'Does it correct and explain my mistakes?', a: 'Yes. After each attempt you get a word-by-word correction showing the right answer vs yours, and why, with detailed AI explanations on your own sentences.' },
  { q: 'Is it good for beginners?', a: 'Yes. You start from the basics (nominative case) and progress to advanced structures across 7 chapters and 10 ranks. Each level builds on the last, with a daily challenge and streaks to keep the habit.' },
];

const learningResource = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  name: "Interactive Arabic i'rab practice with instant feedback — Irab",
  url: 'https://irab.app/en/practice',
  inLanguage: 'en',
  learningResourceType: ['Exercise', 'Quiz', 'Game'],
  teaches: ["i'rab", 'Arabic grammar', 'nahw'],
  educationalLevel: 'beginner to advanced',
  isAccessibleForFree: true,
  description:
    "Practice Arabic i'rab yourself and get instant AI correction and explanation, with challenges, levels, XP, and a leaderboard.",
  provider: { '@type': 'Organization', name: 'Irab', url: 'https://irab.app' },
};
---
<BaseLayout
  lang="en"
  title="Arabic i'rab Practice with Instant AI Feedback · Irab"
  description="Don't just read the i'rab — do it yourself and get instant word-by-word AI correction and explanation. 576 practice sentences, grading on your own sentences, plus challenges and levels."
>
  <Schema slot="head" />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(learningResource)} is:inline />

  <Nav lang="en" />

  <ArticleHero
    lang="en"
    eyebrow="Practice"
    title="Do the i'rab yourself — then get graded."
    summary="Most tools hand you the i'rab. Irab makes you do it: choose each word's type, role, and case marker, and the AI corrects you instantly and explains where you went wrong and why. 576 curated sentences, grading on your own sentences, and challenges that level you up — in the Irab app on iOS and Android."
  />

  {/* Try the interactive tool on the web (login-gated) */}
  <div class="px-6 -mt-2 mb-4 text-center">
    <a href="/en/practice/play" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full bg-purple hover:bg-purple-deep text-white font-medium tracking-tight lift">
      Try the interactive practice now
      <span aria-hidden="true">→</span>
    </a>
    <p class="text-caption text-ink/45 dark:text-mist/45 mt-3">Parse your own sentence in the browser — sign-in required.</p>
  </div>

  <ArticleSection
    lang="en"
    id="how"
    title="How i'rab practice works"
    lead="Three simple steps that turn a grammar rule from something you read into a skill you own."
  >
    <p><strong>1. Parse it yourself.</strong> For each word in the sentence, choose its type (noun, verb, particle), its syntactic role (subject, object, …), and its case marker. You do the analysis — not the machine.</p>
    <p><strong>2. Instant correction + explanation.</strong> The AI compares your answer to the correct i'rab word by word, shows where you were right and wrong, and explains why — with detailed feedback on your own sentences.</p>
    <p><strong>3. Level up.</strong> Earn XP, keep your daily streak, unlock 7 levels and 10 ranks, and compete on the leaderboard.</p>
  </ArticleSection>

  <ArticleSection
    lang="en"
    id="why"
    title="Why active practice makes the difference"
    lead="The brain keeps what it retrieves, not just what it reads. Active recall is the secret to mastery."
  >
    <p>Reading a ready-made i'rab gives a false sense of understanding that quickly evaporates. Doing the i'rab yourself and being corrected is what builds grammatical intuition and moves the rule into long-term memory.</p>
    <p>This is exactly what the other AI i'rab tools don't offer: they all give you the answer and stop. Irab alone closes the loop — you try, you're corrected, you learn from your mistake. That's what turns you into a real learner, not a passive recipient.</p>
  </ArticleSection>

  <ArticleSection
    lang="en"
    id="gamification"
    title="Learn by playing"
    lead="We turned learning grammar into a game you want to master, not a chore you postpone."
  >
    <p><strong>A 7-chapter campaign</strong> progressing from foundations to advanced structures, plus a <strong>daily challenge</strong> that keeps you on track.</p>
    <p><strong>XP, streaks, 10 ranks, and badges</strong> reward your consistency, and a <strong>leaderboard</strong> lets you compete with learners worldwide.</p>
    <p>Every session is short, enjoyable, and sticky — until i'rab becomes a daily habit, not a heavy task.</p>
  </ArticleSection>

  <ArticleCta lang="en">
    <span slot="title">Start practicing today.</span>
    Download the free Irab app on iOS and Android, and test your i'rab on your first sentence now — with instant correction and an explanation for every word.
  </ArticleCta>

  <ArticleFaq items={faqs} lang="en" />

  <Footer lang="en" />
</BaseLayout>
