---
/**
 * /en/library/read?b=<bookId>[&c=<chapterIndex>] — book reader (English chrome,
 * Arabic content). Streams the book bundle client-side, TOC + chapter, last-read.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import { LIBRARY_BASE } from '../../../lib/library';
---
<BaseLayout lang="en" noindex title="Book reader — Grammar Library | Irab" description="Read classical Arabic grammar books on Irab.">
  <Nav lang="en" />

  <main data-reader data-lang="en" data-base={LIBRARY_BASE} class="reader">
    <div class="reader-bar">
      <a href="/en/library" class="btn-ghost reader-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M19 12H5M11 19l-7-7 7-7"/></svg>
        <span>Library</span>
      </a>
      <div class="reader-bar-mid">
        <h1 data-book-title lang="ar" dir="rtl" class="font-arabic-display text-h3 leading-tight truncate"></h1>
        <p data-book-author lang="ar" dir="rtl" class="text-caption text-ink/65 dark:text-mist/65 truncate"></p>
      </div>
      <button type="button" data-toc-toggle class="icon-btn reader-toc-toggle" aria-label="Contents">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>

    <div data-reader-loading class="reader-load" aria-busy="true">
      <div class="skeleton h-8 w-2/3 rounded-md mb-5"></div>
      <div class="skeleton h-5 w-full rounded-md mb-3"></div>
      <div class="skeleton h-5 w-11/12 rounded-md mb-3"></div>
      <div class="skeleton h-5 w-10/12 rounded-md mb-3"></div>
    </div>

    <p data-reader-error class="hidden text-center py-20 text-body text-ink/70 dark:text-mist/70"></p>

    <div data-reader-grid class="reader-grid hidden">
      <aside data-toc class="reader-toc">
        <div class="reader-toc-head">
          <input type="search" data-toc-search placeholder="Search contents…" class="input" />
        </div>
        <ol data-toc-list lang="ar" dir="rtl" class="reader-toc-list"></ol>
      </aside>

      <article class="reader-content">
        <h2 data-chapter-title lang="ar" dir="rtl" class="font-arabic-display text-[clamp(1.6rem,4vw,2.4rem)] leading-tight mb-6"></h2>
        <div data-chapter-html lang="ar" dir="rtl" class="chapter-html"></div>
        <div class="reader-nav">
          <button type="button" data-prev class="btn-ghost"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M19 12H5M11 19l-7-7 7-7"/></svg><span>Previous</span></button>
          <span data-chapter-pos class="font-mono text-caption text-ink/60 dark:text-mist/60"></span>
          <button type="button" data-next class="btn-primary"><span>Next</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M5 12h14M13 5l7 7-7 7"/></svg></button>
        </div>
      </article>
    </div>

    <div data-toc-scrim class="reader-scrim hidden"></div>
  </main>
</BaseLayout>

<style>
  .reader { max-width: 80rem; margin: 0 auto; padding: 0 clamp(1rem, 4vw, 2rem) 4rem; }
  .reader-bar {
    position: sticky; top: 0; z-index: 20;
    display: flex; align-items: center; gap: 1rem; padding: 0.9rem 0;
    background: color-mix(in srgb, var(--color-paper) 85%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-card-edge); margin-bottom: 1.5rem;
  }
  :global(.dark) .reader-bar { background: color-mix(in srgb, var(--color-coal) 85%, transparent); border-bottom-color: var(--color-coal-edge); }
  .reader-back { padding: 0.55rem 1rem; font-size: var(--text-caption); flex-shrink: 0; }
  .reader-bar-mid { min-width: 0; flex: 1; }
  .reader-toc-toggle { display: none; }

  .reader-load { padding: 1rem 0; max-width: 44rem; }
  .reader-grid { display: grid; grid-template-columns: 19rem 1fr; gap: 2rem; align-items: start; }

  .reader-toc {
    position: sticky; top: 6rem; align-self: start;
    max-height: calc(100vh - 8rem); display: flex; flex-direction: column;
    background: var(--color-card); border: 1px solid var(--color-card-edge);
    border-radius: 1rem; box-shadow: var(--shadow-card); overflow: hidden;
  }
  :global(.dark) .reader-toc { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }
  .reader-toc-head { padding: 0.85rem; border-bottom: 1px solid var(--color-card-edge); }
  :global(.dark) .reader-toc-head { border-bottom-color: var(--color-coal-edge); }
  .reader-toc-list { list-style: none; overflow-y: auto; padding: 0.5rem; margin: 0; }
  .reader-toc-list li button {
    display: block; width: 100%; text-align: start;
    padding: 0.6rem 0.8rem; border-radius: 0.6rem; font-size: 1.15rem; line-height: 1.6;
    color: color-mix(in srgb, var(--color-ink) 80%, transparent);
    transition: background-color .15s, color .15s;
  }
  :global(.dark) .reader-toc-list li button { color: color-mix(in srgb, var(--color-mist) 80%, transparent); }
  .reader-toc-list li button:hover { background: color-mix(in srgb, var(--color-purple) 8%, transparent); color: var(--color-purple); }
  .reader-toc-list li button.is-active { background: color-mix(in srgb, var(--color-purple) 14%, transparent); color: var(--color-purple-deep); font-weight: 700; }
  :global(.dark) .reader-toc-list li button.is-active { color: color-mix(in srgb, var(--color-purple) 85%, white); }

  .reader-content {
    background: var(--color-card); border: 1px solid var(--color-card-edge);
    border-radius: 1rem; box-shadow: var(--shadow-card); padding: clamp(1.5rem, 4vw, 2.75rem);
    min-width: 0;
  }
  :global(.dark) .reader-content { background: var(--color-coal-soft); border-color: var(--color-coal-edge); }

  .reader-nav { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-card-edge); }
  :global(.dark) .reader-nav { border-top-color: var(--color-coal-edge); }
  .reader-nav button:disabled { opacity: 0.4; cursor: not-allowed; }

  .chapter-html { font-family: var(--font-arabic-classical); font-size: 1.5rem; line-height: 2.1; color: color-mix(in srgb, var(--color-ink) 90%, transparent); }
  :global(.dark) .chapter-html { color: color-mix(in srgb, var(--color-mist) 88%, transparent); }
  .chapter-html :global(h1), .chapter-html :global(h2), .chapter-html :global(h3) { font-family: var(--font-arabic-display); font-weight: 700; line-height: 1.4; margin: 1.6rem 0 0.9rem; color: var(--color-ink); }
  :global(.dark) .chapter-html :global(h1), :global(.dark) .chapter-html :global(h2), :global(.dark) .chapter-html :global(h3) { color: var(--color-mist); }
  .chapter-html :global(p) { margin: 0 0 1.1rem; }
  .chapter-html :global(.category-badge) { display: inline-block; padding: 0.2rem 0.7rem; border-radius: 999px; font-size: 1rem; font-family: var(--font-mono); background: color-mix(in srgb, var(--color-teal) 14%, transparent); color: var(--color-teal); }
  .chapter-html :global(.book-info-title) { font-family: var(--font-arabic-display); font-size: 2rem; font-weight: 700; display: block; margin-bottom: 0.6rem; }
  .chapter-html :global(table) { width: 100%; border-collapse: collapse; margin: 1.2rem 0; }
  .chapter-html :global(td), .chapter-html :global(th) { border: 1px solid var(--color-card-edge); padding: 0.6rem 0.9rem; }
  .chapter-html :global(a) { color: var(--color-purple); text-underline-offset: 3px; }

  @media (max-width: 860px) {
    .reader-toc-toggle { display: inline-flex; }
    .reader-grid { grid-template-columns: 1fr; }
    .reader-toc {
      position: fixed; inset-inline-end: 0; top: 0; bottom: 0; width: min(85vw, 22rem);
      max-height: none; border-radius: 0; z-index: 60; transform: translateX(100%);
      transition: transform .28s var(--ease-out-quart);
    }
    .reader-toc.is-open { transform: translateX(0); }
    .reader-scrim { position: fixed; inset: 0; background: rgb(0 0 0 / 0.45); z-index: 55; }
  }
</style>

<script>
  interface Chapter { id: number; title: string; html: string; }
  const root = document.querySelector<HTMLElement>('[data-reader]');
  if (root) {
    const base = root.dataset.base || 'https://qamoos.org/grammar/data';
    const q = <T extends Element>(s: string) => root.querySelector<T>(s)!;
    const params = new URLSearchParams(location.search);
    const bookId = params.get('b') || '';

    const loadingEl = q<HTMLElement>('[data-reader-loading]');
    const errorEl = q<HTMLElement>('[data-reader-error]');
    const gridEl = q<HTMLElement>('[data-reader-grid]');
    const titleEl = q<HTMLElement>('[data-book-title]');
    const authorEl = q<HTMLElement>('[data-book-author]');
    const tocList = q<HTMLOListElement>('[data-toc-list]');
    const tocSearch = q<HTMLInputElement>('[data-toc-search]');
    const toc = q<HTMLElement>('[data-toc]');
    const scrim = q<HTMLElement>('[data-toc-scrim]');
    const tocToggle = q<HTMLButtonElement>('[data-toc-toggle]');
    const chTitle = q<HTMLElement>('[data-chapter-title]');
    const chHtml = q<HTMLElement>('[data-chapter-html]');
    const chPos = q<HTMLElement>('[data-chapter-pos]');
    const prevBtn = q<HTMLButtonElement>('[data-prev]');
    const nextBtn = q<HTMLButtonElement>('[data-next]');

    const lastKey = `irab-lib-last:${bookId}`;
    let chapters: Chapter[] = [];
    let idx = 0;

    const fail = (msg: string) => { loadingEl.classList.add('hidden'); errorEl.textContent = msg; errorEl.classList.remove('hidden'); };
    const openToc = () => { toc.classList.add('is-open'); scrim.classList.remove('hidden'); };
    const closeToc = () => { toc.classList.remove('is-open'); scrim.classList.add('hidden'); };
    tocToggle.addEventListener('click', openToc);
    scrim.addEventListener('click', closeToc);

    function buildToc() {
      tocList.replaceChildren();
      chapters.forEach((c, i) => {
        const li = document.createElement('li');
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = c.title || `Chapter ${i + 1}`;
        btn.dataset.i = String(i);
        btn.addEventListener('click', () => { go(i); closeToc(); });
        li.appendChild(btn);
        tocList.appendChild(li);
      });
    }

    function go(i: number) {
      if (i < 0 || i >= chapters.length) return;
      idx = i;
      const c = chapters[i];
      chTitle.textContent = c.title || `Chapter ${i + 1}`;
      chHtml.innerHTML = c.html || '';
      chPos.textContent = `${i + 1} / ${chapters.length}`;
      prevBtn.disabled = i === 0;
      nextBtn.disabled = i === chapters.length - 1;
      tocList.querySelectorAll('button').forEach((b) => b.classList.toggle('is-active', b.dataset.i === String(i)));
      tocList.querySelector<HTMLElement>(`button[data-i="${i}"]`)?.scrollIntoView({ block: 'nearest' });
      try { localStorage.setItem(lastKey, String(i)); } catch {}
      const u = new URL(location.href); u.searchParams.set('c', String(i)); history.replaceState(null, '', u);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    prevBtn.addEventListener('click', () => go(idx - 1));
    nextBtn.addEventListener('click', () => go(idx + 1));

    tocSearch.addEventListener('input', () => {
      const v = (tocSearch.value || '').replace(/[ً-ْٰـ]/g, '').trim();
      tocList.querySelectorAll('li').forEach((li) => {
        const t = (li.textContent || '').replace(/[ً-ْٰـ]/g, '');
        (li as HTMLElement).style.display = !v || t.includes(v) ? '' : 'none';
      });
    });

    if (!bookId) { fail('No book selected. Go back to the library and pick a book.'); }
    else {
      fetch(`${base}/bundle/${encodeURIComponent(bookId)}.json`)
        .then((r) => { if (!r.ok) throw new Error(String(r.status)); return r.json(); })
        .then((bundle) => {
          chapters = Array.isArray(bundle?.chapters) ? bundle.chapters : [];
          if (!chapters.length) { fail("Couldn't load this book's chapters."); return; }
          titleEl.textContent = bundle.title || '';
          authorEl.textContent = bundle.author && bundle.author !== 'غير معروف' ? bundle.author : '';
          document.title = `${bundle.title || 'Book'} — Grammar Library | Irab`;
          buildToc();
          loadingEl.classList.add('hidden');
          gridEl.classList.remove('hidden');
          let start = parseInt(params.get('c') || '', 10);
          if (isNaN(start)) { try { start = parseInt(localStorage.getItem(lastKey) || '0', 10) || 0; } catch { start = 0; } }
          go(Math.min(Math.max(start, 0), chapters.length - 1));
        })
        .catch(() => fail("Couldn't load the book right now. Check your connection and try again."));
    }
  }
</script>
