---
/**
 * /en/app: the signed in web app home (English). Dashboard of all tools + plan
 * + usage. Login-gated, noindex (private surface). Firebase loads only here.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import AppHub from '../../components/AppHub.astro';
---
<BaseLayout lang="en" title="My app · Irab" description="All your Irab tools in one place.">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Nav lang="en" />
  <main class="px-6 py-12 md:py-16">
    <AppHub lang="en" />
  </main>
  <Footer lang="en" />
</BaseLayout>
