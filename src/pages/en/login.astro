---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import AuthForm from '../../components/AuthForm.astro';
---
<BaseLayout lang="en" title="Sign in · Irab" description="Sign in to your Irab account or create one: one account for web and the app.">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Nav lang="en" />
  <main class="px-6 py-14 md:py-20">
    <h1 class="text-center font-display text-[clamp(1.8rem,4vw,2.6rem)] leading-tight mb-3">Welcome to Irab</h1>
    <p class="text-center text-ink/60 dark:text-mist/60 mb-10">One account for web and the app.</p>
    <AuthForm lang="en" />
  </main>
  <Footer lang="en" />
</BaseLayout>
