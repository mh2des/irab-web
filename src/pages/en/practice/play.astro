---
/**
 * /en/practice/play: the interactive practice tool (English). Type a sentence,
 * do the i'rab yourself, get AI-graded word-by-word feedback. Login-gated,
 * noindex (the indexed SEO surface is /en/practice). Firebase loads only here.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/sections/Footer.astro';
import PracticePlay from '../../../components/PracticePlay.astro';
---
<BaseLayout lang="en" title="Practice i'rab · Irab" description="Do the i'rab yourself and get instant AI correction and explanation for every word.">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <Nav lang="en" />
  <main class="px-4 sm:px-6 py-8 md:py-12">
    <PracticePlay lang="en" />
  </main>
  <Footer lang="en" />
</BaseLayout>
