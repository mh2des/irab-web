---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import ArticleHero from '../components/ArticleHero.astro';
import ArticleSection from '../components/ArticleSection.astro';
import ArticleCta from '../components/ArticleCta.astro';
import ArticleFaq from '../components/ArticleFaq.astro';

const faqs = [
  { q: 'هل أستطيع لصق أي آية؟', a: 'نعم. ألصق أي آية في المحلّل وستحصل على إعراب كلمة بكلمة. التطبيق الحالي لا يحتوي على مصحف داخلي للتنقّل بين السور ولا تصدير سورة كاملة بنقرة واحدة.' },
  { q: 'هل التحليل دقيق للعربية الكلاسيكية؟', a: 'إعراب مصمّم للتعامل مع تراكيب العربية الكلاسيكية ويعطي تحليلًا نحويًا مفصلًا، لكن الذكاء الاصطناعي قد يخطئ في المواضع المحتملة. اعتبره مساعد دراسة سريعًا، وقارن الآيات الصعبة بمعلّم مؤهل أو مرجع متخصص.' },
  { q: 'هل يدعم القراءات السبع؟', a: 'لا توجد حاليًا وضعية مخصّصة للقراءات. استعمله كأداة إعراب عامة للنص العربي الكلاسيكي الملصق، لا كأداة مقارنة بين القراءات.' },
  { q: 'هل يمكنني إعراب سورة كاملة دفعة؟', a: 'لا. التطبيق الحالي يعرب النص الذي تلصقه أو تكتبه. لا يحتوي على تنقّل داخل السور ولا تصدير سورة كاملة بنقرة واحدة.' },
  { q: 'ماذا عن تفاصيل الكلمة؟', a: 'كل كلمة في نتيجة الإعراب تظهر بنوعها وإعرابها ووظيفتها وشرحها. للجذر والوزن والمعنى والترجمة والتصريف، استعمل المعجم الذكي.' },
  { q: 'هل يغني عن دراسة العلم على معلّم؟', a: 'لا. يسرّع التدريب لكنّه لا يبدّل الإطار العلمي الذي يضعه المعلّم. استعمله للتحقّق من إعرابك، التدريب الكثيف، وبناء الحاسّة بالحجم, جنبًا إلى جنب مع الدراسة المنهجية، لا بدلًا منها.' },
];
---
<BaseLayout
  lang="ar"
  hasEn
  title="إعراب القرآن مجاناً · تحليل نحوي بالذكاء الاصطناعي · إعراب"
  description="إعراب كلمة بكلمة للنص القرآني الملصق. تحليل نحوي مدعوم بالذكاء الاصطناعي لدراسة العربية الكلاسيكية، بحدود واضحة ودون وضع قراءات."
>
  <Nav lang="ar" />

  <ArticleHero
    lang="ar"
    eyebrow="أدوات القرآن"
    title="إعراب أيّ آية قرآنية, مجاناً."
    summary="إعراب يمنحك تحليلًا نحويًا فوريًّا كلمة بكلمة للنص القرآني الذي تلصقه. ألصق آية، احصل على نوع كل كلمة ووظيفتها وإعرابها وعلامتها وتفاصيلها والتشكيل الكامل وشرح الجملة. مناسب للدراسة الجادّة، مع حدود واضحة: لا وضع للقراءات، لا تصفّح سور، ولا تصدير سورة كاملة."
  />

  <ArticleCta lang="ar">
    <span slot="title">ابدأ بالتجربة المباشرة.</span>
    عرض التجربة المباشرة على الصفحة الرئيسية يستعمل محلّل الإعراب نفسه. جرّب الفاتحة أو ألصق أيّ آية, سترى النظام يعمل فورًا.
  </ArticleCta>

  <ArticleSection
    lang="ar"
    id="why-different"
    title="لماذا إعراب القرآن أصعب من إعراب الفصحى الحديثة"
    lead="العربية القرآنية كلاسيكية لا حديثة: مفردات أعتق، تراكيب أكثف، حذف، تقديم، وعناية بلاغية تظهر باستمرار. الأدوات العامة المبنية للصحافة أو الفصحى البسيطة كثيرًا ما تفوّت هذه العلاقات. مساعد الدراسة المفيد يجعل البنية النحوية صريحة بدل الاكتفاء بترجمة سطحية."
  >
    <p>تأمّل قوله تعالى في البقرة (٢): <span class="ar">ذَٰلِكَ ٱلْكِتَـٰبُ لَا رَيْبَ ۛ فِيهِ ۛ هُدًى لِّلْمُتَّقِينَ</span>. التركيب فيه اسم إشارة مقدَّم، وجملة منفية، وشبه جملة، وخبر نكرة. أدوات الإعراب العامة قد تتعثّر هنا؛ أمّا مساعد الدراسة الجيد فيعرض العلاقات النحوية بوضوح لتراجعها أنت أو معلّمك.</p>
    <p>نتيجة إعراب منظّمة لتحليل العربية الكلاسيكية: نوع الكلمة، الإعراب، الوظيفة والعلامة، الضمائر المستترة، متعلقات شبه الجملة، التشكيل، وشرح بنية الجملة. هذا يجعله نافعًا لدراسة القرآن مع بقاء النتيجة قابلة للمراجعة من معلّم بشري.</p>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="examples"
    title="ماذا ستحصل من النتائج"
    lead="ألصق آية الفاتحة الثانية (ٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَـٰلَمِينَ)، يعطيك إعراب: ٱلْحَمْدُ مبتدأ مرفوع، لِلَّهِ جار ومجرور خبره، رَبِّ بدل مجرور، ٱلْعَـٰلَمِينَ مضاف إليه مجرور. كل كلمة بوظيفتها وحالتها وشرحها."
  >
    <p>المُخرَج لكلّ كلمة معرَبة يشمل:</p>
    <ul>
      <li><strong>الحالة النحوية</strong>, مرفوع، منصوب، مجرور، مجزوم، أو مبني للمبنيات</li>
      <li><strong>الوظيفة</strong>, مبتدأ، خبر، فاعل، مفعول به، بدل، مضاف إليه، إلخ</li>
      <li><strong>علامة الإعراب</strong>, أيّ حركة أو حرف يُظهر الحالة (ضمّة، فتحة، كسرة، سكون، أو ياء جمع المذكّر السالم)</li>
      <li><strong>التفاصيل</strong>, كالضمير المستتر، متعلقات الجار والمجرور، أو وجه إعرابي محتمل</li>
      <li><strong>التشكيل الكامل</strong>, مع ملاحظات تصحيح عند وجود خطأ في النص المدخل</li>
      <li><strong>شرح بلغتك</strong>, لِمَ تأخذ الكلمة هذا الشكل، بلغة قراءتك</li>
    </ul>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="who-uses-it"
    title="لمن هذا"
    lead="طلاب القرآن الذين يريدون القراءة بفهم لا فك رموز. المعلّمون الذين يراجعون محاولات الإعراب. المترجمون والباحثون في التفسير. أهالي الحفّاظ الذين يساعدون أبناءهم على فهم ما يحفظون. كلّ من يريد التعامل بجدّية مع النصّ المقدّس."
  >
    <ul>
      <li><strong>طلاب القرآن</strong>, تدرّب على أيّ آية واحصل على تغذية راجعة بنيوية فورية</li>
      <li><strong>أهالي الحفّاظ</strong>, ساعد أبناءك على فهم معاني ما يحفظون لا الصوت فقط</li>
      <li><strong>معلّمو المدارس الشرعية</strong>, افحص الجملة قبل الصف وقارن تحليل إعراب بمحاولات الطلاب</li>
      <li><strong>المترجمون</strong>, تحقّق من قراءتك للآيات الصعبة بمراجع مستقلّ</li>
      <li><strong>باحثو التفسير</strong>, تحقّق سريعًا من القراءة البنيوية وراء التفاسير الكلاسيكية</li>
      <li><strong>المسلمون الجدد</strong>, ابدأ فهم بنية القرآن من اليوم الأوّل</li>
    </ul>
  </ArticleSection>

  <ArticleSection
    lang="ar"
    id="getting-started"
    title="ابدأ إعراب القرآن اليوم"
    lead="افتح التجربة المباشرة على الصفحة الرئيسية، ألصق أيّ آية، اضغط أعرب. سترى تحليلًا كلمة بكلمة فورًا. لحدود يومية أعلى، والتدريب، والتحديات، والمعاجم، والمكتبة، وOCR، وPDF، والتحليلات، وشهادات الإتقان السنوية، حمّل تطبيق إعراب على iOS أو Android."
  >
    <ol>
      <li><strong>جرّب التجربة أوّلًا.</strong> بدون تسجيل. <a href="/#demo">اضغط هنا</a> لتجربة محلّل الإعراب المباشر.</li>
      <li><strong>حمّل التطبيق.</strong> متاح مجانًا على <a href="https://play.google.com/store/apps/details?id=com.irabapp.arabic" target="_blank" rel="noopener">Google Play</a> و App Store. تتضمّن الخطّة المجانية تحليلات يومية.</li>
      <li><strong>ابنِ عادة يومية.</strong> آية يوميًّا، تُعرَب وتُفهَم. تتراكم إلى الإتقان أسرع مما تتوقّع.</li>
      <li><strong>اقرنه بالدراسة المنهجية.</strong> استعمل إعراب جنبًا إلى جنب مع منهجك العربي, البيّنة، كتب المدينة، أو دورة مسجدك المحلّي.</li>
    </ol>
  </ArticleSection>

  <ArticleFaq lang="ar" items={faqs} />

  <Footer lang="ar" />
</BaseLayout>
